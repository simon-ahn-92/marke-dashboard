def verify(output_path: str):
    print("\n[검증] 주요 지표 최신값:")
    check_cols = [
        ("일간데이터", ["SP500", "NASDAQ100", "금현물가격",
                        "VIX", "HY크레딧스프레드", "장단기금리차(10Y-2Y)",
                        "실질금리TIPS10Y", "달러인덱스DXY"]),
        ("월간데이터", ["미국CPI", "근원PCE", "미국실업률", "Sahm룰침체지표",
                        "컨퍼런스보드선행지수", "산업생산지수", "비농업취업자수",
                        "소매판매", "미국기준금리(FFR)"]),
        ("심리지수",   ["미시간대소비자심리", "금융스트레스지수(STL)", "Fear&Greed지수"]),
    ]
    for sheet, cols in check_cols:
        try:
            df = pd.read_excel(output_path, sheet_name=sheet,
                               index_col=0, parse_dates=True)
            print(f"\n  [{sheet}]")
            for col in cols:
                if col in df.columns:
                    last = df[col].dropna()
                    if not last.empty:
                        print(f"    {col:28s}: {last.iloc[-1]:>10.2f}  "
                              f"({last.index[-1].date()})")
                    else:
                        print(f"    {col:28s}: 데이터 없음")
                else:
                    print(f"    {col:28s}: 컬럼 없음")
        except Exception as e:
            print(f"  [{sheet}] 읽기 실패: {e}")


