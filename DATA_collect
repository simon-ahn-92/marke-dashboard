# 2. FRED 수집
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def collect_fred() -> dict:
    """
    반환:
      {
        "일간": {컬럼명: pd.Series, ...},
        "월간": {컬럼명: pd.Series, ...},
        "심리": {컬럼명: pd.Series, ...},
      }
    """
    print("\n[2/3] FRED 매크로 지표 수집...")
    fred    = Fred(api_key=FRED_KEY)
    buckets = {"일간": {}, "월간": {}, "심리": {}}

    for code, name, bucket in FRED_SERIES:
        try:
            s = fred.get_series(code)
            s = s[s.index >= START_DATE].dropna()

            # 주간 데이터(ICSA)는 월평균으로 변환
            if code == "ICSA":
                s = s.resample("ME").mean()
                s.name = name
            else:
                s.name = name

            buckets[bucket][name] = s
            print(f"  [OK] {name:28s} ({code:20s}) "
                  f"{len(s):4d}행  {s.index[-1].date()}")
        except Exception as e:
            print(f"  [실패] {name} ({code}): {e}")

    for b, d in buckets.items():
        print(f"  → {b}: {len(d)}개")
    return buckets


