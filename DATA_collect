# 3. CNN Fear & Greed 수집
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def fetch_fear_greed() -> pd.Series:
    """
    CNN Fear & Greed 지수 수집.
    엔드포인트가 불안정하므로 여러 URL 순차 시도.
    """
    endpoints = [
        "https://production.dataviz.cnn.io/index/fearandgreed/graphdata",
        "https://fear-and-greed-index.p.rapidapi.com/v1/fgi",   # RapidAPI (fallback)
    ]
    headers_list = [
        {"User-Agent": "Mozilla/5.0",
         "Referer": "https://edition.cnn.com/markets/fear-and-greed"},
        {"User-Agent": "Mozilla/5.0"},
    ]
    for url, headers in zip(endpoints, headers_list):
        try:
            resp = requests.get(url, headers=headers, timeout=15, verify=False)
            if resp.status_code != 200 or not resp.text.strip():
                continue
            data   = resp.json()
            scores = data.get("fear_and_greed_historical", {}).get("data", [])
            if not scores:
                continue

            s = pd.Series(
                {pd.to_datetime(item["x"], unit="ms"): float(item["y"])
                 for item in scores},
                name="Fear&Greed지수"
            ).sort_index()

            print(f"  [OK] Fear&Greed지수              "
                  f"{len(s):4d}행  {s.index[-1].date()}  현재={s.iloc[-1]:.1f}")
            return s
        except Exception:
            continue

    print("  [스킵] CNN Fear & Greed: 접근 불가 (엔드포인트 차단) → 심리지수 시트에서 제외")
    return pd.Series(dtype=float, name="Fear&Greed지수")


