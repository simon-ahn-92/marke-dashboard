# 1. EODHD 수집
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def fetch_eodhd_series(col_name: str, symbol: str, desc: str) -> pd.Series | None:
    url = (
        f"https://eodhd.com/api/eod/{symbol}"
        f"?api_token={EODHD_KEY}"
        f"&from={START_DATE}"
        f"&period=d"
        f"&fmt=json"
    )
    try:
        resp = requests.get(url, timeout=20, verify=False)
        resp.raise_for_status()
        data = resp.json()

        if not data or isinstance(data, dict):
            print(f"  [실패] {col_name:20s} ({symbol}) 데이터 없음")
            return None

        df = pd.DataFrame(data)
        df["date"] = pd.to_datetime(df["date"])
        df = df.set_index("date").sort_index()

        price_col = "adjusted_close" if "adjusted_close" in df.columns else "close"
        s = pd.to_numeric(df[price_col], errors="coerce").dropna()
        s.name = col_name

        print(f"  [OK] {col_name:20s} ({symbol:18s}) "
              f"{len(s):4d}행  {s.index[0].date()} ~ {s.index[-1].date()}")
        return s

    except Exception as e:
        print(f"  [실패] {col_name:20s} ({symbol}): {e}")
        return None


def _collect_group(asset_list: list, label: str) -> dict:
    results = {}
    for col_name, symbol, desc in asset_list:
        s = fetch_eodhd_series(col_name, symbol, desc)
        if s is not None:
            results[col_name] = s
        time.sleep(0.3)
    print(f"  → {label}: {len(results)}/{len(asset_list)}개 수집")
    return results


def collect_eodhd() -> tuple[dict, dict, dict]:
    """
    반환: (eodhd_main, cash_etfs, theme_etfs)
      eodhd_main : 일간데이터 시트에 합산되는 자산 (지수·원자재·채권·스타일ETF)
      cash_etfs  : 현금성ETF 시트 (SHV, BIL)
      theme_etfs : 테마ETF 시트 (SPY, SOXX 등 위성 ETF)
    """
    print("\n[1/3] EODHD 자산 가격 수집...")
    main  = _collect_group(EODHD_ASSETS, "일반 자산·스타일ETF")
    cash  = _collect_group(CASH_ETFS,   "현금성 ETF")
    theme = _collect_group(THEME_ETFS,  "테마 ETF")
    return main, cash, theme


