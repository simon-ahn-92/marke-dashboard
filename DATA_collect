# 4. 저장
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def _etf_sheet_df(etf_dict: dict) -> pd.DataFrame:
    """ETF 가격 dict → ffill 적용된 일별 DataFrame"""
    if not etf_dict:
        return pd.DataFrame()
    df = pd.DataFrame(etf_dict).sort_index()
    df.index.name = "Date"
    full_cal = pd.date_range(df.index.min(), df.index.max(), freq="D")
    return df.reindex(full_cal).ffill().dropna(how="all")


def save_to_excel(eodhd: dict, cash_etfs: dict, theme_etfs: dict,
                  fred: dict, fg: pd.Series, output_path: str):
    Path(output_path).parent.mkdir(parents=True, exist_ok=True)

    # ── 일간데이터 ──────────────────────────────
    daily_combined = {}
    daily_combined.update(fred["일간"])   # FRED 일간 지표 먼저
    daily_combined.update(eodhd)          # EODHD 자산 (같은 컬럼명 있으면 EODHD 우선)

    df_daily = pd.DataFrame(daily_combined).sort_index()
    df_daily.index.name = "Date"
    df_daily = df_daily[df_daily.index >= pd.Timestamp(START_DATE)]

    # ── Moody BAA-AAA 파생 스프레드 생성 ───────
    # BofA HY스프레드가 2023년 이전 데이터 없으므로
    # Moody BAA - AAA 스프레드를 HY크레딧스프레드 대용으로 사용
    if "Moody_BAA금리" in df_daily.columns and "Moody_AAA금리" in df_daily.columns:
        baa_aaa = df_daily["Moody_BAA금리"] - df_daily["Moody_AAA금리"]
        # 2023년 이후는 실제 BofA HY스프레드로 덮어씀 (더 정확)
        if "HY크레딧스프레드_단기" in df_daily.columns:
            baa_aaa_filled = baa_aaa.copy()
            hy_short = df_daily["HY크레딧스프레드_단기"].dropna()
            if not hy_short.empty:
                # 두 시리즈 겹치는 구간에서 레벨 조정 (접합)
                overlap = baa_aaa.loc[hy_short.index].dropna()
                if not overlap.empty:
                    offset = (hy_short.loc[overlap.index] - overlap).mean()
                    baa_aaa_filled = baa_aaa + offset
                baa_aaa_filled.loc[hy_short.index] = hy_short
            df_daily["HY크레딧스프레드"] = baa_aaa_filled
        else:
            df_daily["HY크레딧스프레드"] = baa_aaa
        print(f"  → HY크레딧스프레드 생성: Moody BAA-AAA 접합 "
              f"({df_daily['HY크레딧스프레드'].dropna().index[0].date()} ~)")

    # ── 주말·공휴일 빈 날짜 채우기 (캘린더 기준 매일 인덱스 → ffill) ──
    # 모든 날짜(주말 포함)를 인덱스로 확장한 뒤 가장 최근 종가로 채움
    full_calendar = pd.date_range(
        start=df_daily.index.min(),
        end=df_daily.index.max(),
        freq="D"
    )
    df_daily = (
        df_daily
        .reindex(full_calendar)          # 주말·공휴일 행 삽입 (NaN)
        .ffill()                         # 직전 영업일 값으로 채움
        .dropna(how="all")               # 수집 시작 이전 완전 빈 행 제거
    )
    df_daily.index.name = "Date"
    filled_days = full_calendar.difference(df_daily.dropna(how="all").index)
    print(f"  → 주말·공휴일 ffill 적용: 총 {len(full_calendar)}일 "
          f"(원본 {len(daily_combined[list(daily_combined.keys())[0]])}행 기준)")

    # ── 월간데이터 ──────────────────────────────
    df_monthly = pd.DataFrame(fred["월간"]).sort_index()
    df_monthly.index.name = "Date"
    df_monthly = df_monthly[df_monthly.index >= pd.Timestamp(START_DATE)]

    # ── 심리지수 (2016~) ─────────────────────────
    sentiment_all = dict(fred["심리"])
    if not fg.empty:
        sentiment_all["Fear&Greed지수"] = fg

    base_idx = sorted(set().union(*[s.index for s in sentiment_all.values()]))
    df_sentiment = pd.DataFrame(
        {name: s.reindex(pd.DatetimeIndex(base_idx), method="ffill")
         for name, s in sentiment_all.items()}
    ).sort_index()
    df_sentiment.index.name = "Date"
    df_sentiment = df_sentiment[df_sentiment.index >= "2016-01-01"]

    # ── 현금성 ETF / 테마 ETF DataFrame ─────────
    df_cash  = _etf_sheet_df(cash_etfs)
    df_theme = _etf_sheet_df(theme_etfs)

    # ── 수집현황 ────────────────────────────────
    rows = []
    for col_name, symbol, desc in EODHD_ASSETS:
        ok = col_name in eodhd
        rows.append({
            "출처": "EODHD", "시트": "일간데이터", "심볼": symbol,
            "컬럼명": col_name, "설명": desc, "수집": "✅" if ok else "❌",
            "행수": len(eodhd[col_name]) if ok else 0,
            "최신일": eodhd[col_name].index[-1].date() if ok else "",
        })
    for col_name, symbol, desc in CASH_ETFS:
        ok = col_name in cash_etfs
        rows.append({
            "출처": "EODHD", "시트": "현금성ETF", "심볼": symbol,
            "컬럼명": col_name, "설명": desc, "수집": "✅" if ok else "❌",
            "행수": len(cash_etfs[col_name]) if ok else 0,
            "최신일": cash_etfs[col_name].index[-1].date() if ok else "",
        })
    for col_name, symbol, desc in THEME_ETFS:
        ok = col_name in theme_etfs
        rows.append({
            "출처": "EODHD", "시트": "테마ETF", "심볼": symbol,
            "컬럼명": col_name, "설명": desc, "수집": "✅" if ok else "❌",
            "행수": len(theme_etfs[col_name]) if ok else 0,
            "최신일": theme_etfs[col_name].index[-1].date() if ok else "",
        })
    for code, name, bucket in FRED_SERIES:
        s = fred.get(bucket, {}).get(name)
        rows.append({
            "출처": "FRED", "시트": bucket + "데이터" if bucket != "심리" else "심리지수",
            "심볼": code, "컬럼명": name, "설명": bucket,
            "수집": "✅" if s is not None else "❌",
            "행수": len(s) if s is not None else 0,
            "최신일": s.index[-1].date() if s is not None else "",
        })
    rows.append({
        "출처": "CNN", "시트": "심리지수", "심볼": "fearandgreed",
        "컬럼명": "Fear&Greed지수", "설명": "심리",
        "수집": "✅" if not fg.empty else "❌",
        "행수": len(fg), "최신일": fg.index[-1].date() if not fg.empty else "",
    })
    df_summary = pd.DataFrame(rows)

    # ── 엑셀 저장 ───────────────────────────────
    with pd.ExcelWriter(output_path, engine="xlsxwriter",
                        date_format="yyyy-mm-dd") as writer:
        df_daily.to_excel(    writer, sheet_name="일간데이터")
        df_monthly.to_excel(  writer, sheet_name="월간데이터")
        df_sentiment.to_excel(writer, sheet_name="심리지수")
        if not df_cash.empty:
            df_cash.to_excel( writer, sheet_name="현금성ETF")
        if not df_theme.empty:
            df_theme.to_excel(writer, sheet_name="테마ETF")
        df_summary.to_excel(  writer, sheet_name="수집현황", index=False)

    print(f"\n[저장 완료]  {output_path}")
    print(f"  일간데이터 : {df_daily.shape[1]}컬럼  "
          f"{df_daily.index[0].date()} ~ {df_daily.index[-1].date()}")
    print(f"  월간데이터 : {df_monthly.shape[1]}컬럼")
    print(f"  심리지수   : {df_sentiment.shape[1]}컬럼  "
          f"{df_sentiment.index[0].date()} ~ {df_sentiment.index[-1].date()}")
    if not df_cash.empty:
        print(f"  현금성ETF  : {df_cash.shape[1]}컬럼  "
              f"{df_cash.index[0].date()} ~ {df_cash.index[-1].date()}")
    if not df_theme.empty:
        print(f"  테마ETF    : {df_theme.shape[1]}컬럼  "
              f"{df_theme.index[0].date()} ~ {df_theme.index[-1].date()}")
    print(f"  수집현황   : {len(rows)}개 항목")


