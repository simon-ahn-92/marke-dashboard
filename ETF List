def enrich_df(df):
    df = df.copy()
    # 추종지수 컬럼 찾기 (인덱스형/테마형/대체형: '추종지수' or '추종지수/전략')
    ref_col = next((c for c in df.columns if c.startswith("추종지수")), None)
    insert_at = df.columns.get_loc(ref_col) + 1 if ref_col else len(df.columns)

    new_cols = [
        ("AUM(억달러)",    [aum_map.get(t)     for t in df["티커"]]),
        ("상장연도",       [year_map.get(t)    for t in df["티커"]]),
        ("CAGR(%,연환산)", [cagr_map.get(t)    for t in df["티커"]]),
        ("운용보수(%)",    [expense_map.get(t) for t in df["티커"]]),
    ]
    for col, vals in new_cols:
        if col in df.columns:
            df[col] = vals
        else:
            df.insert(insert_at, col, vals)
            insert_at += 1
    return df

df_idx   = enrich_df(df_idx)
df_theme = enrich_df(df_theme)
df_alt   = enrich_df(df_alt)
