# 5. 엑셀 저장
# ══════════════════════════════════════════════════════════════
# 최종 컬럼 순서:
#   인덱스형: 티커·ETF명·분류·추종지수·AUM·상장연도·CAGR·운용보수·별점·선정이유
#   채권형:   티커·ETF명·분류·만기구분·추종지수·AUM·상장연도·CAGR·운용보수·별점·선정이유
COL_WIDTHS = {
    "인덱스형ETF": [8, 42, 14, 28, 10, 8, 10, 8, 6, 35],
    "테마형ETF":   [8, 42, 16, 30, 10, 8, 10, 8, 6, 35],
    "대체형ETF":   [8, 42, 18, 30, 10, 8, 10, 8, 6, 35],
    "채권형ETF":   [8, 42, 16, 14, 36, 10, 8, 10, 8, 6, 35],
}

with pd.ExcelWriter(OUTPUT, engine="xlsxwriter") as writer:
    wb = writer.book

    header_fmt = wb.add_format({
        "bold": True, "bg_color": "#1a1a2e", "font_color": "white",
        "border": 1, "align": "center", "valign": "vcenter",
        "font_size": 11, "font_name": "맑은 고딕"
    })
    cell_fmt = wb.add_format({
        "border": 1, "align": "left", "valign": "vcenter",
        "font_size": 10, "font_name": "맑은 고딕", "text_wrap": True
    })

    def write_sheet(df, sheet_name, cat_col, col_widths):
        df.to_excel(writer, sheet_name=sheet_name, index=False,
                    header=False, startrow=1)
        ws = writer.sheets[sheet_name]

        for col_num, col_name in enumerate(df.columns):
            ws.write(0, col_num, col_name, header_fmt)

        for col_idx, width in enumerate(col_widths[:len(df.columns)]):
            ws.set_column(col_idx, col_idx, width)

        prev_cat = None
        row_colors = ["#ffffff", "#f4f6f8"]
        for row_idx, (_, row) in enumerate(df.iterrows()):
            cur_cat = row[cat_col]
            bg = "#e8f4fd" if cur_cat != prev_cat else row_colors[row_idx % 2]
            prev_cat = cur_cat

            base_fmt = wb.add_format({
                "border": 1, "align": "left", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕",
                "text_wrap": True, "bg_color": bg
            })
            rnum_fmt = wb.add_format({
                "border": 1, "align": "right", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕", "bg_color": bg
            })
            rpct_fmt = wb.add_format({
                "border": 1, "align": "right", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕",
                "num_format": "0.00%", "bg_color": bg
            })
            rpos_fmt = wb.add_format({
                "border": 1, "align": "right", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕",
                "font_color": "#1a7a3a", "bold": True, "bg_color": bg
            })
            rneg_fmt = wb.add_format({
                "border": 1, "align": "right", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕",
                "font_color": "#c0392b", "bold": True, "bg_color": bg
            })
            rna_fmt = wb.add_format({
                "border": 1, "align": "center", "valign": "vcenter",
                "font_size": 10, "font_name": "맑은 고딕",
                "font_color": "#aaaaaa", "bg_color": bg
            })

            ws.set_row(row_idx + 1, 18)
            for col_idx, (col_name, val) in enumerate(zip(df.columns, row)):
                if col_name == "AUM(억달러)":
                    if val is None or (isinstance(val, float) and np.isnan(val)):
                        ws.write(row_idx + 1, col_idx, "N/A", rna_fmt)
                    else:
                        ws.write(row_idx + 1, col_idx, val, rnum_fmt)
                elif col_name == "상장연도":
                    if val is None or (isinstance(val, float) and np.isnan(val)):
                        ws.write(row_idx + 1, col_idx, "N/A", rna_fmt)
                    else:
                        ws.write(row_idx + 1, col_idx, int(val), rnum_fmt)
                elif col_name == "별점(5점)":
                    ws.write(row_idx + 1, col_idx, val, rnum_fmt)
                elif col_name == "운용보수(%)":
                    if val is None or (isinstance(val, float) and np.isnan(val)):
                        ws.write(row_idx + 1, col_idx, "N/A", rna_fmt)
                    else:
                        ws.write(row_idx + 1, col_idx, val / 100, rpct_fmt)
                elif col_name == "CAGR(%,연환산)":
                    if val is None or (isinstance(val, float) and np.isnan(val)):
                        ws.write(row_idx + 1, col_idx, "N/A", rna_fmt)
                    elif val >= 0:
                        ws.write(row_idx + 1, col_idx, f"+{val:.2f}%", rpos_fmt)
                    else:
                        ws.write(row_idx + 1, col_idx, f"{val:.2f}%", rneg_fmt)
                else:
                    ws.write(row_idx + 1, col_idx, val, base_fmt)

        ws.freeze_panes(1, 0)
        ws.autofilter(0, 0, len(df), len(df.columns) - 1)

    write_sheet(df_idx,   "인덱스형ETF", "분류", COL_WIDTHS["인덱스형ETF"])
    write_sheet(df_theme, "테마형ETF",   "테마", COL_WIDTHS["테마형ETF"])
    write_sheet(df_alt,   "대체형ETF",   "유형", COL_WIDTHS["대체형ETF"])
    write_sheet(df_bond,  "채권형ETF",   "분류", COL_WIDTHS["채권형ETF"])

    df_notes.to_excel(writer, sheet_name="주의사항", index=False,
                      header=False, startrow=1)
    ws_n = writer.sheets["주의사항"]
    for col_num, col_name in enumerate(df_notes.columns):
        ws_n.write(0, col_num, col_name, header_fmt)
    ws_n.set_column(0, 0, 20)
    ws_n.set_column(1, 1, 40)
    ws_n.set_column(2, 2, 60)
    for row_idx, (_, row) in enumerate(df_notes.iterrows()):
        ws_n.set_row(row_idx + 1, 30)
        for col_idx, val in enumerate(row):
            ws_n.write(row_idx + 1, col_idx, val, cell_fmt)

