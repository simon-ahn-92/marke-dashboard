def fetch_eodhd(ticker: str, retries: int = 3) -> float | None:
    """EODHD 월별 adjusted_close -> CAGR(%)
    rate limit 대비 최대 retries회 재시도.
    """
    url = (f"https://eodhd.com/api/eod/{ticker}.US"
           f"?api_token={TOKEN}&fmt=json&period=m")
    for attempt in range(retries):
        try:
            r = requests.get(url, verify=False, timeout=15)
            if r.status_code == 429:
                time.sleep(2 * (attempt + 1))
                continue
            if r.status_code != 200:
                return None
            data = r.json()
            if not data or len(data) < 2:
                if attempt < retries - 1:
                    time.sleep(1)
                    continue
                return None
            prices = [d["adjusted_close"] for d in data if d.get("adjusted_close")]
            if len(prices) < 2:
                return None
            p_first, p_last = prices[0], prices[-1]
            years = len(prices) / 12.0
            if p_first <= 0 or years < 0.5:
                return None
            return round(((p_last / p_first) ** (1 / years) - 1) * 100, 2)
        except Exception:
            if attempt < retries - 1:
                time.sleep(1)
    return None


def fetch_stockanalysis(ticker: str) -> tuple:
    """stockanalysis.com -> (AUM 억달러, 상장연도, 운용보수%)"""
    url = f"https://stockanalysis.com/etf/{ticker.lower()}/"
    try:
        r = cf.get(url, impersonate="chrome110", verify=False, timeout=15)
        if r.status_code != 200:
            return None, None, None
        text = r.text

        # AUM
        aum = None
        m = re.search(r">Assets</td><td[^>]*>(.*?)</td>", text)
        if m:
            raw = m.group(1).strip()
            nm = re.match(r"[\$]?([\d,]+\.?\d*)\s*([BMKTbmkt]?)", raw.replace(",", ""))
            if nm:
                num, unit = float(nm.group(1)), nm.group(2).upper()
                # 1B = 10억달러, 1M = 0.01억달러
                if unit == "B":
                    aum = round(num * 10, 1)
                elif unit == "M":
                    aum = round(num / 100, 2)
                elif unit == "T":
                    aum = round(num * 10000, 0)
                else:
                    aum = round(num, 1)

        # 상장연도
        year = None
        m2 = re.search(r">Inception Date</td><td[^>]*>(.*?)</td>", text)
        if m2:
            yr = re.search(r"(\d{4})", m2.group(1))
            if yr:
                year = int(yr.group(1))

        # 운용보수
        expense = None
        m3 = re.search(r">Expense Ratio</td><td[^>]*>(.*?)</td>", text)
        if m3:
            em = re.search(r"([\d.]+)%", m3.group(1))
            if em:
                expense = float(em.group(1))

        return aum, year, expense
    except Exception:
        return None, None, None


