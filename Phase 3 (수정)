def fetch_current_price(ticker: str) -> float | None:
    sym = ticker if "." in ticker else ticker + ".US"
    today = datetime.today()
    start = today.replace(month=max(today.month - 2, 1)).strftime("%Y-%m-%d")
    url = f"https://eodhd.com/api/eod/{sym}?api_token={EODHD_KEY}&fmt=json&from={start}"
    try:
        r = requests.get(url, timeout=15, verify=False)
        if r.status_code != 200:
            return None
        data = r.json()
        if not isinstance(data, list) or not data:
            return None
        return float(data[-1].get("adjusted_close") or data[-1].get("close"))
    except Exception:
        return None


