def load_category_candidates() -> dict:
    """카테고리별 [통과 + 스코어 정렬] DataFrame 반환"""
    cats = {}
    for sheet in PHASE2_CATEGORY_SHEETS:
        try:
            df = pd.read_excel(INPUT_PATH, sheet_name=sheet, header=3)
        except ValueError:
            df = pd.DataFrame()
            cats[sheet] = df
            continue
        if df.empty or "하드룰통과" not in df.columns:
            cats[sheet] = pd.DataFrame()
            continue
        df_pass = df[df["하드룰통과"].astype(str).str.startswith("통과")].copy()
        # 스코어 → numeric
        df_pass["_score"] = pd.to_numeric(df_pass["스코어"], errors="coerce")
        df_pass = df_pass.sort_values("_score", ascending=False).reset_index(drop=True)
        cats[sheet] = df_pass
    return cats


def pick_for_slot(category_key: str, cat_candidates: dict, used_tickers: set) -> dict:
    """슬롯 카테고리 → ticker_whitelist 우선 선정 + 중복 회피"""
    base_cat = category_key.split("#")[0]
    df = cat_candidates.get(base_cat, pd.DataFrame())
    whitelist = SLOT_TICKER_WHITELIST.get(base_cat, [])

    # 1순위: ticker_whitelist에 있는 후보만 (스코어 정렬 유지)
    primary, fallback = [], []
    for _, row in df.iterrows():
        tk = str(row.get("티커", ""))
        if not tk or tk in used_tickers:
            continue
        if tk in whitelist:
            primary.append(row)
        else:
            fallback.append(row)

    # whitelist 매칭 우선, 없으면 fallback
    if primary:
        return primary[0]
    if fallback:
        return fallback[0]
    return None


