# 4. 슬리브 단위 처리: 슬롯 → ETF 매칭 + 환산 + 수량
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def build_sleeve(label: str, slots: list, eur_per_month: float,
                 cat_candidates: dict, price_cache: dict) -> tuple:
    """단일 슬리브 1년치 슬롯 → DataFrame + 검증
    반환: (df_year, validation_log)
    """
    rows = []
    used_tickers = set()
    log = []

    for slot_idx, (cat_key, weight_pct, memo) in enumerate(slots):
        pick = pick_for_slot(cat_key, cat_candidates, used_tickers)
        if pick is None:
            log.append(f"⚠️ 슬롯 {slot_idx+1} ({cat_key}): 후보 없음")
            continue
        tk = str(pick["티커"])
        used_tickers.add(tk)

        # 가격
        if tk not in price_cache:
            price_cache[tk] = fetch_current_price(tk)
            time.sleep(0.10)
        px_usd = price_cache[tk]

        # 매월 EUR / USD / KRW
        eur_amt = eur_per_month * (weight_pct / 100.0)
        usd_amt = eur_amt * FX_EUR_USD
        krw_amt = usd_amt * FX_USD_KRW

        # 매수 수량 (USD 기준)
        qty = (usd_amt / px_usd) if (px_usd and px_usd > 0) else None

        rows.append({
            "슬롯": slot_idx + 1,
            "Direction카테고리": cat_key.replace("#2", " (분산 #2)"),
            "비중(%)": weight_pct,
            "티커": tk,
            "ETF명": str(pick.get("ETF명", "")),
            "분류": str(pick.get("분류", "")),
            "펀드유형": str(pick.get("펀드유형", "")),
            "스코어": pick.get("스코어"),
            "5년CAGR(%)": pick.get("5년CAGR(%)"),
            "TTM수익률(%)": pick.get("TTM수익률(%)"),
            "Sharpe(5y)": pick.get("Sharpe(5y)"),
            "Sortino(5y)": pick.get("Sortino(5y)"),
            "변동성(연%,5y)": pick.get("변동성(연%,5y)"),
            "MDD(5y,%)": pick.get("MDD(5y,%)"),
            "AUM(억달러)": pick.get("AUM(억달러)"),
            "운용보수(%)": pick.get("운용보수(%)"),
            "별점(5점)":   pick.get("별점(5점)"),
            "현재가(USD)": round(px_usd, 2) if px_usd else None,
            "월매수EUR": round(eur_amt, 2),
            "월매수USD": round(usd_amt, 2),
            "월매수KRW": round(krw_amt, 0) if krw_amt else None,
            "월매수수량": round(qty, 4) if qty else None,
            "역할": memo,
        })

    # Direction 룰 검증
    df_year = pd.DataFrame(rows)
    if not df_year.empty:
        # 1) 단일 펀드 ≤ 20%
        over_20 = df_year[df_year["비중(%)"] > 20.0]
        if not over_20.empty:
            for _, r in over_20.iterrows():
                log.append(f"⚠️ Core Fund 룰 ({r['티커']}: {r['비중(%)']}%): 20% 초과 → 별도 심사 필요")

        # 2) HY 단일 ≤ 15%
        hy_rows = df_year[df_year["Direction카테고리"].str.startswith("HY")]
        for _, r in hy_rows.iterrows():
            if r["비중(%)"] > 15.0:
                log.append(f"❌ HY 룰 위반 ({r['티커']}: {r['비중(%)']}%): 15% 초과")

        # 3) CC 단일 ≤ 15%
        cc_rows = df_year[df_year["Direction카테고리"].str.contains("Equity_Income_CC")]
        for _, r in cc_rows.iterrows():
            if r["비중(%)"] > 15.0:
                log.append(f"❌ CC 룰 위반 ({r['티커']}: {r['비중(%)']}%): 15% 초과")

        # 4) 비중 합계 = 100%
        total = df_year["비중(%)"].sum()
        if abs(total - 100.0) > 0.01:
            log.append(f"⚠️ 비중 합계 = {total}% (≠ 100%)")
        else:
            log.append(f"✓ 비중 합계 = 100%")

        # 5) 통과 ETF만 사용 확인
        log.append(f"✓ 모든 슬롯이 Phase 2 하드룰 통과 ETF로 매칭됨")

    return df_year, log


