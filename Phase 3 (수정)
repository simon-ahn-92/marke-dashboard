# 4-B. 포트폴리오 단위 가중 메트릭 계산
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def _to_float(x) -> float | None:
    """'12.81%' / '+5.06%' / '혼합분배' / N/A → float or None"""
    if pd.isna(x):
        return None
    if isinstance(x, (int, float)):
        return float(x)
    s = str(x).strip().replace("%", "").replace("+", "").replace(",", "")
    if not s or s in ("-", "N/A", "혼합분배"):
        return None
    try:
        return float(s)
    except ValueError:
        return None


def compute_portfolio_metrics(df: pd.DataFrame) -> dict:
    """포트폴리오 가중 메트릭 (단순 가중평균 — 공분산 미반영)
    - CAGR / TTM / Sharpe / Sortino: 정상 가중평균
    - Vol / MDD: 단순 가중평균 = 보수적 상한치 (실제는 분산효과로 더 낮음)
    """
    if df.empty:
        return {}

    weights = df["비중(%)"].astype(float).values / 100.0

    def num_col(col):
        return np.array([_to_float(v) or 0.0 for v in df[col]])

    cagr    = num_col("5년CAGR(%)")
    ttm     = num_col("TTM수익률(%)")
    sharpe  = num_col("Sharpe(5y)")
    sortino = num_col("Sortino(5y)")
    vol     = num_col("변동성(연%,5y)")
    mdd     = num_col("MDD(5y,%)")
    expense = num_col("운용보수(%)")
    star    = num_col("별점(5점)")

    return {
        "weighted_cagr":    float(np.dot(weights, cagr)),
        "weighted_ttm":     float(np.dot(weights, ttm)),
        "weighted_sharpe":  float(np.dot(weights, sharpe)),
        "weighted_sortino": float(np.dot(weights, sortino)),
        "weighted_vol":     float(np.dot(weights, vol)),
        "weighted_mdd":     float(np.dot(weights, mdd)),
        "weighted_expense": float(np.dot(weights, expense)),
        "weighted_star":    float(np.dot(weights, star)),
    }


