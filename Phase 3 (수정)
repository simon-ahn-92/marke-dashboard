        df, log = build_sleeve(label, slots, EUR_PER_MONTH_PERSONAL,
                                cat_candidates, price_cache)
        personal_results[label] = (df, log)
        for _, row in df.iterrows():
            print(f"    {str(row['티커']):6s} {str(row['ETF명'])[:34]:36s} "
                  f"{row['비중(%)']}% → EUR{row['월매수EUR']:>5.0f} / USD{row['월매수USD']:>5.0f}")

    print(f"\n[3/3] 엑셀 저장...")
    save_excel(company_results, personal_results)
    print(f"\n[Phase 3 완료] {OUTPUT_PATH}")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 6. Excel 저장
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def save_excel(company_results: dict, personal_results: dict):
    Path(OUTPUT_PATH).parent.mkdir(parents=True, exist_ok=True)

    OUT_COLS = ["슬롯", "Direction카테고리", "비중(%)", "티커", "ETF명", "분류",
                "펀드유형", "역할", "스코어", "5년CAGR(%)", "TTM수익률(%)",
                "Sharpe(5y)", "Sortino(5y)", "변동성(연%,5y)", "MDD(5y,%)",
                "AUM(억달러)", "운용보수(%)",
                "현재가(USD)", "월매수EUR", "월매수USD", "월매수KRW", "월매수수량"]

    with pd.ExcelWriter(OUTPUT_PATH, engine="xlsxwriter") as writer:
        wb = writer.book

        header_fmt = wb.add_format({
            "bold": True, "bg_color": "#1a1a2e", "font_color": "white",
            "border": 1, "align": "center", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕", "text_wrap": True,
        })
        intro_fmt = wb.add_format({
            "bold": True, "font_size": 12, "font_name": "맑은 고딕",
            "bg_color": "#1a7a3a", "font_color": "white", "border": 1,
            "align": "left", "valign": "vcenter",
        })
        meta_fmt = wb.add_format({
            "italic": True, "font_size": 10, "font_name": "맑은 고딕",
            "border": 1, "bg_color": "#fef5e7", "align": "left",
            "valign": "vcenter", "text_wrap": True,
        })
        cell_fmt = wb.add_format({
            "border": 1, "align": "center", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕"
        })
        cell_left = wb.add_format({
            "border": 1, "align": "left", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕"
        })
        money_fmt = wb.add_format({
            "border": 1, "align": "right", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕",
            "num_format": "#,##0",
        })
        money_eur = wb.add_format({
            "border": 1, "align": "right", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕",
            "num_format": '"€"#,##0.00',
        })
        money_usd = wb.add_format({
            "border": 1, "align": "right", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕",
            "num_format": '"$"#,##0.00',
        })
        money_krw = wb.add_format({
            "border": 1, "align": "right", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕",
            "num_format": '"₩"#,##0',
        })
        weight_fmt = wb.add_format({
            "bold": True, "border": 1, "align": "center", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕",
            "bg_color": "#ebf5fb",
        })
        log_ok_fmt = wb.add_format({
            "font_size": 10, "font_name": "맑은 고딕",
            "font_color": "#1a7a3a",
        })
        log_warn_fmt = wb.add_format({
            "font_size": 10, "font_name": "맑은 고딕",
            "font_color": "#c0392b", "bold": True,
        })

        def write_sleeve(label: str, df: pd.DataFrame, log: list, sheet_name: str,
                         eur_per_month: float = EUR_PER_MONTH_COMPANY):
            ws = wb.add_worksheet(sheet_name)
            writer.sheets[sheet_name] = ws

            # 환율/적립금 메타
            sleeve_amt = df["월매수EUR"].sum() if not df.empty else 0
            n_cols = len(OUT_COLS)

            # 인트로
            ws.merge_range(0, 0, 0, n_cols-1,
                f"【{label}】  매월 적립 EUR {sleeve_amt:,.0f}  ※ 환율 가정: EUR/USD={FX_EUR_USD}, USD/KRW={FX_USD_KRW:,.0f}",
                intro_fmt)
            ws.set_row(0, 28)

            # 검증 로그
            log_text = "  ".join(log) if log else ""
            ws.merge_range(1, 0, 1, n_cols-1, "검증: " + log_text, meta_fmt)
            ws.set_row(1, 30)

            # 헤더
            for ci, col in enumerate(OUT_COLS):
                ws.write(3, ci, col, header_fmt)

            # 컬럼 폭
            widths = []
            for col in OUT_COLS:
                if col == "슬롯": widths.append(5)
                elif col == "Direction카테고리": widths.append(22)
                elif col == "비중(%)": widths.append(8)
                elif col == "티커": widths.append(7)
                elif col == "ETF명": widths.append(32)
                elif col == "분류": widths.append(12)
                elif col == "펀드유형": widths.append(8)
                elif col == "역할": widths.append(22)
                elif col == "월매수KRW": widths.append(13)
                elif col in ("Sharpe(5y)", "Sortino(5y)"): widths.append(9)
                else: widths.append(10)
            for ci, w in enumerate(widths):
                ws.set_column(ci, ci, w)

            # 데이터
            for ri, (_, row) in enumerate(df.iterrows()):
                ws.set_row(4 + ri, 22)
                for ci, col in enumerate(OUT_COLS):
                    val = row.get(col)
                    if col == "비중(%)":
                        ws.write(4+ri, ci, f"{val}%" if pd.notna(val) else "", weight_fmt)
                    elif col in ("ETF명", "역할", "분류"):
                        ws.write(4+ri, ci, val if pd.notna(val) else "", cell_left)
                    elif col == "월매수EUR":
                        ws.write(4+ri, ci, float(val) if pd.notna(val) else "", money_eur)
                    elif col in ("월매수USD", "현재가(USD)"):
                        ws.write(4+ri, ci, float(val) if pd.notna(val) else "", money_usd)
                    elif col == "월매수KRW":
                        ws.write(4+ri, ci, float(val) if pd.notna(val) else "", money_krw)
                    elif col == "월매수수량":
                        ws.write(4+ri, ci,
                                 f"{float(val):.4f}주" if pd.notna(val) else "", cell_fmt)
                    elif col == "AUM(억달러)":
                        ws.write(4+ri, ci, float(val) if pd.notna(val) else "", money_fmt)
                    else:
                        ws.write(4+ri, ci, val if pd.notna(val) else "", cell_fmt)

            # 합계 행
            total_row = len(df) + 4
            n_cols = len(OUT_COLS)   # 22
            eur_idx = OUT_COLS.index("월매수EUR")
            usd_idx = OUT_COLS.index("월매수USD")
            krw_idx = OUT_COLS.index("월매수KRW")
            qty_idx = OUT_COLS.index("월매수수량")

            ws.write(total_row, 0, "합계", header_fmt)
            ws.write(total_row, 1, "", header_fmt)
            ws.write(total_row, 2, f"{df['비중(%)'].sum()}%", header_fmt)
            for ci in range(3, eur_idx):
                ws.write(total_row, ci, "", header_fmt)
            ws.write(total_row, eur_idx, df["월매수EUR"].sum() if not df.empty else 0, money_eur)
            ws.write(total_row, usd_idx, df["월매수USD"].sum() if not df.empty else 0, money_usd)
            ws.write(total_row, krw_idx, df["월매수KRW"].sum() if not df.empty else 0, money_krw)
            ws.write(total_row, qty_idx, "", cell_fmt)
            ws.set_row(total_row, 24)

            # ── 포트폴리오 가중 메트릭 박스 ─────────────
            metrics = compute_portfolio_metrics(df)
            if metrics:
                # 박스 시작 행 (합계 다음 +2)
                box_row = total_row + 2

                # 적립 시뮬레이션 (개월 수: Y1=12, Y2=24, Y3=36, Final=36 누적)
                if "Y1" in label or "Y1" in sheet_name:
                    n_months_at_end = 12
                elif "Y2" in label or "Y2" in sheet_name:
                    n_months_at_end = 24
                elif "Y3" in label or "Y3" in sheet_name or "Final" in label:
                    n_months_at_end = 36
                else:  # Personal
                    n_months_at_end = 36   # 36개월 시점 비교

                eur_cum  = eur_per_month * n_months_at_end
                usd_cum  = eur_cum * FX_EUR_USD
                krw_cum  = usd_cum * FX_USD_KRW

                # 예상 연간 인컴 (TTM 가중 × 누적 자산)
                ttm_pct  = metrics["weighted_ttm"]
                annual_income_usd = usd_cum * (ttm_pct / 100.0)
                annual_income_krw = annual_income_usd * FX_USD_KRW

                # 박스 포맷
                box_label = wb.add_format({
                    "bold": True, "bg_color": "#1a7a3a",
                    "font_color": "white", "border": 1,
                    "align": "left", "valign": "vcenter",
                    "font_size": 11, "font_name": "맑은 고딕"
                })
                metric_label = wb.add_format({
                    "bold": True, "bg_color": "#ebf5fb",
                    "border": 1, "align": "left", "valign": "vcenter",
                    "font_size": 10, "font_name": "맑은 고딕"
                })
                metric_val = wb.add_format({
                    "border": 1, "align": "center", "valign": "vcenter",
                    "font_size": 10, "font_name": "맑은 고딕",
                    "bg_color": "#fef5e7", "bold": True,
                })
                metric_val_pos = wb.add_format({
                    "border": 1, "align": "center", "valign": "vcenter",
                    "font_size": 10, "font_name": "맑은 고딕",
                    "bg_color": "#d5f5e3", "font_color": "#1a7a3a", "bold": True,
                })
                metric_val_neg = wb.add_format({
                    "border": 1, "align": "center", "valign": "vcenter",
                    "font_size": 10, "font_name": "맑은 고딕",
                    "bg_color": "#fadbd8", "font_color": "#c0392b", "bold": True,
                })

                # 박스 헤더
                ws.merge_range(box_row, 0, box_row, 21,
                    "📊 포트폴리오 단위 가중 메트릭 (비중 가중평균 — Vol/MDD는 분산효과 미반영 보수적 상한)",
                    box_label)
                ws.set_row(box_row, 24)
                box_row += 1

                # 메트릭 4행 × 5열
                metrics_layout = [
                    [
                        ("가중 5년 CAGR",  f"{metrics['weighted_cagr']:+.2f}%",
                         metric_val_pos if metrics['weighted_cagr'] > 0 else metric_val_neg),
                        ("가중 TTM 수익률", f"{metrics['weighted_ttm']:.2f}%",
                         metric_val_pos if metrics['weighted_ttm'] >= 3.0 else metric_val),
                        ("가중 Sharpe",    f"{metrics['weighted_sharpe']:.2f}",
                         metric_val_pos if metrics['weighted_sharpe'] >= 0.5 else metric_val),
                        ("가중 Sortino",   f"{metrics['weighted_sortino']:.2f}",
                         metric_val_pos if metrics['weighted_sortino'] >= 0.7 else metric_val),
                    ],
                    [
                        ("가중 변동성(연%)", f"{metrics['weighted_vol']:.2f}%",
                         metric_val_pos if metrics['weighted_vol'] <= 12 else
                         (metric_val_neg if metrics['weighted_vol'] >= 18 else metric_val)),
                        ("가중 MDD(5y)",    f"{metrics['weighted_mdd']:+.2f}%",
                         metric_val_neg if metrics['weighted_mdd'] <= -25 else
                         (metric_val_pos if metrics['weighted_mdd'] >= -15 else metric_val)),
                        ("가중 운용보수",   f"{metrics['weighted_expense']:.3f}%",
                         metric_val_pos if metrics['weighted_expense'] < 0.30 else metric_val),
                        ("가중 별점",       f"{metrics['weighted_star']:.2f}/5",
                         metric_val_pos if metrics['weighted_star'] >= 4.0 else metric_val),
                    ],
                ]
                for ri, row_data in enumerate(metrics_layout):
                    ws.set_row(box_row + ri, 22)
                    col_pos = 0
                    for label_, val_, fmt_ in row_data:
                        ws.merge_range(box_row+ri, col_pos, box_row+ri, col_pos+1,
                                        label_, metric_label)
                        ws.merge_range(box_row+ri, col_pos+2, box_row+ri, col_pos+4,
                                        val_, fmt_)
                        col_pos += 5
                box_row += len(metrics_layout)

                # 적립 시뮬레이션 박스
                ws.merge_range(box_row, 0, box_row, 21,
                    f"💰 적립 시뮬레이션 ({n_months_at_end}개월 시점 누적)", box_label)
                ws.set_row(box_row, 24)
                box_row += 1

                ws.set_row(box_row, 22)
                ws.merge_range(box_row, 0,  box_row, 1,
                                "월 적립", metric_label)
                ws.merge_range(box_row, 2,  box_row, 5,
                                f"EUR {eur_per_month:,.0f}", metric_val)
                ws.merge_range(box_row, 6,  box_row, 9,
                                f"= USD ${eur_per_month*FX_EUR_USD:,.0f}", metric_val)
                ws.merge_range(box_row, 10, box_row, 14,
                                f"= ₩{eur_per_month*FX_EUR_USD*FX_USD_KRW:,.0f}", metric_val)
                ws.merge_range(box_row, 15, box_row, 21,
                                "", cell_fmt)
                box_row += 1

                ws.set_row(box_row, 22)
                ws.merge_range(box_row, 0,  box_row, 1,
                                f"{n_months_at_end}개월 누적", metric_label)
                ws.merge_range(box_row, 2,  box_row, 5,
                                f"EUR {eur_cum:,.0f}", metric_val_pos)
                ws.merge_range(box_row, 6,  box_row, 9,
                                f"= USD ${usd_cum:,.0f}", metric_val_pos)
                ws.merge_range(box_row, 10, box_row, 14,
                                f"= ₩{krw_cum:,.0f}", metric_val_pos)
                ws.merge_range(box_row, 15, box_row, 21,
                                "", cell_fmt)
                box_row += 1

                # 인컴 추정 (Y3/Final/Personal만)
                if n_months_at_end >= 24 and ttm_pct > 0:
                    box_row += 1
                    ws.merge_range(box_row, 0, box_row, 21,
                        "📈 예상 연간 인컴 (TTM 가중 × 누적 자산)", box_label)
                    ws.set_row(box_row, 24)
                    box_row += 1

                    target_min, target_max = 10000, 12000
                    if eur_per_month < 1000:   # Personal sleeve
                        target_min, target_max = 0, 0   # 인컴 목표 없음 (재투자)
                        target_text = "Direction: 분배금 100% 재투자 (목표 없음)"
                        income_status_fmt = metric_val
                    elif annual_income_usd < target_min:
                        target_text = f"⚠️ Direction 목표 USD $10K-$12K 미달 ({annual_income_usd-target_min:+,.0f})"
                        income_status_fmt = metric_val_neg
                    elif annual_income_usd > 14000:
                        target_text = f"⚠️ Direction 목표 초과 (과도한 인컴 — 신용/CC 집중도 확인)"
                        income_status_fmt = metric_val_neg
                    elif annual_income_usd <= target_max:
                        target_text = f"✓ Direction 목표 USD $10K-$12K 달성"
                        income_status_fmt = metric_val_pos
                    else:
                        target_text = f"○ Direction 상회 (적정 범위 내)"
                        income_status_fmt = metric_val_pos

                    ws.set_row(box_row, 22)
                    ws.merge_range(box_row, 0, box_row, 4,
                                    f"가중 TTM 수익률", metric_label)
                    ws.merge_range(box_row, 5, box_row, 9,
                                    f"{ttm_pct:.2f}%", metric_val)
                    ws.merge_range(box_row, 10, box_row, 14,
                                    f"× USD ${usd_cum:,.0f}", metric_val)
                    ws.merge_range(box_row, 15, box_row, 21,
                                    f"= USD ${annual_income_usd:,.0f} (₩{annual_income_krw:,.0f})",
                                    income_status_fmt)
                    box_row += 1

                    ws.set_row(box_row, 22)
                    ws.merge_range(box_row, 0, box_row, 21, target_text, income_status_fmt)

            ws.freeze_panes(4, 4)

        # 1. 거버넌스 슬리브 (4 시트: Y1, Y2, Y3, Final)
        for label, (df, log) in company_results.items():
            short = label.split("—")[0].strip()  # "Y1" 등
            short = short.replace(" ", "_")[:18]
            write_sleeve(label, df, log, short, eur_per_month=EUR_PER_MONTH_COMPANY)

        # 2. 개인 슬리브
        for label, (df, log) in personal_results.items():
            write_sleeve(label, df, log, "Personal", eur_per_month=EUR_PER_MONTH_PERSONAL)

        # 3. Direction 룰 검증 종합
        check_rows = []
        check_rows.append(("연차", "총 ETF 수", "비중 합계", "단일 펀드 최대",
                           "HY 비중", "CC 비중", "Direction 룰", "비고"))
        for label, (df, _) in company_results.items():
            short = label.split("—")[0].strip()
            n = len(df)
            tot = df["비중(%)"].sum() if not df.empty else 0
            single_max = df["비중(%)"].max() if not df.empty else 0
            hy = df[df["Direction카테고리"].str.startswith("HY")]["비중(%)"].sum() if not df.empty else 0
            cc = df[df["Direction카테고리"].str.contains("Equity_Income_CC")]["비중(%)"].sum() if not df.empty else 0

            rules = []
            if single_max > 20: rules.append("단일>20% 위반")
            if hy > 15: rules.append("HY>15% 위반")
            if cc > 30: rules.append("CC 합>30% 주의")  # 분산 후 합산 30% 한도
            note = " / ".join(rules) if rules else "✓ 통과"
            check_rows.append((short, n, f"{tot:.1f}%", f"{single_max:.1f}%",
                                f"{hy:.1f}%", f"{cc:.1f}%", note,
                                f"매월 EUR {df['월매수EUR'].sum():,.0f}"))

        df_check = pd.DataFrame(check_rows[1:], columns=check_rows[0])
        df_check.to_excel(writer, sheet_name="Direction룰검증",
                          index=False, header=False, startrow=1)
        ws_v = writer.sheets["Direction룰검증"]
        for ci, col in enumerate(df_check.columns):
            ws_v.write(0, ci, col, header_fmt)
        for ci in range(8):
            ws_v.set_column(ci, ci, 18)
        for ri, (_, row) in enumerate(df_check.iterrows()):
            ws_v.set_row(ri + 1, 24)
            for ci, val in enumerate(row):
                ws_v.write(ri + 1, ci, str(val), cell_fmt)

        # 4. 환율/적립금 가정
        assump_rows = [
            ("EUR/USD 환율 가정", FX_EUR_USD),
            ("USD/KRW 환율 가정", FX_USD_KRW),
            ("거버넌스 월 적립", f"EUR {EUR_PER_MONTH_COMPANY:,.0f}"),
            ("개인 월 적립",      f"EUR {EUR_PER_MONTH_PERSONAL:,.0f}"),
            ("적립 기간",         f"{N_MONTHS}개월"),
            ("36개월 누적 (거버넌스)", f"EUR {EUR_PER_MONTH_COMPANY * N_MONTHS:,.0f}"),
            ("36개월 누적 (개인)",     f"EUR {EUR_PER_MONTH_PERSONAL * N_MONTHS:,.0f}"),
            ("평가 기준일",       TODAY.strftime("%Y-%m-%d")),
            ("",                  ""),
            ("주의",              "환율은 변동 가능. 실제 매월 매수액은 당시 환율로 재계산 필요"),
            ("주의",              "현재가는 본 평가 시점 종가. 매월 변동 → 매수 수량은 실시간 재계산"),
        ]
        df_a = pd.DataFrame(assump_rows, columns=["항목", "값"])
        df_a.to_excel(writer, sheet_name="가정",
                      index=False, header=False, startrow=1)
        ws_a = writer.sheets["가정"]
        ws_a.write(0, 0, "항목", header_fmt)
        ws_a.write(0, 1, "값",   header_fmt)
        ws_a.set_column(0, 0, 25)
        ws_a.set_column(1, 1, 50)
        for ri, (_, row) in enumerate(df_a.iterrows()):
