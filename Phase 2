                              "MDD(5y,%)"): widths.append(11)
                elif col in ("Sharpe(5y)", "Sortino(5y)", "별점(5점)",
                              "인컴구분", "통과(9개중)"): widths.append(9)
                elif col == "Morningstar(수동)": widths.append(13)
                else: widths.append(11)
            for ci, w in enumerate(widths):
                ws.set_column(ci, ci, w)

            # 데이터 행
            for ri, (_, row) in enumerate(df_out.iterrows()):
                ws.set_row(start_row + 1 + ri, 22)
                for ci, col in enumerate(avail_cols):
                    val = row[col]
                    if col == "하드룰통과":
                        if val:
                            ws.write(start_row+1+ri, ci, "통과", pass_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "탈락", fail_fmt)
                    elif col == "스코어":
                        if pd.notna(val):
                            v = float(val)
                            fmt = score_high if v >= 1.5 else cell_fmt
                            ws.write(start_row+1+ri, ci, f"{v:.2f}", fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "", cell_fmt)
                    elif col in ("ETF명", "선정이유", "탈락사유"):
                        ws.write(start_row+1+ri, ci,
                                 val if pd.notna(val) else "", cell_left)
                    elif col == "운용보수(%)":
                        if pd.notna(val):
                            # Phase 1 출력은 이미 "0.03%" 등 문자열로 포맷됨
                            ws.write(start_row+1+ri, ci, str(val), cell_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "", cell_fmt)
                    elif col in ("5년CAGR(%)", "TTM수익률(%)",
                                  "변동성(연%,5y)", "MDD(5y,%)"):
                        if pd.notna(val):
                            try:
                                v = float(val)
                                ws.write(start_row+1+ri, ci, f"{v:+.2f}%" if col == "MDD(5y,%)" else f"{v:.2f}%", cell_fmt)
                            except (ValueError, TypeError):
                                ws.write(start_row+1+ri, ci, str(val), cell_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "-", cell_fmt)
                    elif col in ("Sharpe(5y)", "Sortino(5y)"):
                        if pd.notna(val):
                            try:
                                ws.write(start_row+1+ri, ci, f"{float(val):.2f}", cell_fmt)
                            except (ValueError, TypeError):
                                ws.write(start_row+1+ri, ci, str(val), cell_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "-", cell_fmt)
                    elif col == "AUM(억달러)":
                        if pd.notna(val):
                            ws.write(start_row+1+ri, ci, float(val), cell_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "", cell_fmt)
                    elif col == "상장연도":
                        if pd.notna(val):
                            ws.write(start_row+1+ri, ci, int(val), cell_fmt)
                        else:
                            ws.write(start_row+1+ri, ci, "", cell_fmt)
                    else:
                        ws.write(start_row+1+ri, ci,
                                 val if pd.notna(val) else "", cell_fmt)

            ws.freeze_panes(start_row + 1, 2)
            ws.autofilter(start_row, 0, start_row + len(df_out),
                          len(avail_cols) - 1)

        # ── 1. 카테고리별 시트 (10개) ──────────────────
        for cat in DIRECTION_CATEGORIES:
            df_cat = cat_candidates.get(cat["name"], pd.DataFrame())
            if df_cat.empty:
                continue
            n_pass = df_cat["하드룰통과"].sum()
            intro = (f"【{cat['label']}】  매칭 {len(df_cat)}개 / 하드룰 통과 {n_pass}개")
            meta  = (f"Direction 지침: {cat['instruction']}    "
                     f"| 목표 비중: {cat['weight_target']}    "
                     f"| 추천 후보: {', '.join(cat['ticker_whitelist'][:8])}")
            write_df(df_cat, cat["name"][:31], intro_text=intro, meta_text=meta)

        # ── 2. ★Top후보 합본 (각 카테고리 상위 5개) ────
        top_combined = []
        for cat in DIRECTION_CATEGORIES:
            df_cat = cat_candidates.get(cat["name"], pd.DataFrame())
            if df_cat.empty:
                continue
            top = df_cat[df_cat["하드룰통과"] == True].head(5).copy()
            if not top.empty:
                top.insert(0, "Direction카테고리", cat["label"])
                top_combined.append(top)
        if top_combined:
            df_top = pd.concat(top_combined, ignore_index=True)
            intro = "★ Direction 카테고리별 Top 후보 (하드룰 통과 + 스코어 상위 5개)"
            write_df(df_top, "★Top후보", intro_text=intro)

        # ── 3. 전체 합본 (하드룰 통과/탈락 모두) ────────
        df_all_disp = df_all.sort_values(
            ["하드룰통과", "스코어"], ascending=[False, False]
        ).reset_index(drop=True)
        intro = (f"전체 평가 합본: {len(df_all_disp)}개 "
                 f"(통과 {df_all_disp['하드룰통과'].sum()}, "
                 f"탈락 {(~df_all_disp['하드룰통과']).sum()})")
        write_df(df_all_disp, "전체합본", intro_text=intro)

        # ── 4. Direction 매핑 가이드 ──────────────────
        guide_rows = [
            (cat["label"], cat["weight_target"], cat["instruction"],
             ", ".join(cat["ticker_whitelist"]))
            for cat in DIRECTION_CATEGORIES
        ]
        df_guide = pd.DataFrame(guide_rows,
            columns=["카테고리", "목표 비중", "Direction 지침", "추천 티커"])
        df_guide.to_excel(writer, sheet_name="Direction가이드",
                          index=False, header=False, startrow=1)
        ws_g = writer.sheets["Direction가이드"]
        for ci, col in enumerate(df_guide.columns):
            ws_g.write(0, ci, col, header_fmt)
        ws_g.set_column(0, 0, 30)
        ws_g.set_column(1, 1, 35)
        ws_g.set_column(2, 2, 50)
        ws_g.set_column(3, 3, 60)
        for ri, (_, row) in enumerate(df_guide.iterrows()):
            ws_g.set_row(ri + 1, 40)
            for ci, val in enumerate(row):
                ws_g.write(ri + 1, ci, val, cell_left if ci > 0 else cell_fmt)


if __name__ == "__main__":
    main()
