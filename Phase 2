def detect_categories(tk: str, name: str, category_text: str) -> list:
    """단일 상품 → 매칭되는 Direction 카테고리 리스트 (다수 매칭 가능)"""
    matches = []
    text_lower = (name + " " + category_text).lower()

    for cat in DIRECTION_CATEGORIES:
        # 1순위: ticker whitelist 매칭
        if tk in cat["ticker_whitelist"]:
            matches.append(cat["name"])
            continue
        # 2순위: 카테고리 키워드 매칭
        for kw in cat["category_includes"]:
            if kw.lower() in text_lower:
                matches.append(cat["name"])
                break
    return matches


def passes_hard_rules(row: pd.Series) -> tuple:
    """Direction 하드룰 통과 여부 → (passed: bool, fail_reasons: list)"""
    fails = []

    # 트랙레코드 5년+
    yr_v = _to_float(row.get("상장연도"))
    if yr_v is not None:
        age = CURRENT_YR - int(yr_v)
        if age < 5:
            fails.append(f"트랙{age}y<5")
    else:
        fails.append("트랙?")

    # AUM 1억달러+
    aum_v = _to_float(row.get("AUM(억달러)"))
    if aum_v is not None:
        if aum_v < 1.0:
            fails.append(f"AUM${aum_v:.1f}억<1억")
    else:
        fails.append("AUM?")

    # 레버리지/구조화 ❌
    chk11 = str(row.get("11.레버리지/구조화제외", ""))
    if chk11 == "✗":
        fails.append("레버리지/구조화")

    # 보수 투명성 (체크11 통과 + 6번 ✓ 또는 △ 허용)
    chk6 = str(row.get("6.유동성+투명수수료", ""))
    if chk6 == "✗":
        fails.append("보수>0.75%")

    return (len(fails) == 0, fails)


def _to_float(x) -> float | None:
    """'17.45%' / '+12.81%' / 0.85 / N/A → float or None"""
    if pd.isna(x):
        return None
    if isinstance(x, (int, float)):
        return float(x)
    s = str(x).strip().replace("%", "").replace("+", "").replace(",", "")
    if not s or s in ("-", "N/A", "혼합분배"):
        return None
    try:
        return float(s)
    except ValueError:
        return None


def compute_score(row: pd.Series) -> float:
    """종합 스코어 = Sharpe + Sortino*0.5 - (Vol-15)/30 + AUM/트랙 보너스"""
    sharpe  = _to_float(row.get("Sharpe(5y)"))
    sortino = _to_float(row.get("Sortino(5y)"))
    vol     = _to_float(row.get("변동성(연%,5y)"))
    aum     = _to_float(row.get("AUM(억달러)"))
    yr      = _to_float(row.get("상장연도"))
    star    = _to_float(row.get("별점(5점)"))

    score = 0.0

    if sharpe is not None:
        score += sharpe
    if sortino is not None:
        score += sortino * 0.5
    if vol is not None:
        # 15% 변동성 기준, 그 이상은 페널티
        score -= max(0, vol - 15) / 30.0
    if aum is not None and aum >= 10:
        score += 1.0
    if yr is not None and (CURRENT_YR - int(yr)) >= 10:
        score += 0.5
    if star is not None:
        score += (int(star) - 3) * 0.2   # 별점 4 = +0.2, 5 = +0.4

    return round(score, 3)


