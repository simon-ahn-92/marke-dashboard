    from plotly.subplots import make_subplots as _msp
    fig = _msp(rows=1, cols=1, specs=[[{"secondary_y": True}]])

    latest = df.index[-1]
    add_regime_backgrounds(fig, df, row=1)

    CRISIS_LINE_COLOR = "rgba(255,255,255,0.55)"
    for start, end, label, color in CRISIS_PERIODS:
        end_ts   = latest if end is None else pd.Timestamp(end)
        start_ts = pd.Timestamp(start)
        is_current = (end is None)
        fig.add_shape(
            type="line", x0=start_ts, x1=start_ts, y0=0, y1=1,
            xref="x", yref="y domain", layer="above",
            line=dict(color=CRISIS_LINE_COLOR, width=1.5, dash="solid"),
        )
        if not is_current:
            fig.add_shape(
                type="line", x0=end_ts, x1=end_ts, y0=0, y1=1,
                xref="x", yref="y domain", layer="above",
                line=dict(color=CRISIS_LINE_COLOR, width=1.0, dash="dot"),
            )
        fig.add_annotation(
            x=start_ts, y=0.995, yref="paper",
            text=f"<b>{label}</b>", showarrow=False,
            font=dict(size=9, color=color, family="Malgun Gothic"),
            xanchor="left", yanchor="top", textangle=-90,
        )

    for col_key, name, source, right_axis, color, visible, _ in OVERLAY_SERIES:
        s = idx_df[col_key] if source == "index" else df.get(col_key)
        if s is None or (hasattr(s, "empty") and s.empty):
            continue
        s = s.dropna()
        if s.empty:
            continue
        fmt  = ".2f" if right_axis else ",.1f"
        unit = "%" if right_axis and col_key not in ("VIX", "M2통화량", "ISM제조업PMI") else ""
        fig.add_trace(go.Scatter(
            x=s.index, y=s.values, name=name,
            line=dict(color=color, width=1.5),
            visible=True if visible else False,
            hovertemplate=f"<b>{name}</b>: %{{y:{fmt}}}{unit}<extra></extra>",
            showlegend=False,
        ), row=1, col=1, secondary_y=right_axis)

    for i, (regime, color) in enumerate(REGIME_LINE_COLORS.items()):
        fig.add_trace(go.Scatter(
            x=[None], y=[None], mode="markers",
            marker=dict(size=11, color=color, symbol="square"),
            name=regime, legendgroup="regime",
            legendgrouptitle=dict(text="국면") if i == 0 else None,
            showlegend=True,
            hoverinfo="skip",
        ), row=1, col=1)

    fig.update_layout(
        title=dict(text="<b>시장 국면 판단 대시보드</b>",
                   font=dict(size=20, family="Malgun Gothic", color="white"), x=0.5,
                   y=0.99, yanchor="top"),
        template="plotly_dark",
        height=560, hovermode="x unified",
        dragmode="pan", autosize=True,
        margin=dict(l=60, r=200, t=60, b=40),
        legend=dict(orientation="v", x=1.02, y=1.0,
                    xanchor="left", yanchor="top",
                    font=dict(size=11, color="white"),
                    bgcolor="rgba(0,0,0,0.4)",
                    bordercolor="rgba(255,255,255,0.2)", borderwidth=1),
        xaxis=dict(
            type="date",
            rangeselector=dict(
                buttons=[
                    dict(count=1,  label="1Y", step="year",  stepmode="backward"),
                    dict(count=3,  label="3Y", step="year",  stepmode="backward"),
                    dict(count=5,  label="5Y", step="year",  stepmode="backward"),
                    dict(count=10, label="10Y",step="year",  stepmode="backward"),
                    dict(step="all", label="전체"),
                ],
                bgcolor="rgba(0,0,0,0.5)",
                activecolor="#3498db",
                font=dict(size=11, color="white"),
            ),
            rangeslider=dict(visible=True, thickness=0.05),
        ),
        font=dict(family="Malgun Gothic"),
    )
    fig.update_yaxes(title_text="가격 / 지수", row=1, col=1, secondary_y=False)
    fig.update_yaxes(title_text="금리 / 지표", row=1, col=1, secondary_y=True, showgrid=False)

    # ── 학습 / 추론 경계선 ─────────────────────────────────
    infer_ts = pd.Timestamp(INFER_START_DATE)
    fig.add_shape(
        type="line", x0=infer_ts, x1=infer_ts, y0=0, y1=1,
        xref="x", yref="y domain", layer="above",
        line=dict(color="rgba(255,255,255,0.75)", width=2, dash="dashdot"),
    )
    fig.add_annotation(
        x=infer_ts, y=0.50, yref="paper",
        text="<b>학습 ◀│▶ 추론</b>",
        showarrow=False,
        font=dict(size=9, color="rgba(255,255,255,0.8)", family="Malgun Gothic"),
        xanchor="center", yanchor="middle", textangle=-90,
        bgcolor="rgba(30,30,50,0.75)",
        bordercolor="rgba(255,255,255,0.35)", borderwidth=1,
    )
    return fig


def build_prob_chart(df: pd.DataFrame) -> go.Figure:
    """하단 차트: 국면 확률 (단독 Figure, 호버 독립)"""
    fig = go.Figure()

    add_regime_backgrounds(fig, df, row=None)

    for regime, color in zip(PROB_REGIMES, PROB_COLORS):
        col_match = [c for c in df.columns
                     if regime in c and "prob" not in c.lower() and c != "국면"]
        if not col_match:
            col_match = [c for c in df.columns if regime == c]
        if col_match:
            fig.add_trace(go.Scatter(
                x=df.index, y=df[col_match[0]] * 100,
                mode="lines", name=regime,
                stackgroup="prob", line=dict(width=0),
                fillcolor=color, showlegend=True,
                legendgroup="prob",
                hovertemplate=f"<b>{regime}</b>: %{{y:.1f}}%<extra></extra>",
            ))

    fig.update_layout(
        template="plotly_dark",
        height=260, hovermode="x unified",
        dragmode="pan", autosize=True,
        margin=dict(l=60, r=200, t=30, b=40),
        legend=dict(orientation="v", x=1.02, y=1.0,
                    xanchor="left", yanchor="top",
                    font=dict(size=11, color="white"),
                    bgcolor="rgba(0,0,0,0.4)",
                    bordercolor="rgba(255,255,255,0.2)", borderwidth=1),
        xaxis=dict(type="date"),
        yaxis=dict(title="확률 (%)", range=[0, 100], fixedrange=True),
        font=dict(family="Malgun Gothic"),
        annotations=[dict(
            text="국면 확률", x=0.0, xref="paper", y=1.04, yref="paper",
            showarrow=False, xanchor="left",
            font=dict(size=15, family="Malgun Gothic", color="rgba(255,255,255,0.9)"),
        )],
    )

    # ── 학습 / 추론 경계선 ─────────────────────────────────
    infer_ts = pd.Timestamp(INFER_START_DATE)
    fig.add_shape(
        type="line", x0=infer_ts, x1=infer_ts, y0=0, y1=1,
        xref="x", yref="y domain", layer="above",
        line=dict(color="rgba(255,255,255,0.75)", width=2, dash="dashdot"),
    )
    fig.add_annotation(
        x=infer_ts, y=0.50, yref="paper",
        text="<b>학습 ◀│▶ 추론</b>",
        showarrow=False,
        font=dict(size=9, color="rgba(255,255,255,0.8)", family="Malgun Gothic"),
        xanchor="center", yanchor="middle", textangle=-90,
        bgcolor="rgba(30,30,50,0.75)",
        bordercolor="rgba(255,255,255,0.35)", borderwidth=1,
    )
    return fig


def _build_html_body(chart_html: str, df: pd.DataFrame,
                     idx_df: pd.DataFrame, wrapper_height: str) -> str:
    groups = OrderedDict()
    for _, name, _, right_axis, color, visible, group in OVERLAY_SERIES:
        groups.setdefault(group, []).append((name, color, visible, right_axis))

    cb_sections = ""
    for group_name, items in groups.items():
        items_html = ""
        for name, color, visible, right_axis in items:
            checked    = "checked" if visible else ""
            safe_id    = (name.replace(" ", "_").replace("(", "")
                              .replace(")", "").replace("/", "_"))
            active_cls = "active" if right_axis else ""
            btn_txt    = "우✓" if right_axis else "우"
            items_html += f"""
      <label class="cb-label">
        <input type="checkbox" id="cb_{safe_id}" {checked}
          onchange="toggleSeries(this,'{name}')">
        <span class="cb-dot" style="background:{color}"></span>
        <span class="cb-name">{name}</span>
        <button class="btn-yaxis-item {active_cls}" data-trace="{name}"
          onclick="toggleSeriesAxis(this,'{name}');event.stopPropagation();"
          title="우측 축 전환">{btn_txt}</button>
      </label>"""
        cb_sections += f"""
    <div class="cb-group">
      <div class="cb-group-title"><span>{group_name}</span></div>{items_html}
    </div>"""

    defaults_items = []
    for _, name, _, _, _, visible, _ in OVERLAY_SERIES:
        escaped = name.replace("'", "\\'")
        defaults_items.append(f"  '{escaped}': {'true' if visible else 'false'}")
    defaults_js = "{\n" + ",\n".join(defaults_items) + "\n}"

    axis_defaults = {name: ra for _, name, _, ra, _, _, _ in OVERLAY_SERIES}
    axis_defaults_json = json.dumps(axis_defaults)

    prob_cols = {}
    for regime in PROB_REGIMES:
        col_match = [c for c in df.columns
                     if regime in c and "prob" not in c.lower() and c != "국면"]
        if not col_match:
            col_match = [c for c in df.columns if regime == c]
        if col_match:
            prob_cols[regime] = df[col_match[0]]

    prob_json_rows = []
    if prob_cols:
        for dt in list(prob_cols.values())[0].index:
            ds = dt.strftime("%Y-%m-%d")
            row = {"d": ds}
            for regime, s in prob_cols.items():
                row[regime] = round(float(s.get(dt, 0)) * 100, 1)
            prob_json_rows.append(row)
    prob_json = json.dumps(prob_json_rows)

    perf_assets = {}
    for col_key, name, source, right_axis, _, _, _ in OVERLAY_SERIES:
        if right_axis:
            continue
        s = idx_df[col_key] if source == "index" else df.get(col_key)
        if s is None or (hasattr(s, "empty") and s.empty):
            continue
        s = s.dropna()
        if s.empty:
            continue
        perf_assets[name] = [{"d": dt.strftime("%Y-%m-%d"), "v": round(float(v), 4)}
                              for dt, v in s.items()]
    perf_assets_json = json.dumps(perf_assets)

    sp500_s = idx_df["SP500"].dropna() if "SP500" in idx_df.columns else pd.Series()
    sp500_json = json.dumps([{"d": dt.strftime("%Y-%m-%d"), "v": round(float(v), 2)}
                              for dt, v in sp500_s.items()])

    data_start = df.index[0].strftime("%Y-%m-%d")
    data_end   = df.index[-1].strftime("%Y-%m-%d")

    latest_str = df.index[-1].strftime("%Y-%m-%d")
    crisis_hover_list = []
    for start, end, label, color in CRISIS_PERIODS:
        end_str = latest_str if end is None else end
        info    = CRISIS_HOVER_INFO.get(label, {})
        crisis_hover_list.append({
            "label":      label,
            "title":      info.get("title", label),
            "period":     info.get("period", f"{start[:7]} ~ {end_str[:7]}"),
            "start":      start,
            "end":        end_str,
            "color":      color,
            "indicators": info.get("indicators", []),
            "note":       info.get("note", ""),
        })
    crisis_hover_json = json.dumps(crisis_hover_list, ensure_ascii=False)

    return f"""<style>
