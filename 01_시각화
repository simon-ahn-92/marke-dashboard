def load_index_data() -> pd.DataFrame:
    """지수 가격 데이터 — 국면판단_원데이터.xlsx 일간데이터에서 직접 로드"""
    daily = pd.read_excel(FRED_PATH, sheet_name="일간데이터",
                          index_col=0, parse_dates=True).sort_index()
    if "금현물가격(USD/oz)" in daily.columns and "금현물가격" not in daily.columns:
        daily = daily.rename(columns={"금현물가격(USD/oz)": "금현물가격"})
    return daily


def load_fred_assets() -> pd.DataFrame:
    """FRED 일간데이터에서 자산 가격 컬럼 추출"""
    try:
        daily = pd.read_excel(FRED_PATH, sheet_name="일간데이터",
                               index_col=0, parse_dates=True).sort_index()
        if "금현물가격(USD/oz)" in daily.columns and "금현물가격" not in daily.columns:
            daily = daily.rename(columns={"금현물가격(USD/oz)": "금현물가격"})
        asset_cols = [c for c in ["금현물가격","WTI원유","미국IG채권TR",
                                   "미국HY채권TR","미국7-10년국채TR"] if c in daily.columns]
        return daily[asset_cols] if asset_cols else pd.DataFrame()
    except Exception:
        return pd.DataFrame()


def load_regime_monthly() -> pd.Series:
    """국면 시계열 로드 — v2 결과는 이미 월별 인덱스"""
    try:
        regime_df = pd.read_excel(RESULT_PATH, sheet_name="국면_시계열",
                                   index_col=0, parse_dates=True).sort_index()
        return regime_df["국면"]
    except Exception:
        return pd.Series(dtype=str)


def load_regime_period_type() -> pd.Series:
    """학습/추론 구간구분 시계열 로드 (없으면 날짜 기준으로 생성)"""
    try:
        regime_df = pd.read_excel(RESULT_PATH, sheet_name="국면_시계열",
                                   index_col=0, parse_dates=True).sort_index()
        if "구간구분" in regime_df.columns:
            return regime_df["구간구분"]
    except Exception:
        pass
    # fallback: 날짜 기준으로 생성
    regime = load_regime_monthly()
    if regime.empty:
        return pd.Series(dtype=str)
    return regime.index.map(
        lambda d: "추론" if d > pd.Timestamp(TRAIN_END_DATE) else "학습"
    )


def build_asset_df() -> pd.DataFrame:
    """자산 일간 가격 — 국면판단_원데이터.xlsx 일간데이터 단일 소스"""
    df = load_index_data()
    df = df.loc[:, ~df.columns.duplicated(keep="first")]
    df = df[~df.index.duplicated(keep="first")].sort_index()
    return df


