def compute_crisis_returns(df: pd.DataFrame) -> dict:
    """
    위기 구간별 자산 기간 수익률 계산.
    구간 첫 거래일 → 마지막 거래일 기준 단순 수익률(%).
    반환: {crisis_name: {asset_name: return_pct or None}}
    """
    result = {}
    for crisis_name, (start, end) in CRISIS_PERIODS_COMP.items():
        start_ts = pd.Timestamp(start)
        end_ts   = df.index[-1] if end is None else pd.Timestamp(end)
        sub      = df.loc[(df.index >= start_ts) & (df.index <= end_ts)]
        row = {}
        for col, display in RETURN_ASSETS:
            if col not in sub.columns:
                row[display] = None
                continue
            s = sub[col].dropna()
            if len(s) < 2:
                row[display] = None
                continue
            ret = (s.iloc[-1] / s.iloc[0] - 1) * 100
            row[display] = round(ret, 1)
        result[crisis_name] = row
    return result


def build_crisis_bar_chart(profiles: pd.DataFrame,
                           scores: pd.DataFrame,
                           similarity: pd.Series):
    """코사인 유사도 막대그래프 + customdata 반환"""
    names  = list(CRISIS_PERIODS_COMP.keys())
    colors = {n: CRISIS_COLORS_COMP[i % len(CRISIS_COLORS_COMP)] for i, n in enumerate(names)}

    # 유사도 오름차순 정렬 → 막대가 위로 갈수록 높음
    sim_sorted        = similarity.sort_values(ascending=True)
    ind_names_list    = list(INDICATORS_COMP.keys())
    current_key_score = [k for k in scores.index if "현재" in k][0]

    customdata = []
    for crisis in sim_sorted.index:
        row_data = {"crisis": crisis, "sim": float(sim_sorted[crisis]), "indicators": []}
        for ind in ind_names_list:
            cur_val = scores.loc[current_key_score, ind]
            cri_val = scores.loc[crisis, ind]
            cur_raw = profiles.loc[current_key_score, ind]
            cri_raw = profiles.loc[crisis, ind]
            row_data["indicators"].append({
                "name":    ind,
                "cur_pct": round(float(cur_val), 1) if not pd.isna(cur_val) else None,
                "cri_pct": round(float(cri_val), 1) if not pd.isna(cri_val) else None,
                "cur_raw": round(float(cur_raw), 2) if not pd.isna(cur_raw) else None,
                "cri_raw": round(float(cri_raw), 2) if not pd.isna(cri_raw) else None,
            })
        customdata.append(row_data)

    fig = go.Figure()
    fig.add_trace(go.Bar(
        x=sim_sorted.values,
        y=sim_sorted.index,
        orientation="h",
        marker_color=[colors.get(n, "#95a5a6") for n in sim_sorted.index],
        marker_line=dict(color="rgba(255,255,255,0.15)", width=1),
        text=[f"{v:.1f}%" for v in sim_sorted.values],
        textposition="outside",
        textfont=dict(size=13, color="white"),
        showlegend=False,
        customdata=customdata,
        hovertemplate="<b>%{y}</b><br>코사인 유사도: %{x:.1f}%<extra></extra>",
    ))

    fig.update_layout(
        template="plotly_dark",
        height=400,
        autosize=True,
        xaxis=dict(
            title="코사인 유사도 (%)",
            range=[0, 115],
            showgrid=True,
            gridcolor="rgba(255,255,255,0.08)",
        ),
        yaxis=dict(autorange=True, tickfont=dict(size=13)),
        margin=dict(l=10, r=70, t=10, b=40),
        font=dict(family="Malgun Gothic", color="white"),
        plot_bgcolor="rgba(0,0,0,0)",
        paper_bgcolor="rgba(0,0,0,0)",
    )
    return fig, customdata, sim_sorted


