<script>
function getGd() {{
  // 상단 시장 지표 차트 (첫 번째 Figure)
  var divs = document.querySelectorAll('#chart-main .plotly-graph-div');
  return divs.length ? divs[0] : document.querySelector('#chart-area .plotly-graph-div');
}}
function switchTab(id, btn) {{
  document.querySelectorAll('.sb-tab').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.sb-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + id).classList.add('active');
}}
window.addEventListener('load', function() {{
  var gd = getGd();
  if (gd) Plotly.relayout(gd, {{autosize: true}});
  initCrisisHover();
}});

function toggleSeries(cb, traceName) {{
  var gd = getGd(); if (!gd) return;
  var idx = [];
  gd.data.forEach(function(t, i) {{ if (t.name === traceName) idx.push(i); }});
  if (idx.length) Plotly.restyle(gd, {{visible: cb.checked}}, idx);
}}

var DEFAULTS      = {defaults_js};
var AXIS_DEFAULTS = {axis_defaults_json};
var seriesAxisState = Object.assign({{}}, AXIS_DEFAULTS);

function toggleSeriesAxis(btn, traceName) {{
  var gd = getGd(); if (!gd) return;
  var isRight = !seriesAxisState[traceName];
  seriesAxisState[traceName] = isRight;
  btn.classList.toggle('active', isRight);
  btn.textContent = isRight ? '우✓' : '우';
  var idx = [];
  gd.data.forEach(function(t, i) {{
    if (t.name === traceName) idx.push(i);
  }});
  if (idx.length) {{
    Plotly.restyle(gd, {{'yaxis': isRight ? 'y2' : 'y'}}, idx);
  }}
}}

function resetAll() {{
  var gd = getGd(); if (!gd) return;
