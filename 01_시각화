def _build_current_hover_info(df: pd.DataFrame) -> dict:
    """
    2026년 이후 '현재' 구간 hover 텍스트를 실제 데이터 기반으로 자동 생성.
    df: load_crisis_data() 반환값 (일간 데이터, 최신 날짜 기준)
    """
    latest = df.index[-1]
    as_of  = latest.strftime("%Y.%m.%d")

    def latest_val(col):
        if col not in df.columns:
            return None
        s = df[col].dropna()
        return s.iloc[-1] if not s.empty else None

    def prev_val(col, days=252):
        """약 1년 전 값"""
        if col not in df.columns:
            return None
        s = df[col].dropna()
        if len(s) < days:
            return s.iloc[0] if not s.empty else None
        return s.iloc[-days]

    def ytd_return(col):
        """연초(1월 1일) 대비 현재 수익률 (%)"""
        if col not in df.columns:
            return None, None
        s = df[col].dropna()
        if s.empty:
            return None, None
        cur_date = s.index[-1]
        cur_val  = s.iloc[-1]
        # 당해 연도 1월 첫 거래일 값
        year_start = pd.Timestamp(f"{cur_date.year}-01-01")
        ytd_s = s[s.index >= year_start]
        if ytd_s.empty:
            return None, None
        start_val = ytd_s.iloc[0]
        if start_val == 0:
            return None, None
        return (cur_val / start_val - 1) * 100, cur_val

    indicators = []

    # ── VIX ──────────────────────────────────
    vix = latest_val("VIX")
    if vix is not None:
        if vix >= 30:
            vix_txt = f"{vix:.1f} — 공포 구간 (고위험)"
        elif vix >= 20:
            vix_txt = f"{vix:.1f} — 경계 구간"
        else:
            vix_txt = f"{vix:.1f} — 안정 구간"
        indicators.append(["VIX", vix_txt])

    # ── S&P500 (연초 대비 수익률) ─────────────
    sp_ytd, sp_cur = ytd_return("SP500")
    if sp_ytd is not None:
        if sp_ytd >= 10:
            sp_txt = f"연초 대비 {sp_ytd:+.1f}% (강세)"
        elif sp_ytd >= 0:
            sp_txt = f"연초 대비 {sp_ytd:+.1f}% (보합·상승)"
        elif sp_ytd >= -10:
            sp_txt = f"연초 대비 {sp_ytd:+.1f}% (조정)"
        else:
            sp_txt = f"연초 대비 {sp_ytd:+.1f}% (약세장)"
        indicators.append(["S&P500", sp_txt])

    # ── 장단기금리차 ─────────────────────────
    spread = latest_val("장단기금리차(10Y-2Y)")
    if spread is not None:
        if spread >= 0.5:
            sp_label = f"{spread:+.2f}%p — 정상화 (확장 신호)"
        elif spread >= 0:
            sp_label = f"{spread:+.2f}%p — 정상화 (회복 중)"
        elif spread >= -0.5:
            sp_label = f"{spread:+.2f}%p — 소폭 역전"
        else:
            sp_label = f"{spread:+.2f}%p — 역전 (침체 경고)"
        indicators.append(["장단기금리차", sp_label])

    # ── 달러(DXY) — 전년 대비 방향 ──────────
    dxy_cur  = latest_val("달러인덱스DXY")
    dxy_prev = prev_val("달러인덱스DXY", 252)
    if dxy_cur is not None and dxy_prev is not None:
        dxy_chg = (dxy_cur / dxy_prev - 1) * 100
        if dxy_chg >= 3:
            dxy_txt = f"{dxy_cur:.1f} | 전년비 {dxy_chg:+.1f}% 강세"
        elif dxy_chg <= -3:
            dxy_txt = f"{dxy_cur:.1f} | 전년비 {dxy_chg:+.1f}% 약세"
        else:
            dxy_txt = f"{dxy_cur:.1f} | 전년비 {dxy_chg:+.1f}% 보합"
        indicators.append(["달러(DXY)", dxy_txt])

    # ── HY 크레딧 스프레드 ───────────────────
    hy = latest_val("HY크레딧스프레드")
    if hy is not None:
        if hy >= 6:
            hy_txt = f"{hy:.2f}% — 위기 수준 (급확대)"
        elif hy >= 4:
            hy_txt = f"{hy:.2f}% — 경계 구간"
        elif hy >= 3:
            hy_txt = f"{hy:.2f}% — 완화 (중립)"
        else:
            hy_txt = f"{hy:.2f}% — 타이트 (낙관)"
        indicators.append(["HY 스프레드", hy_txt])

    # ── note 자동 생성 ───────────────────────
    risk_flags = []
    if vix is not None and vix >= 25:
        risk_flags.append("변동성 확대")
    if sp_ytd is not None and sp_ytd <= -10:
        risk_flags.append("주식 조정")
    if spread is not None and spread < 0:
        risk_flags.append("금리 역전")
    if hy is not None and hy >= 5:
        risk_flags.append("신용 위험 상승")

    if risk_flags:
        note = "주요 위험 신호: " + " / ".join(risk_flags)
    else:
        note = "주요 위험 신호 미감지. 지표 안정권"

    return {
        "title": f"현재 ({as_of} 기준)",
        "period": f"2026.01 ~ 진행중",
        "indicators": indicators,
        "note": note,
    }

