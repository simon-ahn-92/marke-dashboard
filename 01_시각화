def load_data() -> pd.DataFrame:
    """국면·FRED 데이터 로드 (대시보드용 — 월별 → 일별 ffill 확장)"""
    regime_df = pd.read_excel(RESULT_PATH, sheet_name="국면_시계열",
                               index_col=0, parse_dates=True).sort_index()
    prob_df   = pd.read_excel(RESULT_PATH, sheet_name="국면_확률",
                               index_col=0, parse_dates=True).sort_index()
    daily     = pd.read_excel(FRED_PATH, sheet_name="일간데이터",
                               index_col=0, parse_dates=True).sort_index()
    if "금현물가격(USD/oz)" in daily.columns and "금현물가격" not in daily.columns:
        daily = daily.rename(columns={"금현물가격(USD/oz)": "금현물가격"})
    monthly   = pd.read_excel(FRED_PATH, sheet_name="월간데이터",
                               index_col=0, parse_dates=True).sort_index()
    regime_daily = regime_df.reindex(daily.index, method="ffill")
    prob_daily   = prob_df.reindex(daily.index, method="ffill")
    monthly_d    = monthly.reindex(daily.index, method="ffill")
    fred = pd.concat([daily, monthly_d], axis=1)
    df   = regime_daily.join(fred, how="left", rsuffix="_fred")
    df   = df.join(prob_daily, how="left", rsuffix="_prob")
    df   = df.ffill().bfill()
    return df


def add_regime_backgrounds(fig, df, row):
    regimes = df["국면"]
    current = regimes.iloc[0]
    start   = df.index[0]
    for i in range(1, len(df)):
        if regimes.iloc[i] != current or i == len(df) - 1:
            end   = df.index[i]
            color = REGIME_COLORS.get(current, "rgba(200,200,200,0.12)")
            if row is None:
                fig.add_vrect(x0=start, x1=end, fillcolor=color,
                              layer="below", line_width=0)
            else:
                fig.add_vrect(x0=start, x1=end, fillcolor=color,
                              layer="below", line_width=0, row=row, col=1)
            current = regimes.iloc[i]
            start   = df.index[i]


