# =====================================
# 위기 구간별 수익률 / MDD 계산
# =====================================
def calc_mdd(series: pd.Series) -> float:
    s = series.dropna()
    if s.empty:
        return np.nan
    peak = s.cummax()
    return ((s - peak) / peak * 100).min()


def calc_crisis_heatmap_data(assets_df: pd.DataFrame):
    """CRISIS_PERIODS_COMP 기준으로 위기 구간 × 자산 수익률/MDD 행렬 반환"""
    labels      = list(CRISIS_PERIODS_COMP.keys())
    latest      = assets_df.index[-1]
    asset_keys  = [col  for col, _    in ASSET_LIST if col in assets_df.columns]
    asset_names = [name for col, name in ASSET_LIST if col in assets_df.columns]

    z, text = [], []
    for crisis_name in labels:
        start, end = CRISIS_PERIODS_COMP[crisis_name]
        start_ts = pd.Timestamp(start)
        end_ts   = latest if end is None else pd.Timestamp(end)
        sub = assets_df.loc[(assets_df.index >= start_ts) & (assets_df.index <= end_ts)]

        row_z, row_text = [], []
        for col_key in asset_keys:
            s = sub[col_key].dropna() if col_key in sub.columns else pd.Series()
            if len(s) < 2:
                row_z.append(np.nan)
                row_text.append("N/A")
                continue
            ret = (s.iloc[-1] / s.iloc[0] - 1) * 100
            mdd = calc_mdd(s)
            ret_str = f"+{ret:.1f}%" if ret >= 0 else f"{ret:.1f}%"
            row_z.append(round(ret, 1))
            row_text.append(f"{ret_str}<br>MDD:{mdd:.1f}%")
        z.append(row_z)
        text.append(row_text)

    return labels, asset_names, z, text


# =====================================
# 월별 수익률 계산
# =====================================
def compute_monthly_returns(price_df: pd.DataFrame) -> pd.DataFrame:
    """일간 가격 → 월말 가격 → 월별 수익률(%)"""
    monthly_price = price_df.resample("ME").last()
    monthly_ret   = monthly_price.pct_change() * 100
    return monthly_ret


def pivot_for_heatmap(ret_series: pd.Series) -> pd.DataFrame:
    df = ret_series.dropna().to_frame("ret")
    df["year"]  = df.index.year
    df["month"] = df.index.month
    pivot = df.pivot(index="year", columns="month", values="ret")
    pivot.columns = [MONTH_KR[m-1] for m in pivot.columns]
    pivot["연간"] = (1 + ret_series.dropna() / 100).resample("YE").prod().sub(1).mul(100).reindex(pivot.index)
    return pivot


