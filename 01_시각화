function addMonths(dateStr, months) {{
  var d = new Date(dateStr); d.setMonth(d.getMonth() + months);
  return d.toISOString().slice(0, 10);
}}
function addYears(dateStr, years) {{
  var d = new Date(dateStr); d.setFullYear(d.getFullYear() + years);
  return d.toISOString().slice(0, 10);
}}
function findNearest(dates, target) {{
  var tMs = new Date(target).getTime();
  var best = null, bestDiff = Infinity;
  dates.forEach(function(d) {{
    var diff = Math.abs(new Date(d).getTime() - tMs);
    if (diff < bestDiff) {{ bestDiff = diff; best = d; }}
  }});
  return best;
}}
function getPrice(dateStr) {{
  var d = findNearest(activeAssetDates, dateStr);
  return d ? activeAssetMap[d] : null;
}}
function calcMDD(start, end) {{
  var peak = -Infinity, mdd = 0;
  activeAssetDates.forEach(function(d) {{
    if (d < start || d > end) return;
    var v = activeAssetMap[d]; if (!v) return;
    if (v > peak) peak = v;
    var dd = (v - peak) / peak * 100;
    if (dd < mdd) mdd = dd;
  }});
  return mdd;
}}
function fmtRet(val) {{
  if (val === null || isNaN(val)) return '<span class="na">N/A</span>';
  var cls = val >= 0 ? 'pos' : 'neg';
  return '<span class="' + cls + '">' + (val >= 0 ? '+' : '') + val.toFixed(1) + '%</span>';
}}
