def load_crisis_data() -> pd.DataFrame:
    """FRED + 지수데이터 병합 (위기분석용)"""
    xl      = pd.ExcelFile(FRED_PATH)
    daily   = pd.read_excel(xl, sheet_name="일간데이터",  index_col=0, parse_dates=True)
    monthly = pd.read_excel(xl, sheet_name="월간데이터", index_col=0, parse_dates=True)
    monthly_d = monthly.reindex(daily.index, method="ffill")
    frames = [daily, monthly_d]
    if "심리지수" in xl.sheet_names:
        sent = pd.read_excel(xl, sheet_name="심리지수", index_col=0, parse_dates=True)
        frames.append(sent.reindex(daily.index, method="ffill"))
    df = pd.concat(frames, axis=1)
    df = df[~df.index.duplicated(keep="first")].sort_index()

    try:
        raw = pd.read_excel(INDEX_PATH, sheet_name="Sheet6", header=None)
        col_names = raw.iloc[8, 1:].tolist()
        idx = raw.iloc[14:].copy()
        idx.columns = ["Date"] + col_names
        idx["Date"] = pd.to_datetime(idx["Date"], errors="coerce")
        idx = idx.dropna(subset=["Date"]).set_index("Date").sort_index()
        rmap = {"S&P 500": "SP500", "US Dollar Index": "달러인덱스DXY"}
        idx  = idx.rename(columns=rmap)
        for col in ["SP500", "달러인덱스DXY"]:
            if col in idx.columns:
                df[col] = pd.to_numeric(idx[col], errors="coerce").reindex(df.index, method="ffill")
    except Exception:
        pass

    # SP500 전년 대비 변화율 (약 252 거래일 기준)
    # 절대 가격 레벨 대신 등락률을 사용해 시대 간 비교 가능하게 함
    if "SP500" in df.columns:
        df["SP500_yoy"] = df["SP500"].pct_change(252) * 100

    return df


def compute_crisis_profiles(df: pd.DataFrame) -> pd.DataFrame:
    rows = {}
    for name, (start, end) in CRISIS_PERIODS_COMP.items():
        end_ts = df.index[-1] if end is None else pd.Timestamp(end)
        mask   = (df.index >= pd.Timestamp(start)) & (df.index <= end_ts)
        sub    = df.loc[mask]
        row    = {}
        for ind, (col, _) in INDICATORS_COMP.items():
            row[ind] = sub[col].mean() if col in sub.columns else np.nan
        rows[name] = row
    return pd.DataFrame(rows).T


def compute_percentile_scores(df: pd.DataFrame, profiles: pd.DataFrame) -> pd.DataFrame:
    scores = pd.DataFrame(index=profiles.index, columns=profiles.columns, dtype=float)
    for ind, (col, direction) in INDICATORS_COMP.items():
        if col not in df.columns:
            continue
        series = df[col].dropna()
        for crisis in profiles.index:
            val = profiles.loc[crisis, ind]
            if pd.isna(val):
                scores.loc[crisis, ind] = np.nan
                continue
            pct = (series < val).mean() * 100
            scores.loc[crisis, ind] = round(100 - pct if direction == -1 else pct, 1)
    return scores


def compute_similarity(scores: pd.DataFrame) -> pd.Series:
    current_key = [k for k in scores.index if "현재" in k][0]
    current_vec = scores.loc[current_key].fillna(50).values.astype(float)
    sim = {}
    for crisis in scores.index:
        if "현재" in crisis:
            continue
        vec  = scores.loc[crisis].fillna(50).values.astype(float)
        dist = cosine(current_vec, vec)
        sim[crisis] = round((1 - dist) * 100, 1)
    return pd.Series(sim).sort_values(ascending=False)


