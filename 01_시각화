def dtw_load_indicator_data() -> pd.DataFrame:
    """FRED 일간/월간 병합 → 월말 리샘플 (DTW 분석용)"""
    xl = pd.ExcelFile(FRED_PATH)
    daily   = pd.read_excel(xl, sheet_name="일간데이터",
                            index_col=0, parse_dates=True).sort_index()
    monthly = pd.read_excel(xl, sheet_name="월간데이터",
                            index_col=0, parse_dates=True).sort_index()
    monthly_d = monthly.reindex(daily.index, method="ffill")
    df = pd.concat([daily, monthly_d], axis=1)
    df = df[~df.index.duplicated(keep="first")].sort_index()
    if "금현물가격(USD/oz)" in df.columns and "금현물가격" not in df.columns:
        df = df.rename(columns={"금현물가격(USD/oz)": "금현물가격"})
    monthly_final = df.resample("ME").last()
    for c in monthly_final.columns:
        monthly_final[c] = pd.to_numeric(monthly_final[c], errors="coerce")
    return monthly_final


def dtw_build_indicator_matrix(monthly_df: pd.DataFrame) -> pd.DataFrame:
    """DTW 지표 컬럼 추출"""
    ind_cols = [col for col in DTW_INDICATORS.values() if col in monthly_df.columns]
    missing  = [k for k, v in DTW_INDICATORS.items() if v not in monthly_df.columns]
    if missing:
        print(f"  [DTW 경고] 누락 지표: {missing}")
    return monthly_df[ind_cols].copy()


def dtw_compute_percentile_matrix(ind_matrix: pd.DataFrame) -> pd.DataFrame:
    """
    각 지표의 월간 변화량(방향·속도)을 롤링 백분위로 변환 (DTW용).
    레벨이 아닌 diff(1)에 대해 롤링 DTW_PERCENTILE_WINDOW개월 백분위 계산.
    """
    diff_matrix = ind_matrix.diff(1)
    scores = pd.DataFrame(index=ind_matrix.index,
                          columns=ind_matrix.columns, dtype=float)
    for col in diff_matrix.columns:
        if diff_matrix[col].dropna().shape[0] < DTW_PERCENTILE_WINDOW // 2:
            continue
        rolling_pct = pd.Series(index=diff_matrix.index, dtype=float)
        for t in range(len(diff_matrix)):
            if pd.isna(diff_matrix[col].iloc[t]):
                continue
            window_start = max(0, t - DTW_PERCENTILE_WINDOW)
            window = diff_matrix[col].iloc[window_start:t].dropna()
            if len(window) < 6:
                continue
            val = diff_matrix[col].iloc[t]
            rolling_pct.iloc[t] = (window < val).sum() / len(window)
        scores[col] = rolling_pct
    return scores.astype(float)


def compute_dtw_similarity(scores: pd.DataFrame) -> pd.Series:
    """
    DTW(Dynamic Time Warping) 기반 구간 유사도 계산.
    현재 직전 DTW_WINDOW개월 궤적 vs 과거 슬라이딩 구간 비교 → 유사도(%)
    """
    valid_dates = scores.dropna(how="all").index
    if len(valid_dates) < DTW_MIN_HISTORY + DTW_WINDOW:
        print("  [DTW 경고] 데이터 부족")
        return pd.Series(dtype=float)

    current_date = valid_dates[-1]
    cutoff_date  = current_date - pd.DateOffset(months=DTW_EXCLUDE_RECENT)
    current_window = scores.loc[scores.index <= current_date].tail(DTW_WINDOW)

    valid_cols = [
        c for c in scores.columns
        if current_window[c].notna().sum() >= DTW_WINDOW // 2
    ]
    if len(valid_cols) < 3:
        print(f"  [DTW 경고] 유효 지표 부족: {len(valid_cols)}개")
        return pd.Series(dtype=float)

    curr_arr = current_window[valid_cols].interpolate().bfill().values.T
    col_std  = curr_arr.std(axis=1, keepdims=True)
    col_std[col_std == 0] = 1
    curr_arr = curr_arr / col_std

    dist_dict  = {}
    candidates = [d for d in valid_dates if d <= cutoff_date]
    for i in range(DTW_WINDOW, len(candidates)):
        end_date    = candidates[i]
        start_date  = candidates[i - DTW_WINDOW]
        past_window = scores.loc[start_date:end_date, valid_cols]
        if len(past_window) < DTW_WINDOW // 2:
            continue
        past_arr = past_window.interpolate().bfill().values.T
        past_arr = past_arr / col_std

        total_dist, n_channels = 0.0, 0
        for ch in range(len(valid_cols)):
            try:
                d = dtw.distance_fast(
                    curr_arr[ch].astype(np.double),
                    past_arr[ch].astype(np.double)
                )
                if np.isnan(d) or np.isinf(d):
                    continue
                total_dist += d
                n_channels += 1
            except Exception:
                continue
        if n_channels > 0:
            dist_dict[end_date] = total_dist / n_channels

    if not dist_dict:
        return pd.Series(dtype=float)

    dist_series = pd.Series(dist_dict).dropna()
    max_dist = float(np.nanpercentile(dist_series.values, 95))
    if max_dist == 0:
        max_dist = float(dist_series.max()) or 1.0

    sim_dict = {
        d: round(max(0.0, (1 - v / max_dist) * 100), 2)
        for d, v in dist_dict.items()
    }
    return pd.Series(sim_dict).sort_index()


def dtw_get_top_similar(similarity: pd.Series, n: int = DTW_TOP_N) -> pd.Series:
    """유사도 상위 N 구간 반환 (겹치지 않는 구간만)"""
    if not DTW_NON_OVERLAP:
        return similarity.nlargest(n)
    sorted_sim = similarity.sort_values(ascending=False)
    selected = {}
    for date, sim_val in sorted_sim.items():
        overlap = any(
            abs((date - sel_date).days) < DTW_WINDOW * 30
            for sel_date in selected
        )
        if not overlap:
            selected[date] = sim_val
        if len(selected) >= n:
            break
    return pd.Series(selected).sort_values(ascending=False)


def dtw_generate_description(end_date: pd.Timestamp,
                              scores: pd.DataFrame,
                              max_items: int = 3) -> str:
    """유사 구간 내 지표 모멘텀 평균으로 '왜 유사한가' 설명 자동 생성"""
    start_date = end_date - pd.DateOffset(months=DTW_WINDOW)
    window = scores.loc[(scores.index >= start_date) & (scores.index <= end_date)]
    if window.empty:
        return ""
    col_avg   = window.mean()
    deviation = (col_avg - 0.5).abs()
    top_cols  = deviation.nlargest(max_items + 2).index
    parts = []
    for col in top_cols:
        if col not in _DTW_NARR or pd.isna(col_avg[col]):
            continue
        avg = col_avg[col]
        if avg >= 0.68:
            parts.append(_DTW_NARR[col][0])
        elif avg <= 0.32:
            parts.append(_DTW_NARR[col][1])
        if len(parts) == max_items:
            break
    return " · ".join(parts) if parts else "패턴 유사"


def _dtw_forward_returns(asset_df: pd.DataFrame,
                         end_date: pd.Timestamp,
                         horizons: list = [3, 6, 12]) -> dict:
    """
    end_date 시점부터 horizons 개월 후 자산별 수익률(%) 계산.
    반환: {col_key: {3: ret_pct, 6: ret_pct, 12: ret_pct}}
    """
    FWD_ASSETS = [
        ("SP500",            "S&P 500"),
        ("NASDAQ100",        "NASDAQ 100"),
        ("금현물가격",       "금"),
        ("달러인덱스DXY",    "달러"),
        ("미국7-10년국채TR", "미국채"),
        ("미국HY채권TR",     "HY채권"),
        ("WTI원유",          "WTI"),
    ]
    result = {}
    for col, name in FWD_ASSETS:
        if col not in asset_df.columns:
            continue
        s = asset_df[col].dropna()
        # 기준 가격: end_date 이전 가장 가까운 거래일
        base_idx = s.index[s.index <= end_date]
        if base_idx.empty:
            continue
        p0 = s.loc[base_idx[-1]]
        rets = {}
        for h in horizons:
            target = end_date + pd.DateOffset(months=h)
            future_idx = s.index[s.index >= target]
            if future_idx.empty:
                rets[h] = None
            else:
                p1 = s.loc[future_idx[0]]
                rets[h] = round((p1 / p0 - 1) * 100, 1) if p0 > 0 else None
        result[name] = rets
    return result


def build_dtw_timeline(similarity: pd.Series,
                       top_similar: pd.Series,
                       scores: pd.DataFrame,
                       asset_df: pd.DataFrame = None) -> go.Figure:
    """
    DTW 유사도 타임라인 그래프.
    - x축 스크롤 확대만 허용 (y축 고정)
    - 음영 구간에 마우스 올리면 팝업: 지표 특징 + 사후 수익률
    - 별 마커 없음, 구간 레이블만 annotation으로 표시
    """
    fig = go.Figure()

    # 고유사도 구간 배경
    fig.add_hrect(y0=60, y1=100, fillcolor="rgba(39,174,96,0.07)",
                  line_width=0, annotation_text="고유사도 구간 (60%+)",
                  annotation_position="top right",
                  annotation_font=dict(color="rgba(39,174,96,0.7)", size=11))

    # DTW 유사도 라인
    fig.add_trace(go.Scatter(
        x=similarity.index, y=similarity.values,
        mode="lines", name="DTW 유사도",
        line=dict(color="rgba(52,152,219,0.6)", width=1.5),
        fill="tozeroy", fillcolor="rgba(52,152,219,0.08)",
        hovertemplate="%{x|%Y년 %m월} 종료 구간<br>DTW 유사도: %{y:.1f}%<extra></extra>",
    ))

    # EMA 추세선
    ema = similarity.ewm(span=6).mean()
    fig.add_trace(go.Scatter(
        x=ema.index, y=ema.values,
        mode="lines", name="EMA(6개월)",
        line=dict(color="rgba(52,152,219,0.9)", width=2, dash="dot"),
        hoverinfo="skip",
    ))

    # 상위 N 구간: 음영 + 팝업 + 레이블
    for i, (end_date, sim_val) in enumerate(top_similar.items()):
        color       = DTW_TOP_COLORS[i % len(DTW_TOP_COLORS)]
        rank        = i + 1
        start_date  = end_date - pd.DateOffset(months=DTW_WINDOW)
        crisis_name = _dtw_period_label(end_date)
        date_range  = f"{start_date.strftime('%Y.%m')} ~ {end_date.strftime('%Y.%m')}"
        description = dtw_generate_description(end_date, scores)

        # 구간 경계선
        ed_str = end_date.strftime("%Y-%m-%d")
        fig.add_shape(type="line", x0=ed_str, x1=ed_str, y0=0, y1=1,
                      xref="x", yref="paper",
                      line=dict(color=color, width=1.5, dash="dash"))

        # ── 사후 수익률 계산 ──
        fwd_rets = {}
        if asset_df is not None:
            fwd_rets = _dtw_forward_returns(asset_df, end_date)

        # 사후 수익률 호버 텍스트 구성
        fwd_lines = ""
        if fwd_rets:
            # +12M 수익률 기준 상위 자산 강조
            ret12 = {name: rets.get(12) for name, rets in fwd_rets.items()
                     if rets.get(12) is not None}
            top_asset = max(ret12, key=ret12.get) if ret12 else None

            fwd_lines = "<br><b>─ 이후 자산 수익률 ─</b>"
            fwd_lines += "<br><span style='font-size:10px;color:rgba(255,255,255,0.5)'>자산 &nbsp;&nbsp;&nbsp; +3M &nbsp;&nbsp; +6M &nbsp;&nbsp; +12M</span>"
            for name, rets in fwd_rets.items():
                r3  = f"{rets[3]:+.1f}%"  if rets.get(3)  is not None else "N/A"
                r6  = f"{rets[6]:+.1f}%"  if rets.get(6)  is not None else "N/A"
                r12 = f"{rets[12]:+.1f}%" if rets.get(12) is not None else "N/A"
                star = " ★" if name == top_asset else ""
                # 색상: 12M 기준
                if rets.get(12) is not None:
                    c12 = "#2ecc71" if rets[12] >= 0 else "#e74c3c"
                else:
                    c12 = "rgba(255,255,255,0.5)"
                fwd_lines += (
                    f"<br><span style='color:rgba(255,255,255,0.85)'>{name}{star}</span>"
                    f"  {r3} / {r6} / "
                    f"<span style='color:{c12};font-weight:bold'>{r12}</span>"
                )

        # ── 지표 특징 텍스트 ──
        char_line = f"<br><b>─ 지표 특징 ─</b><br>{description}" if description else ""

        hover_text = (
            f"<b>#{rank}위 유사 구간</b><br>"
            f"<span style='color:{color};font-weight:bold'>{crisis_name}</span>"
            f"  <span style='color:rgba(255,255,255,0.5);font-size:11px'>({date_range})</span><br>"
            f"DTW 유사도: <b>{sim_val:.1f}%</b>"
            f"{char_line}"
            f"{fwd_lines}"
            f"<extra></extra>"
        )

        # ── 음영 (vrect 대용 — 별도 shape) ──
        h = color.lstrip("#")
        r_int, g_int, b_int = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
        fill_rgba = f"rgba({r_int},{g_int},{b_int},0.10)"
        fig.add_shape(
            type="rect",
            x0=start_date.strftime("%Y-%m-%d"), x1=end_date.strftime("%Y-%m-%d"),
            y0=0, y1=105,
            fillcolor=fill_rgba, line_width=0, layer="below",
        )

        # ── 호버 캡처: 구간 내 격자 포인트 ──
        # Plotly는 실제 데이터 포인트 근처에서만 hover를 감지하므로,
        # x(월별) × y(20/40/60/80) 격자로 촘촘히 포인트를 뿌려
        # 음영 전 영역에서 hover가 뜨도록 함.
        grid_x_dates = pd.date_range(start=start_date, end=end_date, freq="MS")
        if len(grid_x_dates) == 0:
            grid_x_dates = pd.DatetimeIndex([start_date, end_date])
        grid_y_levels = [15, 35, 55, 75, 95]
        gx, gy = [], []
        for gd in grid_x_dates:
            for gy_val in grid_y_levels:
                gx.append(gd)
                gy.append(gy_val)

        fig.add_trace(go.Scatter(
            x=gx, y=gy,
            mode="markers",
            marker=dict(size=18, opacity=0, color=color),  # 완전 투명 — 보이지 않음
            name=f"#{rank} {crisis_name}",
            hovertemplate=hover_text,
            hoverlabel=dict(
                bgcolor="#1a2535",
                bordercolor=color,
                font=dict(size=12, family="Malgun Gothic", color="white"),
                namelength=0,
            ),
            showlegend=False,
        ))

        # ── 구간 이름 레이블 (annotation) ──
        mid_date = start_date + (end_date - start_date) / 2
        fig.add_annotation(
            x=mid_date.strftime("%Y-%m-%d"), y=92,
            xref="x", yref="y",
            text=f"<b>#{rank}</b><br>{crisis_name}",
            showarrow=False,
            font=dict(size=13, color=color, family="Malgun Gothic"),
            bgcolor="rgba(0,0,0,0.72)",
            bordercolor=color, borderwidth=1.5, borderpad=6, opacity=0.96,
            align="center",
        )

    # ── 우측 순위 요약 박스 ──
    rank_lines = ["<b>▶ 유사 구간 순위</b>"]
    for i, (end_date_r, sim_val_r) in enumerate(top_similar.items()):
        c_r    = DTW_TOP_COLORS[i % len(DTW_TOP_COLORS)]
        name_r = _dtw_period_label(end_date_r)
        rank_lines.append(
            f"<span style='color:{c_r}'>#{i+1}</span>  {name_r}  "
            f"<span style='color:rgba(255,255,255,0.55)'>({sim_val_r:.1f}%)</span>"
        )
    fig.add_annotation(
        x=1.01, y=0.60,
        xref="paper", yref="paper",
        text="<br>".join(rank_lines),
        showarrow=False,
        align="left",
        xanchor="left", yanchor="top",
        font=dict(size=12, family="Malgun Gothic", color="white"),
        bgcolor="rgba(26,26,46,0.85)",
        bordercolor="rgba(255,255,255,0.2)", borderwidth=1, borderpad=8,
    )

    # 현재 시점 수직선
    current_x = similarity.index[-1] if not similarity.empty else pd.Timestamp.now()
    cx_str    = current_x.strftime("%Y-%m-%d")
    fig.add_shape(type="line", x0=cx_str, x1=cx_str, y0=0, y1=1,
                  xref="x", yref="paper",
                  line=dict(color="rgba(255,255,255,0.6)", width=2, dash="dot"))
    fig.add_annotation(x=cx_str, y=1.02, xref="x", yref="paper",
                       text="현재", showarrow=False,
                       font=dict(color="white", size=11))

    fig.update_layout(
        title=dict(
            text=(
                "<b>현재 시장과 유사한 과거 구간 탐색 (DTW)</b>"
                f"  <span style='font-size:14px;color:rgba(255,255,255,0.6)'>"
                f"(비교 구간: {DTW_WINDOW}개월 궤적 · 음영=유사 구간)</span>"
            ),
            font=dict(size=20, family="Malgun Gothic", color="white"), x=0.0,
        ),
        xaxis=dict(
            title="날짜", showgrid=True,
            gridcolor="rgba(255,255,255,0.08)", tickformat="%Y",
            fixedrange=False,   # x축: 스크롤 확대 허용
        ),
        yaxis=dict(
            title="유사도 (%)", range=[0, 105],
            showgrid=True, gridcolor="rgba(255,255,255,0.08)",
            fixedrange=True,    # y축: 고정 (확대 불가)
        ),
        template="plotly_dark",
        autosize=True,
        height=520,          # 최소 기준 높이 — 실제 렌더는 컨테이너 크기에 따름
        hovermode="closest",
        font=dict(family="Malgun Gothic", color="white"),
        legend=dict(
            orientation="v", x=1.01, y=1.0, xanchor="left", yanchor="top",
            font=dict(size=12), bgcolor="rgba(0,0,0,0.4)",
            bordercolor="rgba(255,255,255,0.2)", borderwidth=1,
        ),
        dragmode=False,   # 좌클릭 드래그 이동 비활성화
        margin=dict(l=60, r=280, t=80, b=50),
        paper_bgcolor="rgba(0,0,0,0)",
        plot_bgcolor="rgba(0,0,0,0)",
    )
    return fig

