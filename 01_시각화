  // false = 수치가 높을수록 시장에 나쁨 (높음→빨간, 낮음→초록)
  var IND_HIGH_IS_GOOD = {{
    'VIX':                  false,
    '장단기금리차(10Y-2Y)': true,
    'HY크레딧스프레드':     false,
    '미국CPI':              false,
    '실질금리TIPS10Y':      false,
    '달러인덱스DXY':        false,
    'SP500(전년비%)':       true,
    '미국실업률':           false,
  }};

  cd.indicators.forEach(function(ind) {{
    if (ind.cur_pct === null && ind.cri_pct === null) return;
    var diff = (ind.cur_pct !== null && ind.cri_pct !== null)
               ? (ind.cur_pct - ind.cri_pct) : null;

    var diffStr;
    if (diff === null) {{
      diffStr = '<span style="color:rgba(255,255,255,0.3);">-</span>';
    }} else if (Math.abs(diff) <= 5) {{
      diffStr = '<span style="color:#f39c12;">≈ 유사</span>';
    }} else {{
      // 현재가 당시보다 높은지(diff>5) 낮은지(diff<-5)
      var isHigh = diff > 5;
      // 해당 방향이 시장에 우호적인지 판단
      var highIsGood = (ind.name in IND_HIGH_IS_GOOD) ? IND_HIGH_IS_GOOD[ind.name] : null;
      var goodForMarket = (highIsGood === null) ? null : (isHigh ? highIsGood : !highIsGood);
      var col   = goodForMarket === null ? '#f39c12'
                : goodForMarket ? '#2ecc71' : '#e74c3c';
      var arrow = isHigh ? '▲ 높음' : '▼ 낮음';
      diffStr = '<span style="color:' + col + ';font-weight:bold;">' + arrow + '</span>';
    }}

    var curPct = ind.cur_pct !== null
      ? '<span style="color:#ecf0f1;">' + ind.cur_pct.toFixed(0) + '점</span>' : 'N/A';
    var criPct = ind.cri_pct !== null
      ? '<span style="color:#ecf0f1;">' + ind.cri_pct.toFixed(0) + '점</span>' : 'N/A';
    var curRaw = ind.cur_raw !== null
      ? '<div style="color:rgba(255,255,255,0.38);font-size:10px;">(' + ind.cur_raw + ')</div>' : '';
    var criRaw = ind.cri_raw !== null
      ? '<div style="color:rgba(255,255,255,0.38);font-size:10px;">(' + ind.cri_raw + ')</div>' : '';

    html += '<tr style="border-bottom:1px solid rgba(255,255,255,0.05);">'
      + '<td style="padding:6px 4px;color:rgba(255,255,255,0.85);">' + ind.name + '</td>'
      + '<td style="padding:6px 4px;text-align:center;">' + curPct + curRaw + '</td>'
      + '<td style="padding:6px 4px;text-align:center;">' + criPct + criRaw + '</td>'
      + '<td style="padding:6px 4px;text-align:center;">' + diffStr + '</td>'
      + '</tr>';
  }});

  html += '</tbody></table>';
  document.getElementById('crisis-detail-content').innerHTML = html;
}}

