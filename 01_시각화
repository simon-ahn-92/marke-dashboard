def _dtw_period_label(end_date: pd.Timestamp) -> str:
    """
    DTW 유사 구간(종료일 기준 DTW_WINDOW개월)을 위기 이름으로 반환.
    가장 많이 겹치는 위기 구간의 이름을 선택. 매핑 없으면 날짜 표시.
    """
    start_date   = end_date - pd.DateOffset(months=DTW_WINDOW)
    best_label   = None
    best_overlap = 0
    for cs, ce, cname in _DTW_CRISIS_PERIODS:
        cs_ts = pd.Timestamp(cs)
        ce_ts = pd.Timestamp(ce)
        overlap_start = max(start_date, cs_ts)
        overlap_end   = min(end_date,   ce_ts)
        if overlap_end > overlap_start:
            overlap_days = (overlap_end - overlap_start).days
            if overlap_days > best_overlap:
                best_overlap = overlap_days
                best_label   = cname
    if best_label:
        return best_label
    return f"{start_date.strftime('%Y.%m')}~{end_date.strftime('%Y.%m')}"


