# 3. 12개 체크리스트 평가
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LEVERAGE_KEYWORDS = ["Leveraged", "Ultra", "Inverse", "Short", "2x", "3x",
                     "-1x", "-2x", "-3x", "Bear", "Bull"]
HY_KEYWORDS = ["High Yield", "HY ", "Junk", "Covered Call", "BuyWrite"]
INCOME_CATEGORIES = ["채권", "회사채", "국채", "TIPS", "리츠", "부동산",
                     "고배당", "배당", "Dividend", "HY", "IG"]

def evaluate_etf(row: pd.Series, sheet: str, cagr_5y: float | None,
                 bm_cagrs: dict, fund_type: str = "etf") -> dict:
    """단일 ETF/뮤추얼펀드 12개 항목 평가 → {1: '✓', 2: '✗', ...}
    fund_type: "etf" | "mutual"  (#7 한국 세무 처리 차이)
    """
    ticker  = str(row.get("티커", "")).strip()
    name    = str(row.get("ETF명", "") or "")
    aum     = row.get("AUM(억달러)")  # 억달러 단위
    year    = row.get("상장연도")
    expense = row.get("운용보수(%)")  # ratio (0.0003 = 0.03%)
    star    = row.get("별점(5점)")
    category = ""
    for col in ["분류", "테마", "유형"]:
        if col in row.index and pd.notna(row.get(col)):
            category = str(row[col])
            break
    if "만기구분" in row.index and pd.notna(row.get("만기구분")):
        category += " " + str(row["만기구분"])

    text = (name + " " + category).lower()
    chk = {}

    # 1. 트랙레코드 5년 이상 (10년 선호)
    if pd.notna(year):
        age = CURRENT_YR - int(year)
        if age >= 10:
            chk[1] = "✓⭐"   # 10년 이상
        elif age >= 5:
            chk[1] = "✓"
        else:
            chk[1] = "✗"
    else:
        chk[1] = "?"

    # 2. AUM USD 100M 이상 (1억달러 = AUM 1.0)
    if pd.notna(aum):
        chk[2] = "✓" if float(aum) >= 1.0 else "✗"
    else:
        chk[2] = "?"

    # 3. 독립평가 양호 (별점 >= 4 proxy)
    if pd.notna(star):
        chk[3] = "✓" if int(star) >= 4 else "△"   # 3점은 보통, 4점 이상만 ✓
    else:
        chk[3] = "?"

    # 4. 5년 벤치마크 상회 (Equity → SPY, Bond → AGG)
    is_bond = any(k in category for k in ["채권", "국채", "회사채", "TIPS"])
    bm_key  = "AGG" if is_bond else "SPY"
    bm_cagr = bm_cagrs.get(bm_key)
    if cagr_5y is not None and bm_cagr is not None:
        chk[4] = "✓" if cagr_5y >= bm_cagr else "✗"
    else:
        chk[4] = "?"

    # 5. Sharpe/Sortino/MDD 데이터 확보 가능 (5년 트랙레코드 = 가능)
    chk[5] = "✓" if chk[1].startswith("✓") else "✗"

    # 6. 일별 유동성 + 투명 수수료
    # US 상장 ETF는 일별 거래 ✓, 운용보수 < 0.75%이면 투명/저보수 ✓
    # 입력 단위: ETF는 ratio(0.0003=0.03%), 뮤추얼은 percent(0.04=0.04%)
    if pd.notna(expense):
        exp_pct = float(expense) * 100 if fund_type == "etf" else float(expense)
        chk[6] = "✓" if exp_pct < 0.75 else "✗"
    else:
        chk[6] = "?"

    # 7. 한국 법인 세무 적합
    if fund_type == "mutual":
        # 미국 뮤추얼 펀드: 국내 거주자 직접 매수 불가 (NAV 매매, 거래소 미상장)
        # 국내 운용사의 재간접 펀드 형태로만 접근 가능 → 사용자 확인 필요
        chk[7] = "?"
    else:
        # US 상장 ETF: 양도세 22% / UCITS도 적합 → ✓
        chk[7] = "✓"

    # 8. 패밀리 기존보유 ISIN 차별화 (사용자 컨텍스트)
    chk[8] = "?"

    # 9. 단일 펀드 비중 20% 미만 (포트폴리오 컨텍스트)
    chk[9] = "?"

    # 10. HY/커버드콜 15% 미만
    is_hy_or_cc = any(k.lower() in text for k in HY_KEYWORDS) or "HY" in category
    if is_hy_or_cc:
        chk[10] = "?"   # HY → 사용자 컨텍스트 필요
    else:
        chk[10] = "✓N/A"   # 해당없음 → 자동 OK

    # 11. 레버리지/투기/구조화노트 ❌
    has_leverage = any(k.lower() in text for k in LEVERAGE_KEYWORDS)
    # VIX 단기/구조화 ETF는 별도 ✗
    if ticker in ("UVXY", "SVXY", "VIXY", "USO", "UNG"):
        chk[11] = "✗"
    elif has_leverage:
        chk[11] = "✗"
    else:
        chk[11] = "✓"

    # 12. 명확한 분배정책 + 인컴 이력 (인컴 펀드인 경우만)
    is_income = any(k.lower() in text for k in [c.lower() for c in INCOME_CATEGORIES])
    if is_income:
        # 인컴 펀드: 트랙레코드 5년+이면 분배 이력 확보 가능 → ✓
        chk[12] = "✓" if chk[1].startswith("✓") else "?"
    else:
        chk[12] = "✓N/A"   # 인컴 펀드 아니면 N/A → 자동 OK

    chk["_is_income"] = is_income
    return chk


def count_pass(chk: dict) -> int:
    """자동 검증 9개 항목 중 ✓ 개수 (✓⭐, ✓N/A 포함, △/✗/? 제외)"""
    return sum(1 for k in AUTO_ITEMS if str(chk.get(k, "")).startswith("✓"))


