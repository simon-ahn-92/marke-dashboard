# 1. EODHD CAGR 계산 (5년)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def fetch_5y_cagr(ticker: str) -> float | None:
    """최근 5년 CAGR(%) — EODHD adjusted_close 월별"""
    suffix = ".US"
    if "." in ticker:
        sym = ticker
    else:
        sym = ticker + suffix

    url = (f"https://eodhd.com/api/eod/{sym}"
           f"?api_token={EODHD_KEY}&fmt=json&period=m")
    try:
        r = requests.get(url, timeout=15, verify=False)
        if r.status_code != 200:
            return None
        data = r.json()
        if not isinstance(data, list) or len(data) < 24:
            return None
        # 최근 60개월 슬라이스
        recent = data[-60:] if len(data) >= 60 else data
        closes = [d.get("adjusted_close") for d in recent
                  if d.get("adjusted_close") is not None]
        if len(closes) < 24:
            return None
        years = len(closes) / 12.0
        if closes[0] <= 0:
            return None
        return ((closes[-1] / closes[0]) ** (1 / years) - 1) * 100
    except Exception:
        return None


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1-1B. 5년 일간 가격 → Sharpe / Sortino / Vol / MDD
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def fetch_5y_risk_metrics(ticker: str, rf_annual: float = 0.04) -> dict:
    """일간 adjusted_close → Sharpe(연환산), Sortino, Vol(연환산), MaxDrawdown
    rf_annual: 연 무위험수익률 (기본 4%, 미국 단기 T-bill 평균)
    반환: {"sharpe": ..., "sortino": ..., "vol_annual_pct": ..., "mdd_pct": ..., "n_days": ...}
    """
    sym = ticker if "." in ticker else ticker + ".US"
    today = datetime.today()
    start = today.replace(year=today.year - 5).strftime("%Y-%m-%d")

    url = (f"https://eodhd.com/api/eod/{sym}"
           f"?api_token={EODHD_KEY}&fmt=json&from={start}&period=d")
    try:
        r = requests.get(url, timeout=20, verify=False)
        if r.status_code != 200:
            return {}
        data = r.json()
        if not isinstance(data, list) or len(data) < 252:
            return {}

        closes = [d.get("adjusted_close") for d in data
                  if d.get("adjusted_close") is not None and d["adjusted_close"] > 0]
        if len(closes) < 252:
            return {}

        prices = pd.Series(closes, dtype=float)
        rets   = prices.pct_change().dropna()
        if len(rets) < 100:
            return {}

        # 연환산 변동성
        vol_d  = rets.std()
        vol_a  = vol_d * (252 ** 0.5)

        # 연환산 평균 수익률 (산술)
        mu_d   = rets.mean()
        mu_a   = mu_d * 252

        # Sharpe = (μ - rf) / σ
        sharpe = (mu_a - rf_annual) / vol_a if vol_a > 0 else None

        # Sortino: 하방 변동성만 사용 (rf 일별 환산 대비 손실)
        rf_d   = rf_annual / 252
        downside = rets[rets < rf_d] - rf_d
        if len(downside) > 0:
            down_d = (downside ** 2).mean() ** 0.5
            down_a = down_d * (252 ** 0.5)
            sortino = (mu_a - rf_annual) / down_a if down_a > 0 else None
        else:
            sortino = None

        # MDD (5년 일간 기준)
        cummax = prices.cummax()
        dd     = (prices / cummax - 1.0)
        mdd    = float(dd.min()) * 100   # %로 표시

        return {
            "sharpe":         round(sharpe, 2) if sharpe is not None else None,
            "sortino":        round(sortino, 2) if sortino is not None else None,
            "vol_annual_pct": round(float(vol_a) * 100, 2),
            "mdd_pct":        round(mdd, 2),
            "n_days":         len(rets),
        }
    except Exception:
        return {}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1-2. TTM 인컴 수익률 계산
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def fetch_ttm_yield(ticker: str) -> tuple:
    """최근 12개월 분배 / 현재가 → TTM 수익률(%)

    자본이득 분배 제거 이중 필터:
      A) NAV의 3% 초과 단일 분배 → 자본이득으로 간주 (액티브 뮤추얼펀드 대응)
      B) 잔여 분배의 중앙값 × 3 초과 → 추가 outlier 제거 (분기 + 연말 보너스 대응)

    반환: (ttm_yield_pct, ttm_sum, outlier_excluded_count, current_price, last_div_date)
    """
    if "." in ticker:
        sym = ticker
    else:
        sym = ticker + ".US"

    today = datetime.today()
    one_year_ago = today.replace(year=today.year - 1).strftime("%Y-%m-%d")

    div_url = (f"https://eodhd.com/api/div/{sym}"
               f"?api_token={EODHD_KEY}&from={one_year_ago}&fmt=json")
    eod_url = (f"https://eodhd.com/api/eod/{sym}"
               f"?api_token={EODHD_KEY}&from={(today.replace(month=max(today.month-2,1))).strftime('%Y-%m-%d')}"
               f"&fmt=json")

    try:
        divs   = requests.get(div_url, timeout=15, verify=False).json()
        prices = requests.get(eod_url, timeout=15, verify=False).json()

        if not isinstance(divs, list) or not divs:
            return None, 0.0, 0, None, None
        if not isinstance(prices, list) or not prices:
            return None, 0.0, 0, None, None

        last_px = prices[-1].get("adjusted_close") or prices[-1].get("close")
        if not last_px or float(last_px) <= 0:
            return None, 0.0, 0, None, None
        last_px = float(last_px)

        values = [float(d.get("value", 0)) for d in divs
                  if d.get("value") and float(d.get("value", 0)) > 0]
        if not values:
            return None, 0.0, 0, last_px, None

        excluded = 0

        # A) NAV의 3% 초과 단일 분배 = 자본이득
        # (정상 분배: 분기당 0.5~1%, 연 1회 1.5~2.5%; 자본이득은 통상 NAV의 5~15%)
        nav_thr = last_px * 0.03
        kept_a = []
        for v in values:
            if v > nav_thr:
                excluded += 1
            else:
                kept_a.append(v)

        # B) 잔여 분배의 중앙값 × 3 초과 → 추가 outlier
        if len(kept_a) >= 3:
            sv = sorted(kept_a)
            n = len(sv)
            med = sv[n // 2] if n % 2 else (sv[n//2-1] + sv[n//2]) / 2
            med_thr = med * 3.0
            kept_b = []
            for v in kept_a:
                if v > med_thr:
                    excluded += 1
                else:
                    kept_b.append(v)
        else:
            kept_b = kept_a

        ttm_sum = sum(kept_b)
        ttm_yld = (ttm_sum / last_px) * 100
        last_dt = divs[-1].get("date")

        # 모든 분배가 자본이득으로 필터링됨 → 액티브 뮤추얼펀드 (배당+자본이득 일괄 분배)
        # 데이터로 분리 불가 → -1 (sentinel)로 반환
        if ttm_sum == 0 and excluded > 0:
            return -1.0, 0.0, excluded, last_px, last_dt

        return round(ttm_yld, 2), round(ttm_sum, 4), excluded, last_px, last_dt

    except Exception:
        return None, 0.0, 0, None, None


