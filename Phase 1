            }
            rows_eval.append(rec)

        result_dfs[sheet] = pd.DataFrame(rows_eval)
        n_pass = (result_dfs[sheet]["통과(9개중)"] >= PASS_THRESHOLD).sum()
        print(f"  {sheet:12s}  {len(df):3d}개 → 통과 {n_pass}개")

    # ETF 시트만 통과 합본 (뮤추얼펀드는 별도 — #7이 ?라서 점수 비교 부정확)
    passed_combined = []
    for sheet, df_ev in result_dfs.items():
        if sheet == "뮤추얼펀드":
            continue
        df_pass = df_ev[df_ev["통과(9개중)"] >= PASS_THRESHOLD].copy()
        df_pass.insert(0, "구분", sheet.replace("ETF",""))
        passed_combined.append(df_pass)
    df_passed = pd.concat(passed_combined, ignore_index=True)
    df_passed = df_passed.sort_values(["구분", "통과(9개중)", "AUM(억달러)"],
                                       ascending=[True, False, False])
    print(f"\n  ★ 통과 ETF (≥{PASS_THRESHOLD}/9): {len(df_passed)}개")

    # 엑셀 저장
    print(f"\n[엑셀 저장] {OUTPUT_PATH}")
    save_excel(result_dfs, df_passed, bm_cagrs)
    print("\n[완료]")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 5. 엑셀 저장 (포맷팅 포함)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
def save_excel(result_dfs: dict, df_passed: pd.DataFrame, bm_cagrs: dict):
    with pd.ExcelWriter(OUTPUT_PATH, engine="xlsxwriter") as writer:
        wb = writer.book

        # 포맷 정의
        header_fmt = wb.add_format({
            "bold": True, "bg_color": "#1a1a2e", "font_color": "white",
            "border": 1, "align": "center", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕", "text_wrap": True
        })
        cell_fmt = wb.add_format({
            "border": 1, "align": "center", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕"
        })
        cell_left = wb.add_format({
            "border": 1, "align": "left", "valign": "vcenter",
            "font_size": 10, "font_name": "맑은 고딕"
        })
        chk_ok    = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":10,"bg_color":"#d5f5e3","font_color":"#1a7a3a","bold":True})
        chk_no    = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":10,"bg_color":"#fadbd8","font_color":"#c0392b","bold":True})
        chk_q     = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":10,"bg_color":"#fef5e7","font_color":"#d68910"})
        chk_mid   = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":10,"bg_color":"#ebf5fb","font_color":"#2874a6"})
        pass_yes  = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":11,"bg_color":"#1a7a3a","font_color":"white","bold":True})
        pass_no   = wb.add_format({"border":1,"align":"center","valign":"vcenter",
                                    "font_size":11,"bg_color":"#999999","font_color":"white"})

        chk_cols = ["1.트랙레코드5y+","2.AUM 100M+","3.독립평가양호","4.벤치마크상회",
                    "5.샤프/소티노/MDD가능","6.유동성+투명수수료","7.한국세무적합",
                    "8.ISIN차별화","9.단일펀드<20%","10.HY/커버드콜<15%",
                    "11.레버리지/구조화제외","12.분배정책명확"]

        def write_df(df, sheet_name, is_mutual=False):
            df.to_excel(writer, sheet_name=sheet_name, index=False,
                        header=False, startrow=1)
            ws = writer.sheets[sheet_name]
            for ci, col in enumerate(df.columns):
                ws.write(0, ci, col, header_fmt)

            # 컬럼폭
            widths = []
            for col in df.columns:
                if col == "티커": widths.append(8)
                elif col == "ETF명": widths.append(38)
                elif col == "분류" or col == "구분": widths.append(14)
                elif col == "선정이유": widths.append(28)
                elif col in ("통과(9개중)", "별점(5점)", "인컴구분"): widths.append(8)
                elif col == "자본이득제외(회)": widths.append(10)
                elif col == "TTM수익률(%)": widths.append(12)
                elif col in ("Sharpe(5y)", "Sortino(5y)"): widths.append(10)
                elif col in ("변동성(연%,5y)", "MDD(5y,%)"): widths.append(12)
                elif col == "Morningstar(수동)": widths.append(13)
                elif col in ("AUM(억달러)", "상장연도", "운용보수(%)", "5년CAGR(%)",
                              "5년 벤치마크 상회"): widths.append(11)
                elif col in chk_cols: widths.append(12)
                else: widths.append(11)
            for ci, w in enumerate(widths):
                ws.set_column(ci, ci, w)

            for ri, (_, row) in enumerate(df.iterrows()):
                ws.set_row(ri + 1, 22)
                for ci, col in enumerate(df.columns):
                    val = row[col]
                    if col == "통과(9개중)":
                        fmt = pass_yes if (pd.notna(val) and int(val) >= PASS_THRESHOLD) else pass_no
                        ws.write(ri+1, ci, f"{val}/9" if pd.notna(val) else "", fmt)
                    elif col in chk_cols:
                        s = str(val) if pd.notna(val) else ""
                        if s.startswith("✓⭐"):
                            ws.write(ri+1, ci, s, chk_ok)
                        elif s.startswith("✓"):
                            ws.write(ri+1, ci, s, chk_ok)
                        elif s == "✗":
                            ws.write(ri+1, ci, s, chk_no)
                        elif s == "△":
                            ws.write(ri+1, ci, s, chk_mid)
                        elif s == "?":
                            ws.write(ri+1, ci, s, chk_q)
                        else:
                            ws.write(ri+1, ci, s, cell_fmt)
                    elif col in ("ETF명", "선정이유"):
                        ws.write(ri+1, ci, val if pd.notna(val) else "", cell_left)
                    elif col == "운용보수(%)":
                        if pd.notna(val):
                            # ETF는 ratio(0.0003), 뮤추얼은 percent(0.04)
                            pct = float(val) if is_mutual else float(val) * 100
                            ws.write(ri+1, ci, f"{pct:.2f}%", cell_fmt)
                        else:
                            ws.write(ri+1, ci, "", cell_fmt)
                    elif col == "5년CAGR(%)":
                        if pd.notna(val):
                            ws.write(ri+1, ci, f"{float(val):+.2f}%", cell_fmt)
                        else:
                            ws.write(ri+1, ci, "N/A", cell_fmt)
                    elif col == "TTM수익률(%)":
                        if pd.notna(val) and float(val) > 0:
                            yld = float(val)
                            yld_fmt = chk_ok if yld >= 4.0 else cell_fmt
                            ws.write(ri+1, ci, f"{yld:.2f}%", yld_fmt)
                        elif pd.notna(val) and float(val) == -1:
                            # 모든 분배가 자본이득 필터에 걸림 → 분리 불가
                            ws.write(ri+1, ci, "혼합분배", chk_q)
                        else:
                            ws.write(ri+1, ci, "-", cell_fmt)
                    elif col == "인컴구분":
                        if val == "인컴":
                            ws.write(ri+1, ci, val, chk_mid)
                        else:
                            ws.write(ri+1, ci, "-" if not pd.notna(val) or val == "-" else val, cell_fmt)
                    elif col == "자본이득제외(회)":
                        if pd.notna(val) and int(val) > 0:
                            ws.write(ri+1, ci, int(val), chk_q)
                        else:
                            ws.write(ri+1, ci, "" if not pd.notna(val) or int(val) == 0 else int(val), cell_fmt)
                    elif col == "Sharpe(5y)":
                        if pd.notna(val):
                            v = float(val)
                            sharpe_fmt = chk_ok if v >= 1.0 else (chk_no if v < 0 else cell_fmt)
                            ws.write(ri+1, ci, f"{v:.2f}", sharpe_fmt)
                        else:
                            ws.write(ri+1, ci, "N/A", cell_fmt)
                    elif col == "Sortino(5y)":
                        if pd.notna(val):
                            v = float(val)
                            sort_fmt = chk_ok if v >= 1.5 else (chk_no if v < 0 else cell_fmt)
                            ws.write(ri+1, ci, f"{v:.2f}", sort_fmt)
                        else:
                            ws.write(ri+1, ci, "N/A", cell_fmt)
                    elif col == "변동성(연%,5y)":
                        if pd.notna(val):
                            v = float(val)
                            ws.write(ri+1, ci, f"{v:.2f}%", cell_fmt)
                        else:
                            ws.write(ri+1, ci, "N/A", cell_fmt)
                    elif col == "MDD(5y,%)":
                        if pd.notna(val):
                            v = float(val)
                            mdd_fmt = chk_no if v <= -30.0 else (chk_q if v <= -15.0 else cell_fmt)
                            ws.write(ri+1, ci, f"{v:+.2f}%", mdd_fmt)
                        else:
                            ws.write(ri+1, ci, "N/A", cell_fmt)
                    elif col == "Morningstar(수동)":
                        ws.write(ri+1, ci, val if pd.notna(val) and val != "" else "", cell_fmt)
                    elif col == "AUM(억달러)":
                        if pd.notna(val):
                            ws.write(ri+1, ci, float(val), cell_fmt)
                        else:
                            ws.write(ri+1, ci, "", cell_fmt)
                    elif col == "상장연도":
                        if pd.notna(val):
                            ws.write(ri+1, ci, int(val), cell_fmt)
                        else:
                            ws.write(ri+1, ci, "", cell_fmt)
                    else:
                        ws.write(ri+1, ci, val if pd.notna(val) else "", cell_fmt)

            ws.freeze_panes(1, 2)
            ws.autofilter(0, 0, len(df), len(df.columns) - 1)

        # 통과 ETF 시트 (최상단)
        write_df(df_passed, "★통과ETF")

        # 시트별 전체 평가
        for sheet, df_ev in result_dfs.items():
            if sheet == "뮤추얼펀드":
                write_df(df_ev, "뮤추얼펀드_평가", is_mutual=True)
            elif sheet == "Preferred_커버드콜":
                write_df(df_ev, "Preferred_커버드콜_평가")
            elif sheet == "Quality_배당성장":
                write_df(df_ev, "Quality_배당성장_평가")
            else:
                write_df(df_ev, sheet.replace("ETF", "_평가"))

        # 체크리스트 설명 시트
        legend_rows = [
            ("자동 검증", 1, "트랙레코드 5년 이상 (10년 선호)",
             "상장연도 기준. 10년 이상은 ✓⭐ 표시"),
            ("자동 검증", 2, "AUM USD 100M 이상",
             "1억달러 (AUM(억달러) >= 1.0)"),
            ("자동 검증", 3, "Morningstar 등 독립평가 양호",
             "별점(5점) >= 4 proxy. △ = 3점 (보통)"),
            ("자동 검증", 4, "5년 벤치마크 상회",
             "주식 ETF→SPY, 채권 ETF→AGG의 5년 CAGR과 비교"),
            ("자동 검증", 5, "Sharpe/Sortino/MDD 데이터 확보 가능",
             "5년 트랙레코드 보유 시 자동 ✓"),
            ("자동 검증", 6, "일별 유동성 + 투명한 수수료",
             "US 상장 ETF는 일별 거래. 운용보수 < 0.75% 시 ✓"),
            ("자동 검증", 7, "한국 법인 세무 적합",
             "US 상장 (W-8BEN, 양도세 22%) → ✓"),
            ("컨텍스트", 8, "패밀리 기존보유 ISIN과 차별화",
             "사용자 보유 정보 필요 → ? (수동 마킹)"),
            ("컨텍스트", 9, "단일 펀드 비중 20% 미만",
             "포트폴리오 구성 단계 검토 필요 → ?"),
            ("컨텍스트", 10, "HY/커버드콜 단일 15% 미만",
             "HY 펀드는 ?, 그 외 ✓N/A"),
            ("자동 검증", 11, "레버리지/투기/구조화노트 코어 사용 ❌",
             "Leveraged/Ultra/Inverse/Bear/2x/3x/VIX 등 키워드 검사"),
            ("자동 검증", 12, "명확한 분배정책 + 인컴 이력",
             "채권/리츠/배당 등 인컴 펀드: 5년+ ✓, 그 외: ✓N/A"),
        ]
        df_legend = pd.DataFrame(legend_rows,
            columns=["구분", "번호", "체크리스트 항목", "평가 방식"])
        df_legend.to_excel(writer, sheet_name="체크리스트설명",
                           index=False, header=False, startrow=1)
        ws_l = writer.sheets["체크리스트설명"]
        for ci, col in enumerate(df_legend.columns):
            ws_l.write(0, ci, col, header_fmt)
        ws_l.set_column(0, 0, 12)
        ws_l.set_column(1, 1, 6)
        ws_l.set_column(2, 2, 36)
        ws_l.set_column(3, 3, 60)
        for ri, (_, row) in enumerate(df_legend.iterrows()):
            ws_l.set_row(ri+1, 32)
            for ci, val in enumerate(row):
                ws_l.write(ri+1, ci, val,
                    cell_fmt if ci != 3 else cell_left)

        # 벤치마크 정보
        bm_rows = [("SPY (주식 벤치마크)", f"{bm_cagrs['SPY']:+.2f}%" if bm_cagrs.get('SPY') is not None else "N/A"),
                   ("AGG (채권 벤치마크)", f"{bm_cagrs['AGG']:+.2f}%" if bm_cagrs.get('AGG') is not None else "N/A"),
                   ("기준 통과 점수",        f"{PASS_THRESHOLD} / 9 (자동 검증 항목 9개 중)"),
                   ("평가 일자",             TODAY.strftime("%Y-%m-%d"))]
        df_bm = pd.DataFrame(bm_rows, columns=["구분", "값"])
        df_bm.to_excel(writer, sheet_name="벤치마크",
                       index=False, header=False, startrow=1)
        ws_b = writer.sheets["벤치마크"]
        for ci, col in enumerate(df_bm.columns):
            ws_b.write(0, ci, col, header_fmt)
        ws_b.set_column(0, 0, 25)
        ws_b.set_column(1, 1, 30)
        for ri, (_, row) in enumerate(df_bm.iterrows()):
            ws_b.set_row(ri+1, 22)
            for ci, val in enumerate(row):
                ws_b.write(ri+1, ci, val, cell_fmt)


if __name__ == "__main__":
    main()
