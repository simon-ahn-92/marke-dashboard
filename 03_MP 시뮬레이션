let _pieOrigColors = null;

function highlightPieStyle(style) {{
  const pieEl = document.getElementById('chart-pie');
  if (!pieEl || !pieEl.data || !pieEl.data.length) return;
  const labels = pieEl.data[0].labels;

  // 첫 호출 시 원본 색상 저장
  if (!_pieOrigColors) _pieOrigColors = [...pieEl.data[0].marker.colors];

  const pull = labels.map(t => (ETF_STYLE_MAP[t] || '기타') === style ? 0.08 : 0);
  const colors = _pieOrigColors.map((c, i) =>
    (ETF_STYLE_MAP[labels[i]] || '기타') === style ? c : c + '33'
  );
  Plotly.restyle('chart-pie', {{'pull': [pull], 'marker.colors': [colors]}}, [0]);
}}

function resetPieStyle() {{
  const pieEl = document.getElementById('chart-pie');
  if (!pieEl || !pieEl.data || !pieEl.data.length || !_pieOrigColors) return;
  const n = pieEl.data[0].labels.length;
  Plotly.restyle('chart-pie', {{
    'pull':          [new Array(n).fill(0)],
    'marker.colors': [_pieOrigColors],
  }}, [0]);
}}

