    }});
    annotations.push({{
      ax:parseFloat(curr.sigma.toFixed(3)), ay:parseFloat(curr.mu.toFixed(3)),
      x:parseFloat(imp2.sigma.toFixed(3)),  y:parseFloat(imp2.mu.toFixed(3)),
      axref:'x', ayref:'y', xref:'x', yref:'y',
