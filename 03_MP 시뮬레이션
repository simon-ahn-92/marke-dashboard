      hovertemplate:`σ: ${{curr.sigma.toFixed(2)}}%<br>μ: ${{curr.mu.toFixed(2)}}%<br>샤프: ${{curr.sharpe.toFixed(2)}}<extra>현재</extra>`,
    }},
  ];

  const annotations = [];
  if (imp1) {{
    traces.push({{
      type:'scatter', mode:'markers+text', name:'① 수익률 유지·변동성↓',
      x:[parseFloat(imp1.sigma.toFixed(3))], y:[parseFloat(imp1.mu.toFixed(3))],
      marker:{{size:14, color:'#2ecc71', symbol:'triangle-up', line:{{color:'white',width:1}}}},
      text:['① 개선'], textposition:'top center',
