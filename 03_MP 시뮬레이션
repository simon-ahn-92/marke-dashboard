// ── 개선안 백테스트 비교 렌더 ───────────────────
function _renderImpBacktest() {{
  const sec = document.getElementById('imp-backtest-section');
  if (!sec) return;
  if (!_globalImp1 && !_globalImp2) {{ sec.style.display = 'none'; return; }}

  const allDates = MONTHLY_DATA.dates;
  const si       = allDates.findIndex(d => d >= '2010-01-01');
  const sIdx     = si >= 0 ? si : 0;

  // ── 월별 수익률 → 누적지수 계산 ─────────────
  function toCum(monthlyRets) {{
    let v = 100; return monthlyRets.map(r => {{ v *= (1 + r); return v; }});
  }}

  const portCurr = computePortfolioReturnsQR(_lastWeights);
  const cumCurr  = toCum(portCurr.returns);

  let imp1Rets = null, cumImp1 = null;
  let imp2Rets = null, cumImp2 = null;
  if (_globalImp1) {{
    imp1Rets = computePortfolioReturnsQR(_globalImp1.w);
    cumImp1  = toCum(imp1Rets.returns);
  }}
  if (_globalImp2) {{
    imp2Rets = computePortfolioReturnsQR(_globalImp2.w);
    cumImp2  = toCum(imp2Rets.returns);
  }}

  const dates  = allDates.slice(sIdx);
  const base0  = v => v.slice(sIdx).map(x => x / v[sIdx] * 100);
  const pCurr  = base0(cumCurr);
  const pImp1  = cumImp1 ? base0(cumImp1) : null;
  const pImp2  = cumImp2 ? base0(cumImp2) : null;

  // ── 기간 수익률 계산 ─────────────────────────
  function periodRet(cum, dts, months) {{
    const n = cum.length - 1;
    const tgt = new Date(dts[n]); tgt.setMonth(tgt.getMonth() - months);
    const ts  = tgt.toISOString().substring(0, 7);
    let idx = -1;
    for (let i = n; i >= 0; i--) {{ if (dts[i] <= ts) {{ idx = i; break; }} }}
    if (idx < 0 || idx >= n) return null;
    return (cum[n] / cum[idx] - 1) * 100;
  }}
  const PERIODS = [['1M',1],['3M',3],['6M',6],['1Y',12],['3Y',36],['5Y',60],['10Y',120]];

  // ── 성과 지표 계산 ────────────────────────────
  function perfMetrics(rets, cumArr) {{
    const n = rets.length;
    if (n < 12) return null;
    const annRet = (Math.pow(cumArr[n-1]/cumArr[0], 12/n) - 1) * 100;
    const mean   = rets.reduce((a,b)=>a+b,0)/n;
    const vol    = Math.sqrt(rets.reduce((a,b)=>a+(b-mean)**2,0)/(n-1)*12)*100;
    const sharpe = vol > 0 ? annRet/vol : 0;
    let peak = cumArr[0], mdd = 0;
    for (const v of cumArr) {{
      if (v > peak) peak = v;
      const dd = (v-peak)/peak*100;
      if (dd < mdd) mdd = dd;
    }}
    return {{ annRet, vol, sharpe, mdd }};
  }}

  const mCurr = perfMetrics(portCurr.returns.slice(sIdx), pCurr);
  const mImp1 = imp1Rets ? perfMetrics(imp1Rets.returns.slice(sIdx), pImp1) : null;
  const mImp2 = imp2Rets ? perfMetrics(imp2Rets.returns.slice(sIdx), pImp2) : null;

  // ── 누적 수익률 차트 ──────────────────────────
  const traces = [{{
    x: dates, y: pCurr, name: '현재 포트',
    line: {{color:'#e74c3c', width:2}}, mode:'lines'
  }}];
  if (pImp1) traces.push({{ x:dates, y:pImp1, name:'① 수익률 유지·변동성↓', line:{{color:'#2ecc71',width:2,dash:'dot'}}, mode:'lines' }});
  if (pImp2) traces.push({{ x:dates, y:pImp2, name:'② 변동성 유지·수익률↑', line:{{color:'#3498db',width:2,dash:'dot'}}, mode:'lines' }});

  const cumId = 'imp-cum-chart';
  sec.style.display = 'block';
  sec.innerHTML = `
<div class="content">
  <div class="section">
    <h2 class="section-title">📊 개선안 백테스트 비교 <span style="font-size:12px;color:rgba(255,255,255,0.4);font-weight:normal;">2010~ 기준 100 시작 · 분기 리밸런싱</span></h2>

    <div id="${{cumId}}" style="width:100%;height:320px;"></div>

    <!-- 기간 수익률 + 성과 지표 표 -->
    <div style="overflow-x:auto;margin-top:20px;">
    <table style="width:100%;border-collapse:collapse;font-size:12px;">
      <thead>
        <tr>
          <th style="padding:8px 12px;border-bottom:2px solid #2c3e50;text-align:left;color:rgba(255,255,255,0.6);">구분</th>
          ${{PERIODS.map(([l])=>`<th style="padding:8px 10px;border-bottom:2px solid #2c3e50;text-align:right;color:rgba(255,255,255,0.6);">${{l}}</th>`).join('')}}
          <th style="padding:8px 12px;border-bottom:2px solid #2c3e50;text-align:right;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.04);">연환산수익률</th>
          <th style="padding:8px 12px;border-bottom:2px solid #2c3e50;text-align:right;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.04);">연환산변동성</th>
          <th style="padding:8px 12px;border-bottom:2px solid #2c3e50;text-align:right;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.04);">샤프</th>
          <th style="padding:8px 12px;border-bottom:2px solid #2c3e50;text-align:right;color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.04);">MDD</th>
        </tr>
      </thead>
      <tbody>
        ${{[
          ['현재 포트', '#e74c3c', pCurr, portCurr.returns.slice(sIdx), mCurr],
          pImp1 ? ['개선안 1 (변동성↓)', '#2ecc71', pImp1, imp1Rets.returns.slice(sIdx), mImp1] : null,
          pImp2 ? ['개선안 2 (수익률↑)', '#3498db', pImp2, imp2Rets.returns.slice(sIdx), mImp2] : null,
        ].filter(Boolean).map(([label, color, cum, rets, m]) => {{
          const pCells = PERIODS.map(([,mo]) => {{
            const v = periodRet(cum, dates, mo);
            if (v===null) return `<td style="padding:7px 10px;text-align:right;color:#555;border-bottom:1px solid rgba(255,255,255,0.06);">-</td>`;
            const c = v>=0?'#2ecc71':'#e74c3c';
            return `<td style="padding:7px 10px;text-align:right;color:${{c}};font-weight:bold;border-bottom:1px solid rgba(255,255,255,0.06);">${{v>=0?'+':''}}${{v.toFixed(1)}}%</td>`;
          }}).join('');
          const mCells = m ? [
            `${{m.annRet.toFixed(1)}}%`,`${{m.vol.toFixed(1)}}%`,`${{m.sharpe.toFixed(2)}}`,`${{m.mdd.toFixed(1)}}%`
          ].map(v=>`<td style="padding:7px 12px;text-align:right;color:white;font-weight:bold;border-bottom:1px solid rgba(255,255,255,0.06);background:rgba(255,255,255,0.04);">${{v}}</td>`).join('')
          : '<td colspan="4" style="text-align:center;color:#555;">-</td>';
          return `<tr>
            <td style="padding:7px 12px;font-weight:bold;color:${{color}};border-bottom:1px solid rgba(255,255,255,0.06);">${{label}}</td>
            ${{pCells}}${{mCells}}
          </tr>`;
        }}).join('')}}
      </tbody>
    </table>
    </div>

    <!-- 개선 효과 비교 카드 -->
    ${{(mImp1 || mImp2) ? `
    <div style="margin-top:28px;">
      <div style="font-size:13px;color:rgba(255,255,255,0.5);margin-bottom:12px;">📈 현재 포트 대비 개선 효과</div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:12px;">
        ${{[
          ['연환산 수익률', 'annRet', '%', false],
          ['연환산 변동성', 'vol',    '%', true],
          ['샤프 비율',    'sharpe', '',  false],
          ['MDD',         'mdd',    '%', false],  // MDD: 값이 0에 가까울수록(덜 음수) 개선
        ].map(([title, key, unit, lowerBetter]) => {{
          function deltaBar(imp, mC, label) {{
            if (!imp || !mC) return '';
            const delta = imp[key] - mC[key];
            // MDD는 음수 값이므로 delta > 0 이면 덜 음수(개선), delta < 0 이면 더 음수(악화)
            // 일반 지표: lowerBetter=true → delta<0 이 개선
            const good  = lowerBetter ? delta < 0 : delta > 0;
            const pct   = mC[key] !== 0 ? Math.abs(delta/mC[key]*100) : 0;
            const color = good ? '#2ecc71' : '#e74c3c';
            const sign  = delta > 0 ? '+' : '';
            const barW  = Math.min(pct * 2, 100);
            return `
              <div style="margin-top:6px;font-size:11px;color:rgba(255,255,255,0.5);">
                ${{label}} ${{sign}}${{delta.toFixed(2)}}${{unit}}
                <span style="color:${{color}};margin-left:4px;">(${{good?'▲개선':'▼악화'}})</span>
              </div>
              <div style="background:rgba(255,255,255,0.08);border-radius:3px;height:5px;margin-top:3px;">
                <div style="width:${{barW}}%;height:100%;background:${{color}};border-radius:3px;transition:width 0.6s;"></div>
              </div>`;
          }}
          return `
          <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:14px 16px;">
            <div style="font-size:11px;color:rgba(255,255,255,0.45);margin-bottom:4px;">${{title}}</div>
            <div style="font-size:18px;font-weight:bold;color:white;">${{mCurr ? mCurr[key].toFixed(key==='sharpe'?2:1)+unit : '-'}}</div>
            ${{deltaBar(mImp1, mCurr, '개선안 1')}}
            ${{deltaBar(mImp2, mCurr, '개선안 2')}}
          </div>`;
        }}).join('')}}
      </div>
    </div>` : ''}}

  </div>
</div>`;

  Plotly.newPlot(cumId, traces, {{
    template:'plotly_dark', paper_bgcolor:'#161622', plot_bgcolor:'#161622',
    margin:{{l:50,r:20,t:20,b:40}},
    xaxis:{{showgrid:true, gridcolor:'#1e2d3d', tickfont:{{color:'rgba(255,255,255,0.7)'}}}},
    yaxis:{{title:{{text:'누적 수익률 (100 시작)', font:{{color:'rgba(255,255,255,0.7)'}}}},
            showgrid:true, gridcolor:'#1e2d3d', tickfont:{{color:'rgba(255,255,255,0.7)'}}}},
    legend:{{orientation:'h', y:-0.18, x:0.5, xanchor:'center', font:{{color:'rgba(255,255,255,0.8)',size:11}}}},
    font:{{family:'Malgun Gothic'}}, dragmode:'pan',
  }}, {{responsive:true, displayModeBar:false, scrollZoom:true}});
}}

// ── 반응형 리사이즈 ────────────────────────────
(function() {{
  const chartIds = ['chart-cum','chart-yr','chart-dd','chart-pie'];
  let resizeTimer;
  window.addEventListener('resize', function() {{
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {{
      chartIds.forEach(function(id) {{
        const el = document.getElementById(id);
        if (el && el.data && el.data.length > 0) {{
          Plotly.relayout(id, {{autosize:true}});
        }}
      }});
    }}, 150);
  }});
}})();

// ── 결과 저장 (현재 페이지 HTML 전체 저장) ────────
function saveSimulation() {{
  const now      = new Date();
  const dateStr  = now.toISOString().slice(0, 10);
  const timeStr  = now.toTimeString().slice(0, 8).replace(/:/g, '-');
  const filename = `포트폴리오_시뮬레이션_${{dateStr}}_${{timeStr}}.html`;

  const html = '<!DOCTYPE html>\\n' + document.documentElement.outerHTML;
  const blob = new Blob([html], {{type: 'text/html; charset=utf-8'}});
  const url  = URL.createObjectURL(blob);

  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}}

