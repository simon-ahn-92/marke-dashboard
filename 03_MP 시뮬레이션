def load_all_prices() -> pd.DataFrame:
    """
    국면판단_원데이터.xlsx에서 ETF 가격 통합 로드
      일간데이터 : 스타일 ETF (QQQ, VTV, XLV 등)
      현금성ETF   : SHV, BIL
      테마ETF     : SPY, SOXX 등 위성 ETF
    """
    xl = pd.ExcelFile(FRED_PATH)

    # 스타일 ETF + 벤치마크(AGG) — 일간데이터 시트
    daily = pd.read_excel(xl, sheet_name="일간데이터",
                          index_col=0, parse_dates=True).sort_index()
    style_tickers = [t for etfs in STYLE_ETFS.values() for t, _ in etfs]
    bench_tickers = ["AGG"]   # 60/40 벤치마크용 (종합채 스타일에도 포함)
    want_cols = list(dict.fromkeys(style_tickers + bench_tickers))  # 중복 제거
    style_cols = [c for c in want_cols if c in daily.columns]
    df = daily[style_cols].dropna(how="all")

    # 현금성 ETF
    if "현금성ETF" in xl.sheet_names:
        cash_df = pd.read_excel(xl, sheet_name="현금성ETF",
                                index_col=0, parse_dates=True).sort_index()
        df = pd.concat([df, cash_df], axis=1)

    # 테마 ETF
    if "테마ETF" in xl.sheet_names:
        theme_df = pd.read_excel(xl, sheet_name="테마ETF",
                                 index_col=0, parse_dates=True).sort_index()
        df = pd.concat([df, theme_df], axis=1)

    df = df.loc[:, ~df.columns.duplicated(keep="last")]
    print(f"  Excel 로드: {len(df.columns)}개 ETF "
          f"({df.index[0].date()} ~ {df.index[-1].date()})")
    return df.sort_index()


def compute_monthly_returns(price_df: pd.DataFrame) -> pd.DataFrame:
    monthly = price_df.resample("ME").last()
    return monthly.pct_change().dropna(how="all")


def build_returns_json(monthly_ret: pd.DataFrame) -> str:
    """월별 수익률 → JavaScript 임베드용 JSON"""
    ret = monthly_ret.copy()
    ret.index = ret.index.to_period("M").to_timestamp("M")
    dates = [d.strftime("%Y-%m-%d") for d in ret.index]
    returns = {}
    for col in ret.columns:
        vals = ret[col].tolist()
        returns[col] = [round(v, 6) if not np.isnan(v) else None for v in vals]
    return json.dumps({"dates": dates, "returns": returns}, ensure_ascii=False)


# ═══════════════════════════════════════════════
# DTW 최적 비중 계산 (시각화_05 로직 재사용)
# ═══════════════════════════════════════════════
def _max_sharpe(ret_df: pd.DataFrame,
                per_bounds: list[tuple] | None = None) -> tuple[np.ndarray, float]:
    n = ret_df.shape[1]
    ret_arr = ret_df.fillna(0).values

    def neg_sharpe(w):
        port = ret_arr @ w
        mean = port.mean() * 12
        std  = port.std() * np.sqrt(12)
        return -(mean / std) if std > 1e-8 else 0.0

    constraints = [{"type": "eq", "fun": lambda w: w.sum() - 1}]
    bounds = per_bounds if per_bounds else [(0.05, 0.65)] * n
    best_w, best_sh = np.ones(n) / n, -np.inf
    np.random.seed(42)
    for _ in range(12):
        x0 = np.clip(np.random.dirichlet(np.ones(n)),
                     [b[0] for b in bounds], [b[1] for b in bounds])
        x0 /= x0.sum()
        try:
            res = sp_minimize(neg_sharpe, x0, method="SLSQP",
                              bounds=bounds, constraints=constraints,
                              options={"maxiter": 500, "ftol": 1e-9})
            if res.success and -res.fun > best_sh:
                best_sh = -res.fun
                best_w  = res.x
        except Exception:
            pass
    best_w = np.where(best_w < 0.01, 0, best_w)
    s = best_w.sum()
    if s > 0: best_w /= s
    return best_w, best_sh


def dtw_load_macro() -> pd.DataFrame:
    xl = pd.ExcelFile(FRED_PATH)
    daily   = pd.read_excel(xl, sheet_name="일간데이터",
                            index_col=0, parse_dates=True).sort_index()
    monthly = pd.read_excel(xl, sheet_name="월간데이터",
                            index_col=0, parse_dates=True).sort_index()
    monthly_d = monthly.reindex(daily.index, method="ffill")
    df = pd.concat([daily, monthly_d], axis=1)
    df = df[~df.index.duplicated(keep="first")].sort_index()
    if "금현물가격(USD/oz)" in df.columns and "금현물가격" not in df.columns:
        df = df.rename(columns={"금현물가격(USD/oz)": "금현물가격"})
    return df.resample("ME").last()


def dtw_build_scores(macro: pd.DataFrame) -> pd.DataFrame:
    cols = [c for c in DTW_INDICATORS if c in macro.columns]
    result = {}
    for col in cols:
        s = macro[col].dropna()
        diffs = s.diff(1)
        pcts = []
        for t in range(len(diffs)):
            val = diffs.iloc[t]
            if pd.isna(val):
                pcts.append(np.nan)
                continue
            hist = diffs.iloc[max(0, t - DTW_PCTILE_WIN):t].dropna()
            pcts.append(sp_stats.percentileofscore(hist, val, kind="rank") / 100
                        if len(hist) >= 6 else 0.5)
        result[col] = pd.Series(pcts, index=diffs.index)
    return pd.DataFrame(result).dropna(how="all")


def dtw_find_similar(scores: pd.DataFrame) -> list[tuple]:
    infer_start = pd.Timestamp(INFER_START_DATE)
    valid       = scores.dropna(how="all").index

    # 추론 구간(현재): INFER_START_DATE 이후 — 비교 기준 윈도우
    infer_idx = valid[valid >= infer_start]
    # 학습 구간: INFER_START_DATE 이전 — 유사 구간 후보
    train_idx = valid[valid < infer_start]

    if len(infer_idx) < 1 or len(train_idx) < DTW_MIN_HISTORY:
        return []

    cur_window  = len(infer_idx)          # 추론 기간 길이 (현재 4개월)
    current_win = scores.loc[infer_idx]
    cols = [c for c in current_win.columns
            if current_win[c].notna().sum() >= max(1, cur_window // 2)]
    if not cols:
        return []
    cur_arr = current_win[cols].fillna(0.5).values.T

    results = []
    for i in range(cur_window, len(train_idx)):
        end_d    = train_idx[i]
        past_win = scores.loc[train_idx[i - cur_window: i], cols].fillna(0.5)
        if len(past_win) < max(1, cur_window // 2):
            continue
        past_arr = past_win.values.T
        dist_sum = sum(
            dtw_lib.distance(cur_arr[ci].astype(np.double),
                             past_arr[ci].astype(np.double))
            for ci in range(len(cols))
        )
        sim = max(0.0, 100.0 * (1.0 - dist_sum / (len(cols) * cur_window)))
        results.append((end_d, sim))

    results.sort(key=lambda x: -x[1])
    selected = []
    for end_d, sim in results:
        if not any(abs((end_d - s[0]).days) < cur_window * 30 for s in selected):
            selected.append((end_d, sim))
        if len(selected) >= DTW_TOP_N:
            break
    return selected


def compute_dtw_optimal(monthly_ret: pd.DataFrame,
                        similar: list[tuple],
                        fwd: int = 12) -> tuple[dict, float, list]:
    """유사 구간 +fwd개월 수익률 기반 최대 샤프 스타일 배분 (OPTIMAL_STYLES만 사용)"""
    if not similar:
        return {}, np.nan, similar

    monthly_ret_idx = monthly_ret.index.to_period("M")
    frames = []
    for end_d, _sim in similar:
        end_p    = end_d.to_period("M")
        target_p = end_p + fwd
        mask = (monthly_ret_idx > end_p) & (monthly_ret_idx <= target_p)
        sub  = monthly_ret.loc[mask]
        if sub.empty:
            continue
        style_cols = {}
        for style, etfs in STYLE_ETFS.items():
            if style not in OPTIMAL_STYLES:
                continue
            tickers = [t for t, _ in etfs if t in sub.columns]
            if tickers:
                grp = sub[tickers].mean(axis=1).dropna()
                if not grp.empty:
                    style_cols[style] = grp
        if style_cols:
            frames.append(pd.DataFrame(style_cols))

    if not frames:
        return {}, np.nan, similar

    combined = pd.concat(frames, ignore_index=True).dropna(how="all").fillna(0)
    if len(combined) < 6 or combined.shape[1] < 2:
        return {}, np.nan, similar

    styles = list(combined.columns)
    # 현금은 30% 상한 적용 (과도한 현금 쏠림 방지)
    per_bounds = [(0.05, 0.30) if s == "현금" else (0.05, 0.65) for s in styles]
    weights, sharpe = _max_sharpe(combined, per_bounds=per_bounds)
    opt_w = {s: round(w * 100, 1) for s, w in zip(styles, weights) if w >= 0.01}
    return opt_w, round(sharpe, 2), similar


def compute_all_dtw_allocs(monthly_ret: pd.DataFrame,
                           similar: list[tuple],
                           fwd: int = 12) -> tuple[dict, float]:
    """
    DTW 유사 구간 기반 4가지 배분 방식 계산
    Returns: (all_allocs_dict, sharpe)
      all_allocs_dict 키: "Sharpe최적", "비례배분", "집중형", "균등혼합", "_sharpe"
    """
    if not similar:
        return {}, np.nan

    monthly_ret_idx = monthly_ret.index.to_period("M")
    frames = []
    for end_d, _sim in similar:
        end_p    = end_d.to_period("M")
        target_p = end_p + fwd
        mask = (monthly_ret_idx > end_p) & (monthly_ret_idx <= target_p)
        sub  = monthly_ret.loc[mask]
        if sub.empty:
            continue
        style_cols = {}
        for style, etfs in STYLE_ETFS.items():
            if style not in OPTIMAL_STYLES:
                continue
            tickers = [t for t, _ in etfs if t in sub.columns]
            if tickers:
                grp = sub[tickers].mean(axis=1).dropna()
                if not grp.empty:
                    style_cols[style] = grp
        if style_cols:
            frames.append(pd.DataFrame(style_cols))

    if not frames:
        return {}, np.nan

    combined = pd.concat(frames, ignore_index=True).dropna(how="all").fillna(0)
    if len(combined) < 6 or combined.shape[1] < 2:
        return {}, np.nan

    styles = list(combined.columns)

    # Sharpe최적 — 종합채 최대 15% 제약
    per_bounds = []
    for s in styles:
        if s == "현금":
            per_bounds.append((0.05, 0.30))
        elif s == "종합채":
            per_bounds.append((0.0, 0.10))
        else:
            per_bounds.append((0.05, 0.65))
    weights, sharpe = _max_sharpe(combined, per_bounds=per_bounds)
    sharpe_w = {s: round(w * 100, 1) for s, w in zip(styles, weights) if w >= 0.01}

    # 스타일별 평균 월수익률 기반 점수 (음수 보정 후 양수화)
    avg_ret  = combined.mean()
    scores   = (avg_ret - avg_ret.min() + 0.001)

    # 비례배분: 점수 비례
    prop   = scores / scores.sum()
    prop_w = {s: round(float(v) * 100, 1) for s, v in prop.items()}

    # 집중형: 점수 제곱 비례 (상위 집중)
    sq     = scores ** 2
    conc   = sq / sq.sum()
    conc_w = {s: round(float(v) * 100, 1) for s, v in conc.items()}

    # 균등혼합: 성장주·대체자산·방어주·종합채 고정 25%
    equal_w = {"성장주": 25.0, "대체자산": 25.0, "방어주": 25.0, "종합채": 25.0}

    return {
        "Sharpe최적": sharpe_w,
        "비례배분":   prop_w,
        "집중형":     conc_w,
        "균등혼합":   equal_w,
        "_sharpe":    round(sharpe, 2),
    }, round(sharpe, 2)


def compute_all_regime_allocs(monthly_ret: pd.DataFrame,
                              regime_series: pd.Series,
                              current_regime: str) -> tuple[dict, float]:
    """
    국면 역사 기반 4가지 배분 계산 (현재 국면 구간 전체 실적 기반)
    Returns (all_allocs_dict, sharpe)
    """
    regime_s = regime_series.copy()
    regime_s.index = regime_s.index.to_period("M").to_timestamp("M")
    regime_s = regime_s[~regime_s.index.duplicated(keep="last")]

    ret = monthly_ret.copy()
    ret.index = ret.index.to_period("M").to_timestamp("M")

    combined = ret.copy()
    combined["__regime__"] = regime_s
    curr_sub = combined[combined["__regime__"] == current_regime].drop(columns=["__regime__"])
    if len(curr_sub) < 3:
        return {}, np.nan

    style_rets = {}
    for style, etfs in STYLE_ETFS.items():
        if style not in OPTIMAL_STYLES:
            continue
        tickers = [t for t, _ in etfs if t in curr_sub.columns]
        if tickers:
            grp = curr_sub[tickers].mean(axis=1).dropna()
            if len(grp) >= 3:
                style_rets[style] = grp

    if len(style_rets) < 2:
        return {}, np.nan

    ret_mat = pd.DataFrame(style_rets).dropna()
    styles  = list(ret_mat.columns)

    # Sharpe최적 — 종합채 최대 15% 제약
    per_bounds = []
    for s in styles:
        if s == "현금":
            per_bounds.append((0.05, 0.30))
        elif s == "종합채":
            per_bounds.append((0.0, 0.10))
        else:
            per_bounds.append((0.05, 0.65))
    weights, sharpe = _max_sharpe(ret_mat, per_bounds=per_bounds)
    sharpe_w = {s: round(w * 100, 1) for s, w in zip(styles, weights) if w >= 0.01}

    # 평균 수익률 기반 점수
    avg_ret = ret_mat.mean()
    scores  = avg_ret - avg_ret.min() + 0.001

    prop   = scores / scores.sum()
    prop_w = {s: round(float(v) * 100, 1) for s, v in prop.items()}

    sq     = scores ** 2
    conc   = sq / sq.sum()
    conc_w = {s: round(float(v) * 100, 1) for s, v in conc.items()}

    # 균등혼합: 성장주·대체자산·방어주·종합채 고정 25%
    equal_w = {"성장주": 25.0, "대체자산": 25.0, "방어주": 25.0, "종합채": 25.0}

    return {
        "Sharpe최적": sharpe_w,
        "비례배분":   prop_w,
        "집중형":     conc_w,
        "균등혼합":   equal_w,
        "_sharpe":    round(sharpe, 2),
    }, round(sharpe, 2)


