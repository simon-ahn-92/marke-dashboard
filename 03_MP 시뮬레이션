function buildShockImpact(sp500Pct, rateBp, usdPct, oilPct) {{
  if (!_lastWeights) return null;
  const totalW = Object.values(_lastWeights).reduce((a, b) => a + b, 0);
  function calcImpact(w) {{
    let impact = 0;
    for (const [etf, wt] of Object.entries(w)) {{
      const sens = ETF_SENS[etf];
      if (!sens) continue;
      const norm = wt / totalW;
      impact += norm * (
        sens.sp   * sp500Pct / 100 +
        sens.rate * rateBp   / 100 +
        sens.usd  * usdPct   / 10  +
        sens.oil  * oilPct   / 10
      );
    }}
    return (impact * 100).toFixed(2);
  }}
  return {{
    port: calcImpact(_lastWeights),
    spy:  calcImpact({{SPY:1}}),
    bm:   calcImpact({{SPY:0.6, AGG:0.4}}),
  }};
}}

