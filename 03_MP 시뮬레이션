function crisisStats(dates, cumArr, sd, ed) {{
  const si = dates.findIndex(d => d >= sd);
  const ei = dates.findIndex(d => d >= ed);
  if (si < 0 || ei < 0 || ei <= si) return {{ret:null, mdd:null}};
  const ret = (cumArr[ei] / cumArr[si] - 1) * 100;
  let peak = cumArr[si], mdd = 0;
  for (let i = si; i <= ei; i++) {{
    if (cumArr[i] > peak) peak = cumArr[i];
    const dd = (cumArr[i] - peak) / peak * 100;
    if (dd < mdd) mdd = dd;
  }}
  return {{ret: ret.toFixed(1), mdd: mdd.toFixed(1)}};
}}

