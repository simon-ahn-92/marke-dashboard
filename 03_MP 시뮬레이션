// 랜덤 Dirichlet 비중 (균등 심플렉스 샘플링)
function _randDirichlet(etfs, rng) {{
  const vals = etfs.map(() => -Math.log(rng() + 1e-10));
  const sum  = vals.reduce((a, b) => a + b, 0);
  const w = {{}};
  etfs.forEach((t, i) => {{ w[t] = vals[i] / sum; }});
  return w;
}}

// 단순 포트폴리오 통계 (가중합 수익률 기반, Rf=0)
function _simPortStats(normW, etfRets, n) {{
  const etfs = Object.keys(normW);
  const portRet = [];
  for (let i = 0; i < n; i++) {{
    let r = 0;
    for (const t of etfs) {{
      const v = etfRets[t]?.[i];
      if (v !== null && v !== undefined && !isNaN(v)) r += normW[t] * v;
    }}
    portRet.push(r);
  }}
  const mean  = portRet.reduce((a, b) => a + b, 0) / n;
  const std   = Math.sqrt(portRet.map(x => (x - mean) ** 2).reduce((a, b) => a + b, 0) / (n - 1));
  const mu    = mean * 12 * 100;
  const sigma = std * Math.sqrt(12) * 100;
  const sharpe = sigma > 0 ? mu / sigma : 0;
  return {{mu, sigma, sharpe}};
}}

