// ── ETF 최종 비중 계산 ───────────────────────────
function buildEtfWeights() {{
  const coreRatio = getCoreRatio();
  const sw        = getCurrentStyleWeights();
  const selected  = getSelectedThemeEtfs();
  const N         = selected.length;
  const coreShare = N > 0 ? coreRatio        : 1.00;
  const satShare  = N > 0 ? (1 - coreRatio)  : 0.00;
  const weights   = {{}};

  // Core
  for (const [style, stylePct] of Object.entries(sw)) {{
    const subEtfs = BASE_ETF_SUB[style];
    if (!subEtfs) continue;
    for (const [etf, subW] of Object.entries(subEtfs)) {{
      weights[etf] = (weights[etf] || 0) + (stylePct/100) * coreShare * subW;
    }}
  }}

  // Satellite
  if (N > 0) {{
    const perEtf = satShare / N;
    for (const etf of selected) {{
      weights[etf] = (weights[etf] || 0) + perEtf;
    }}
  }}

  return weights;
}}

// ── 포트폴리오 수익률 계산 (분기별 리밸런싱) ────────
function computePortfolioReturns(weights) {{
  return computePortfolioReturnsQR(weights);
}}

function computePortfolioReturnsQR(weights) {{
  const dates   = MONTHLY_DATA.dates;
  const retData = MONTHLY_DATA.returns;
  const etfs    = Object.keys(weights).filter(t => t in retData);
  const totalW  = etfs.reduce((s, t) => s + (weights[t] || 0), 0);
  if (!etfs.length || totalW <= 0) return {{ dates, returns: dates.map(() => 0) }};

  // 정규화된 목표 비중
  const normW = {{}};
  for (const t of etfs) normW[t] = (weights[t] || 0) / totalW;

  // 포지션 초기화 (1원 기준)
  const pos = {{}};
  for (const t of etfs) pos[t] = normW[t];

  const portRet = [];
  for (let i = 0; i < dates.length; i++) {{
    const monthNum = new Date(dates[i]).getMonth(); // 0=Jan,3=Apr,6=Jul,9=Oct

    // 분기 첫 달(1/4/7/10월) 또는 첫 데이터: 목표 비중으로 리밸런싱
    if (i === 0 || monthNum % 3 === 0) {{
      const totV = etfs.reduce((s, t) => s + pos[t], 0);
      for (const t of etfs) pos[t] = totV * normW[t];
    }}

    const totBefore = etfs.reduce((s, t) => s + pos[t], 0);
    for (const t of etfs) {{
      const v = retData[t][i];
      if (v !== null && !isNaN(v)) pos[t] *= (1 + v);
    }}
    const totAfter = etfs.reduce((s, t) => s + pos[t], 0);
    portRet.push(totBefore > 0 ? (totAfter / totBefore - 1) : 0);
  }}
  return {{ dates, returns: portRet }};
}}

function computeCumulative(returns, base=100) {{
  let cum = base, res = [];
  for (const r of returns) {{ cum *= (1+r); res.push(parseFloat(cum.toFixed(4))); }}
  return res;
}}

function computeMetrics(dates, returns) {{
  // 2010년 이후만
  const startIdx = dates.findIndex(d => d >= '2010-01-01');
  const r = returns.slice(startIdx >= 0 ? startIdx : 0);
  const n = r.length;
  if (n < 12) return null;
  const cagr  = (Math.pow(r.reduce((a,b)=>a*(1+b),1), 12/n) - 1) * 100;
  const mean  = r.reduce((a,b)=>a+b,0) / n;
  const std   = Math.sqrt(r.map(x=>(x-mean)**2).reduce((a,b)=>a+b,0)/(n-1));
  const sharpe= std > 0 ? (mean * 12) / (std * Math.sqrt(12)) : 0;
  let peak=1, mdd=0, cum=1;
  for (const ret of r) {{
    cum *= (1+ret);
    if (cum > peak) peak = cum;
    const dd = (peak-cum)/peak;
    if (dd > mdd) mdd = dd;
  }}
  const yrMap = {{}};
  dates.slice(startIdx >= 0 ? startIdx : 0).forEach((d,i) => {{
    const yr = d.slice(0,4);
    if (!yrMap[yr]) yrMap[yr] = [];
    yrMap[yr].push(r[i]);
  }});
  const annualRet = Object.fromEntries(
    Object.entries(yrMap).map(([yr,rets]) => [yr, (rets.reduce((a,b)=>a*(1+b),1)-1)*100])
  );
  return {{ cagr, sharpe, mdd: mdd*100, vol: std*Math.sqrt(12)*100, annualRet }};
}}

// ── 시뮬레이션 실행 ──────────────────────────────
function runSimulation() {{
  const btn = document.getElementById('run-btn');
  btn.textContent = '⏳ 계산 중...';
  btn.disabled = true;

  setTimeout(() => {{
    try {{
      const weights = buildEtfWeights();
      _lastWeights = weights;

      // 포트폴리오
      const port    = computePortfolioReturns(weights);
      const portCum = computeCumulative(port.returns);
      const portM   = computeMetrics(port.dates, port.returns);
      const _si2010 = port.dates.findIndex(d => d >= '2010-01-01');
      _portRet2010  = port.returns.slice(_si2010 >= 0 ? _si2010 : 0);

      // 벤치마크: SPY
      const spyW    = {{ SPY: 1.0 }};
      const spyPort = computePortfolioReturns(spyW);
      const spyCum  = computeCumulative(spyPort.returns);
      const spyM    = computeMetrics(spyPort.dates, spyPort.returns);

      // 벤치마크: 60/40 (SPY 60% + AGG 40%)
      const bm6040  = computePortfolioReturns({{ SPY: 0.6, AGG: 0.4 }});
      const bm6040C = computeCumulative(bm6040.returns);
      const bm6040M = computeMetrics(bm6040.dates, bm6040.returns);

      renderSimulation(port.dates, portCum, spyCum, bm6040C,
                       portM, spyM, bm6040M, weights);
      renderPerformance(port.dates, portCum, spyCum, bm6040C,
                        portM, spyM, bm6040M);

      // Tab 2 이동 + 스크롤 상단 복귀
      document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
      document.getElementById('simulation').classList.add('active');
      document.getElementById('sim-tab-btn').classList.add('active');
      window.scrollTo({{top: 0, behavior: 'smooth'}});
      // 탭이 visible 된 직후 Plotly 강제 리사이즈 (hidden 상태로 렌더링된 차트 복구)
      setTimeout(() => {{
        CHART_IDS.forEach(cid => {{
          const el = document.getElementById(cid);
          if (el && el.data && el.data.length) Plotly.relayout(cid, {{autosize: true}});
        }});
      }}, 100);
    }} catch(e) {{
      alert('시뮬레이션 오류: ' + e.message);
      console.error(e);
    }}
    btn.textContent = '🚀 시뮬레이션 실행';
    btn.disabled = false;
  }}, 50);
}}

