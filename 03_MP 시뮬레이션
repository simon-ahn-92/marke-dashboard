      <tbody>
        ${{rows}}
        ${{summaryRow('현재', '#e74c3c', curr)}}
        ${{summaryRow('① 수익률 유지·변동성↓', '#2ecc71', imp1)}}
        ${{summaryRow('② 변동성 유지·수익률↑', '#3498db', imp2)}}
      </tbody>
    </table>
    ${{!imp1 && !imp2 ? '<p style="text-align:center;color:rgba(255,255,255,0.4);font-size:12px;margin-top:12px;">※ 현재 포트폴리오가 이미 효율적 프론티어에 근접해 있어 유의미한 개선안을 찾지 못했습니다.</p>' : ''}}`;

  // ── 파이차트 3개 ─────────────────────────────────
