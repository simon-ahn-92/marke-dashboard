      text:'', standoff:10,
    }});
  }}

  Plotly.newPlot('frontier-chart', traces, {{
    template:'plotly_dark', paper_bgcolor:'#111', plot_bgcolor:'#111',
    height:540, margin:{{l:65,r:30,t:60,b:110}},
