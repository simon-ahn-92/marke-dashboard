  // ─ 비중 비교 테이블
  const TH  = 'padding:7px 10px;font-size:11px;border-bottom:2px solid #2c3e50;color:white;font-weight:bold;text-align:right;white-space:nowrap;';
  const THL = 'padding:7px 10px;font-size:11px;border-bottom:2px solid #2c3e50;color:white;font-weight:bold;text-align:left;';
