def main():
    print("===== 포트폴리오_MP 시작 =====\n")

    print("[1/5] ETF 가격 로드...")
    price_df = load_all_prices()
    print(f"      총 {len(price_df.columns)}개 ETF | "
          f"{price_df.index[0].date()} ~ {price_df.index[-1].date()}")
    available_tickers = price_df.columns.tolist()

    print("[2/5] 월별 수익률 계산...")
    monthly_ret = compute_monthly_returns(price_df)
    returns_json = build_returns_json(monthly_ret)
    print(f"      {len(monthly_ret)}개월, JSON {len(returns_json)//1024}KB")

    print("[3/5] DTW 유사 구간 & 최적 비중 계산...")
    print(f"      추론 기간: {INFER_START_DATE} ~ (학습 구간: ~ {TRAIN_END_DATE})")
    macro_df = dtw_load_macro()
    scores_m = dtw_build_scores(macro_df)
    similar  = dtw_find_similar(scores_m)
    if similar:
        for i, (d, s) in enumerate(similar):
            print(f"      #{i+1}  {d.strftime('%Y-%m')}  유사도 {s:.1f}%")
    else:
        print("      유사 구간 없음 — 추론 기간 데이터 부족 가능성 확인 필요")
    all_allocs, sharpe = compute_all_dtw_allocs(monthly_ret, similar, fwd=12)
    if all_allocs:
        opt_w = all_allocs["Sharpe최적"]
        print(f"      최적 샤프: {sharpe:.2f}")
        for s, w in sorted(opt_w.items(), key=lambda x: -x[1]):
            print(f"        {s}: {w:.1f}%")
    else:
        print("      최적 비중 산출 불가 → 기본값 사용")
        opt_w = {"현금": 35.0, "방어주": 30.0, "가치주": 20.0, "성장주": 15.0}
        sharpe = 0.80
        all_allocs = {"Sharpe최적": opt_w, "_sharpe": sharpe}

    print("[4/5] 국면 정보 로드...")
    df_reg = pd.read_excel(RESULT_PATH, sheet_name="국면_시계열",
                           index_col=0, parse_dates=True).sort_index()
    regime_series   = df_reg["국면"].dropna()
    current_regime  = regime_series.iloc[-1]
    as_of           = regime_series.index[-1].strftime("%Y년 %m월")
    print(f"      현재 국면: {current_regime} ({as_of})")

    print("      국면 역사 기반 배분 계산...")
    regime_allocs, regime_sharpe = compute_all_regime_allocs(
        monthly_ret, regime_series, current_regime)
    if regime_allocs:
        print(f"      국면 역사 Sharpe: {regime_sharpe:.2f}")
    else:
        print("      국면 역사 배분 산출 불가 → DTW 기반으로 대체")
        regime_allocs = all_allocs

    print("[5/5] HTML 생성...")
    html = build_html(
        dtw_weights       = opt_w,
        sharpe_dtw        = sharpe,
        similar           = similar,
        returns_json      = returns_json,
        current_regime    = current_regime,
        as_of             = as_of,
        available_tickers = available_tickers,
        all_allocs        = all_allocs,
        regime_allocs     = regime_allocs,
    )
    OUTPUT_PATH.write_text(html, encoding="utf-8")
    print(f"\n[완료] {OUTPUT_PATH}")


if __name__ == "__main__":
    main()
