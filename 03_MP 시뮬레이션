    }}
  }}

  // 음수 제거 + 정규화 (합계 100% 보장)
  let total = 0;
  for (const k in base) {{ base[k] = Math.max(0, base[k]); total += base[k]; }}
  if (total > 0) for (const k in base) base[k] = base[k] / total * 100;

  return base;
}}

