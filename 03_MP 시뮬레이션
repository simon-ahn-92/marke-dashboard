      hovertemplate:'σ: %{{x:.2f}}%<br>μ: %{{y:.2f}}%<extra>효율적 프론티어</extra>',
    }},
    {{
      type:'scatter', mode:'markers+text', name:'현재 포트폴리오',
      x:[parseFloat(curr.sigma.toFixed(3))], y:[parseFloat(curr.mu.toFixed(3))],
      marker:{{size:16, color:'#e74c3c', symbol:'star', line:{{color:'white',width:1}}}},
