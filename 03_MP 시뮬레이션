function _doImprovedAnalysis(el) {{
  // 1. 2010년 이후 ETF 수익률 배열 추출
  const dates  = MONTHLY_DATA.dates;
  const si     = dates.findIndex(d => d >= '2010-01-01');
  const slice  = si >= 0 ? si : 0;
  const retData = MONTHLY_DATA.returns;
  const n      = dates.length - slice;
  const etfRets = {{}};
  for (const [t, arr] of Object.entries(retData)) etfRets[t] = arr.slice(slice);

  // 2. 현재 ETF 목록 및 정규화 비중
  const currEtfs  = Object.keys(_lastWeights).filter(t => t in etfRets);
  const currTotal = currEtfs.reduce((s, t) => s + _lastWeights[t], 0);
  if (!currEtfs.length || currTotal <= 0) {{
    el.innerHTML = '<div style="color:#e74c3c;text-align:center;padding:20px;">현재 포트폴리오 데이터 없음</div>';
    return;
  }}
  const currNorm = {{}};
  for (const t of currEtfs) currNorm[t] = _lastWeights[t] / currTotal;

  // 3. 현재 포트폴리오 통계
  const curr = _simPortStats(currNorm, etfRets, n);

  // 4. Monte Carlo: 4,000개 랜덤 비중 조합
  const N_SIM = 4000;
  const rng = _seededRng(1234);
  const sim = [];
  for (let s = 0; s < N_SIM; s++) {{
    const w     = _randDirichlet(currEtfs, rng);
    const stats = _simPortStats(w, etfRets, n);
    if (stats) sim.push({{...stats, w}});
  }}

  // 5. 극단값 제거 (sigma 2~98 percentile, mu 1~99 percentile)
  const _sortedSig = sim.map(p => p.sigma).sort((a, b) => a - b);
  const _sortedMu  = sim.map(p => p.mu).sort((a, b) => a - b);
  const _p2  = _sortedSig[Math.floor(sim.length * 0.02)];
  const _p98 = _sortedSig[Math.floor(sim.length * 0.98)];
  const _m1  = _sortedMu[Math.floor(sim.length * 0.01)];
  const _m99 = _sortedMu[Math.floor(sim.length * 0.99)];
  const simVis = sim.filter(p => p.sigma >= _p2 && p.sigma <= _p98 && p.mu >= _m1 && p.mu <= _m99);

  // 효율적 프론티어 (필터된 범위에서 sigma 구간별 최고 mu)
  const sigMin  = _p2;
  const sigMax  = _p98;
  const bins    = 40;
  const step    = (sigMax - sigMin) / bins;
  const frontier = [];
  for (let i = 0; i < bins; i++) {{
    const lo = sigMin + i * step, hi = lo + step;
    const inBin = simVis.filter(p => p.sigma >= lo && p.sigma < hi);
    if (inBin.length) frontier.push(inBin.reduce((a, b) => a.mu > b.mu ? a : b));
  }}
  frontier.sort((a, b) => a.sigma - b.sigma);

  // 6. 개선 포트폴리오 탐색 — 반드시 효율적 투자기회선(frontier) 위의 점만 선택
  // ① 수익률 유지·변동성↓ — frontier 중 sigma < curr.sigma이고 mu가 curr.mu에 가장 근접한 점 (수평 좌이동)
  const cand1 = frontier
    .filter(p => p.sigma < curr.sigma - 0.05)
    .sort((a, b) => Math.abs(a.mu - curr.mu) - Math.abs(b.mu - curr.mu));
  const imp1 = cand1[0] || null;

  // ② 변동성 유지·수익률↑ — frontier 중 mu > curr.mu이고 sigma가 curr.sigma에 가장 근접한 점 (수직 상향)
  const cand2 = frontier
    .filter(p => p.mu > curr.mu + 0.05)
    .sort((a, b) => Math.abs(a.sigma - curr.sigma) - Math.abs(b.sigma - curr.sigma));
  const imp2 = cand2[0] || null;

  // 7. 렌더링
  el.innerHTML = `
    <div id="frontier-chart" style="margin-bottom:20px;"></div>
    <div id="frontier-table"></div>
    <div id="imp-pie-charts" style="display:flex;gap:12px;margin-top:20px;"></div>`;

  // ─ 차트 traces
  const colorVals = simVis.map(p => parseFloat(p.sharpe.toFixed(3)));
  const traces = [
    {{
      type:'scatter', mode:'markers', name:'시뮬레이션 포트폴리오',
      x: simVis.map(p => parseFloat(p.sigma.toFixed(3))),
      y: simVis.map(p => parseFloat(p.mu.toFixed(3))),
      marker: {{size:3, color:colorVals, colorscale:'Plasma', opacity:0.45,
               showscale:true,
               colorbar:{{title:{{text:'샤프', font:{{size:10}}}}, thickness:12, len:0.6,
                          tickfont:{{size:9, color:'rgba(255,255,255,0.7)'}}}}}},
      hoverinfo:'skip',
    }},
    {{
