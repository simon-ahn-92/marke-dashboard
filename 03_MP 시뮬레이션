let _perfDates = null, _perfPort = null, _perfSpy = null, _perfBm = null;
let _fullDates = null, _fullPort = null, _fullSpy = null, _fullBm = null; // 2010 이전 포함 전체
let _selPt1 = null;   // 기간 선택 첫 번째 클릭 날짜

// ── 트레일링 수익률 계산 ──────────────────────
function trailingReturn(cumArr, dates, months) {{
  if (!cumArr || !cumArr.length) return null;
  const lastDate = new Date(dates[dates.length - 1]);
  const cutoff   = new Date(lastDate);
  cutoff.setMonth(cutoff.getMonth() - months);
  let idx = -1;
  for (let i = dates.length - 1; i >= 0; i--) {{
    if (new Date(dates[i]) <= cutoff) {{ idx = i; break; }}
  }}
  if (idx < 0 || cumArr[idx] === 0) return null;
  return (cumArr[cumArr.length - 1] / cumArr[idx] - 1) * 100;
}}

// 두 날짜 사이 수익률
function returnBetween(cumArr, dates, d1, d2) {{
  const t1 = new Date(d1 < d2 ? d1 : d2).getTime();
  const t2 = new Date(d1 < d2 ? d2 : d1).getTime();
  let i1 = -1, i2 = -1;
  for (let i = 0; i < dates.length; i++) {{
    const t = new Date(dates[i]).getTime();
    if (i1 < 0 && t >= t1) i1 = i;
    if (t <= t2) i2 = i;
  }}
  if (i1 < 0 || i2 < 0 || i1 >= i2 || cumArr[i1] === 0) return null;
  return (cumArr[i2] / cumArr[i1] - 1) * 100;
}}

// ── 팝업 표시/숨김 ──────────────────────────────
function showPerfPopup(html, clientX, clientY) {{
  const p = document.getElementById('perf-popup');
  p.innerHTML = html;
  p.style.display = 'block';
  const pw = 240, ph = 120;
  const vw = window.innerWidth, vh = window.innerHeight;
  p.style.left = Math.min(clientX + 16, vw - pw - 8) + 'px';
  p.style.top  = Math.max(clientY - 20, 8) + 'px';
  if (clientY + ph > vh) p.style.top = Math.max(clientY - ph - 8, 8) + 'px';
}}
function hidePerfPopup() {{
  document.getElementById('perf-popup').style.display = 'none';
}}
document.addEventListener('keydown', e => {{ if (e.key === 'Escape') resetPerfSel(); }});
// 스크롤 시 팝업 숨기기 (capture:true 로 모든 스크롤 이벤트 캐치)
window.addEventListener('scroll', hidePerfPopup, true);

function resetPerfSel() {{
  _selPt1 = null;
  hidePerfPopup();
  const el = document.getElementById('perf-chart-cum');
  if (el && el.data) Plotly.relayout('perf-chart-cum', {{shapes: []}});
}}

// ── 기간 선택 클릭 핸들러 ─────────────────────
function attachPerfClick() {{
  const el = document.getElementById('perf-chart-cum');
  if (!el) return;
  el.on('plotly_click', function(evData) {{
    if (!evData.points.length) return;
    const xDate = evData.points[0].x;
    const mx = evData.event.clientX, my = evData.event.clientY;
    if (!_selPt1) {{
      _selPt1 = xDate;
      Plotly.relayout('perf-chart-cum', {{
        shapes: [{{type:'line',x0:xDate,x1:xDate,y0:0,y1:1,yref:'paper',
                  line:{{color:'#f1c40f',width:1.5,dash:'dot'}}}}]
      }});
      showPerfPopup(
        `<div style="color:#f1c40f;font-weight:bold;margin-bottom:6px;">📍 시작: ${{xDate.slice(0,7)}}</div>
         <div style="color:rgba(255,255,255,0.5);font-size:11px;">종료 시점을 클릭하세요<br>
         <span onclick="resetPerfSel()" style="cursor:pointer;color:#e74c3c;">✕ 초기화</span></div>`,
        mx, my
      );
    }} else {{
      const d1 = _selPt1, d2 = xDate;
      const rp  = returnBetween(_perfPort, _perfDates, d1, d2);
      const rs  = returnBetween(_perfSpy,  _perfDates, d1, d2);
      const rb  = returnBetween(_perfBm,   _perfDates, d1, d2);
      const fmt = v => v === null ? 'N/A' :
        `<span style="color:${{v>=0?'#2ecc71':'#e74c3c'}};font-weight:bold;">${{v>=0?'+':''}}${{v.toFixed(2)}}%</span>`;
      const sd = (d1<d2?d1:d2).slice(0,7), ed = (d1<d2?d2:d1).slice(0,7);
      Plotly.relayout('perf-chart-cum', {{
        shapes: [
          {{type:'line',x0:sd,x1:sd,y0:0,y1:1,yref:'paper',line:{{color:'#f1c40f',width:1.5,dash:'dot'}}}},
          {{type:'line',x0:ed,x1:ed,y0:0,y1:1,yref:'paper',line:{{color:'#e74c3c',width:1.5,dash:'dot'}}}},
          {{type:'rect',x0:sd,x1:ed,y0:0,y1:1,yref:'paper',
            fillcolor:'rgba(255,255,255,0.04)',line:{{width:0}}}}
        ]
      }});
      showPerfPopup(
        `<div style="font-weight:bold;margin-bottom:8px;color:rgba(255,255,255,0.7);">
           📅 ${{sd}} → ${{ed}}</div>
         <table style="width:100%;border-collapse:collapse;font-size:12px;">
           <tr><td style="color:rgba(255,255,255,0.4);padding:2px 6px;">모델 포트</td>
               <td style="text-align:right;padding:2px 6px;">${{fmt(rp)}}</td></tr>
           <tr><td style="color:rgba(255,255,255,0.4);padding:2px 6px;">SPY</td>
               <td style="text-align:right;padding:2px 6px;">${{fmt(rs)}}</td></tr>
           <tr><td style="color:rgba(255,255,255,0.4);padding:2px 6px;">60/40</td>
               <td style="text-align:right;padding:2px 6px;">${{fmt(rb)}}</td></tr>
         </table>
         <div style="margin-top:8px;font-size:11px;color:rgba(255,255,255,0.3);">
           <span onclick="resetPerfSel()" style="cursor:pointer;color:#e74c3c;">✕ 초기화</span>
         </div>`,
        mx, my
      );
      _selPt1 = null;
    }}
  }});
  // 차트 바깥 클릭시 팝업 닫기
  el.on('plotly_doubleclick', resetPerfSel);
}}

