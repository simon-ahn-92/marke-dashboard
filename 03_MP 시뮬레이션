      hovertemplate:`σ: ${{imp1.sigma.toFixed(2)}}%<br>μ: ${{imp1.mu.toFixed(2)}}%<br>샤프: ${{imp1.sharpe.toFixed(2)}}<extra>①개선</extra>`,
    }});
