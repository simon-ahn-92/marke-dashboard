  if (!hdr || !bar) return;
  const hh = hdr.getBoundingClientRect().height;
  bar.style.top = hh + 'px';
  const bh = bar.getBoundingClientRect().height;
  const total = Math.ceil(hh + bh) + 'px';
  document.querySelectorAll('.tab-content').forEach(el => {{
    el.style.paddingTop = total;
  }});
}}
window.addEventListener('resize', _syncLayout);

