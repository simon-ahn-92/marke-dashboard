    const c = v > 0.05 ? '#2ecc71' : v < -0.05 ? '#e74c3c' : '#aaa';
    return `<span style="color:${{c}};">${{v > 0 ? '+' : ''}}${{v.toFixed(1)}}%p</span>`;
  }}

  const rows = currEtfs.map(t => {{
    const cW  = (currNorm[t] * 100).toFixed(1);
    const i1W = imp1 ? (imp1.w[t] * 100).toFixed(1) : '-';
    const i2W = imp2 ? (imp2.w[t] * 100).toFixed(1) : '-';
    const d1  = imp1 ? (imp1.w[t] - currNorm[t]) * 100 : null;
    const d2  = imp2 ? (imp2.w[t] - currNorm[t]) * 100 : null;
