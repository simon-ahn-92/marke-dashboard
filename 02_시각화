def build_section3_html(scores_df: pd.DataFrame,
                        current_regime: str,
                        monthly_ret: pd.DataFrame | None = None,
                        opt_now: dict | None = None,
                        sharpe_now: float = np.nan) -> str:
    """추천 포트폴리오 (3가지 모드) — 채권·경기민감 제외 4자산 기준"""
    if current_regime not in scores_df.columns:
        return "<div class='section'><p>현재 국면 데이터 없음</p></div>"

    # 4자산으로 필터 (채권·경기민감 제외)
    scores_all = scores_df[current_regime].dropna()
    scores = scores_all.reindex([s for s in OPTIMAL_STYLES if s in scores_all.index]).dropna()
    if scores.empty:
        scores = scores_all
    weight_modes = compute_portfolio_weights(scores)

    # Sharpe 최적화 모드 추가 (상관관계 반영)
    if monthly_ret is not None:
        opt_styles = [s for s in OPTIMAL_STYLES if s in scores.index]
        style_rets = {}
        for s in opt_styles:
            tickers = [t for t, _ in STYLE_ETFS[s] if t in monthly_ret.columns]
            if tickers:
                grp = monthly_ret[tickers].mean(axis=1).dropna()
                if len(grp) >= 24:
                    style_rets[s] = grp
        if len(style_rets) >= 2:
            ret_mat = pd.DataFrame(style_rets).dropna()
            sh_w, sh_v = _max_sharpe(ret_mat, per_bounds=[(0.05, 0.65)] * len(style_rets))
            sharpe_opt_w = pd.Series(
                {s: round(w * 100, 1) for s, w in zip(style_rets.keys(), sh_w) if w >= 0.01},
                dtype=float
            )
            # 상관계수 행렬 계산
            corr_mat = ret_mat.corr().round(2)
            weight_modes["Sharpe최적"] = sharpe_opt_w.reindex(scores.index).fillna(0)
            _sharpe_val = round(sh_v, 2)
            _corr_mat   = corr_mat
        else:
            _sharpe_val = np.nan
            _corr_mat   = None
    else:
        _sharpe_val = np.nan
        _corr_mat   = None
    if not weight_modes:
        return "<div class='section'><p>포트폴리오 계산 불가</p></div>"

    sharpe_desc = (f"Sharpe {_sharpe_val:.2f}" if not np.isnan(_sharpe_val) else "Sharpe 최적")
    mode_desc = {
        "비례배분":    "점수에 비례하여 배분. 다양한 스타일에 분산 투자.",
