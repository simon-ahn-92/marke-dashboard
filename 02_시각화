# ═══════════════════════════════════════════════
# 위기 국면별 자산 성과 분석
# ═══════════════════════════════════════════════

def _max_sharpe(ret_df: pd.DataFrame,
                per_bounds: list[tuple] | None = None) -> tuple[np.ndarray, float]:
    """
    월별 수익률 행렬 → 최대 샤프 비율 포트폴리오 가중치·샤프값 반환
    ret_df     : columns=asset_groups, rows=months
    per_bounds : 자산별 (min, max) 제약 리스트. None이면 (0, 1)
    """
    n = ret_df.shape[1]
    ret_arr = ret_df.fillna(0).values

    def neg_sharpe(w):
        port = ret_arr @ w
        mean = port.mean() * 12
        std  = port.std() * np.sqrt(12)
        return -(mean / std) if std > 1e-8 else 0.0

    constraints = [{"type": "eq", "fun": lambda w: w.sum() - 1}]
    bounds = per_bounds if per_bounds else [(0.0, 1.0)] * n
    best_w, best_sh = np.ones(n) / n, -np.inf

    np.random.seed(42)
    for _ in range(12):
        x0 = np.clip(np.random.dirichlet(np.ones(n)),
                     [b[0] for b in bounds], [b[1] for b in bounds])
        x0 /= x0.sum()
        try:
            res = sp_minimize(neg_sharpe, x0, method="SLSQP",
                              bounds=bounds, constraints=constraints,
                              options={"maxiter": 500, "ftol": 1e-9})
            if res.success and -res.fun > best_sh:
                best_sh = -res.fun
                best_w  = res.x
        except Exception:
            pass

    best_w = np.where(best_w < 0.01, 0, best_w)
    s = best_w.sum()
    if s > 0:
        best_w /= s
    return best_w, best_sh


SHARPE_FWD_SHORT = 6    # 위기 구간 < 6개월일 때 추가 기간
SHARPE_FWD_LONG  = 12   # 위기 구간 ≥ 6개월일 때 추가 기간

def compute_crisis_perf(monthly_ret: pd.DataFrame,
                        price_df: pd.DataFrame | None = None) -> dict:
    """
    각 위기 구간별 자산 그룹 성과 + 최대 샤프 최적 배분 계산.

    누적수익률
      - 과거 위기 (end 확정): 월별 수익률 복리 합산
      - 진행중 위기 (end=None): 일간 가격 기준 (price_df)으로 최신 수익률 반영
    샤프 최적화 : 위기 시작 ~ 종료 후 +N개월 기준 월별 수익률 사용
    """
    today = pd.Timestamp.today()
    monthly_ret = monthly_ret.copy()
    monthly_ret.index = monthly_ret.index.to_period("M").to_timestamp("M")
    result = {}

    for name, color, start, end in CRISIS_DEF:
        start_ts = pd.Timestamp(start)
        end_ts   = pd.Timestamp(end) if end else today

        group_cum     = {}
        group_monthly = {}

        if end is None and price_df is not None:
            # ── 진행중 위기: 일간 가격으로 정확한 누적수익률 계산 ──
            # 기준가: 위기 시작 직전 마지막 거래일 종가
            pre = price_df.loc[:start_ts - pd.Timedelta(days=1)].dropna(how="all")
            base_prices = pre.iloc[-1] if not pre.empty else None

            # 현재가: 가장 최근 거래일
            latest_prices = price_df.dropna(how="all").iloc[-1]
            latest_date   = price_df.dropna(how="all").index[-1]

            for gname, (tickers, _, _cat) in CRISIS_ASSET_GROUPS.items():
                avail = [t for t in tickers if t in price_df.columns]
                if not avail or base_prices is None:
                    group_cum[gname] = np.nan
                    continue
                valid = [t for t in avail
                         if not pd.isna(base_prices.get(t))
                         and not pd.isna(latest_prices.get(t))
                         and base_prices[t] > 0]
                if not valid:
                    group_cum[gname] = np.nan
                    continue
                rets = [(latest_prices[t] / base_prices[t]) - 1 for t in valid]
                group_cum[gname] = np.mean(rets) * 100

            # 월수 표시: 위기 시작부터 현재까지 개월 수
            n_months = (today.year - start_ts.year) * 12 + (today.month - start_ts.month)
            n_months = max(n_months, 1)

        else:
            # ── 과거 위기: 월별 수익률 복리 합산 ──────────────────
            mask_crisis = (monthly_ret.index >= start_ts) & (monthly_ret.index <= end_ts)
            period_ret  = monthly_ret[mask_crisis]
            n_months    = len(period_ret)
            if n_months == 0:
                continue

            latest_date = end_ts

            for gname, (tickers, _, _cat) in CRISIS_ASSET_GROUPS.items():
                avail = [t for t in tickers if t in period_ret.columns]
                if not avail:
                    group_cum[gname] = np.nan
                    continue
                grp = period_ret[avail].mean(axis=1).dropna()
                if grp.empty:
                    group_cum[gname] = np.nan
                    continue
                group_cum[gname]     = ((1 + grp).prod() - 1) * 100
                group_monthly[gname] = grp

        # ── 샤프 최적화 구간 (월별 데이터 사용) ──────────────────
        sharpe_fwd = SHARPE_FWD_LONG if n_months >= 6 else SHARPE_FWD_SHORT
        if end:
            sharpe_end_ts = min(end_ts + pd.DateOffset(months=sharpe_fwd), today)
        else:
            sharpe_end_ts = today

        mask_sharpe   = (monthly_ret.index >= start_ts) & (monthly_ret.index <= sharpe_end_ts)
        period_sharpe = monthly_ret[mask_sharpe]
        n_sharpe      = len(period_sharpe)

        group_monthly_sharpe = {}
        for gname, (tickers, _, _cat) in CRISIS_ASSET_GROUPS.items():
            avail = [t for t in tickers if t in period_sharpe.columns]
            if not avail:
                continue
            grp = period_sharpe[avail].mean(axis=1).dropna()
            if not grp.empty:
                group_monthly_sharpe[gname] = grp

        valid_groups = [g for g in CRISIS_ASSET_GROUPS if g in group_monthly_sharpe]
        opt_weights, opt_sharpe = {}, np.nan

        if n_sharpe >= 6 and len(valid_groups) >= 2:
            ret_matrix = pd.DataFrame(
                {g: group_monthly_sharpe[g] for g in valid_groups}
            ).dropna(how="all").fillna(0)
            if len(ret_matrix) >= 3:
                weights, sharpe = _max_sharpe(ret_matrix)
                opt_weights = {
                    g: round(w * 100, 1)
                    for g, w in zip(valid_groups, weights)
                    if w >= 0.01
                }
                opt_sharpe = round(sharpe, 2)

        # 최적배분 기간(start → sharpe_end) 누적수익률 계산 (표 표시용)
        # 진행중 위기: 월별 데이터가 최신 월 미반영이므로 일간 기준(group_cum) 그대로 사용
        if end is None:
            group_cum_sharpe = dict(group_cum)
        else:
            group_cum_sharpe = {}
            for gname, grp_s in group_monthly_sharpe.items():
                if not grp_s.empty:
                    group_cum_sharpe[gname] = ((1 + grp_s).prod() - 1) * 100
            for gname in CRISIS_ASSET_GROUPS:
                if gname not in group_cum_sharpe:
                    group_cum_sharpe[gname] = np.nan

        # 연환산 변동성 (현재 탭 전용 — 2026-01-01 이후 데이터 기준)
        group_vol: dict = {}
        if end is None:
            vol_start = pd.Timestamp("2026-01-01")
            for gname, grp_s in group_monthly_sharpe.items():
                grp_vol = grp_s[grp_s.index >= vol_start]
                if len(grp_vol) >= 2:
                    group_vol[gname] = round(grp_vol.std() * np.sqrt(12) * 100, 1)
                else:
                    group_vol[gname] = np.nan

        result[name] = {
            "color":           color,
            "start":           start_ts,
            "end":             end_ts if end else None,
            "latest_date":     latest_date,
            "sharpe_end":      sharpe_end_ts,
            "n_months":        n_months,
            "n_sharpe":        n_sharpe,
            "returns":         group_cum,         # 위기 기간 수익률 (막대 차트용)
            "returns_sharpe":  group_cum_sharpe,  # 최적배분 기간 수익률 (표 표시용)
            "group_monthly":   group_monthly,
            "opt_weights":     opt_weights,
            "opt_sharpe":      opt_sharpe,
            "group_vol":       group_vol,         # 연환산 변동성 (현재 탭 전용)
        }

    return result


def _build_tran_evidence_html(daily_df: pd.DataFrame,
                              monthly_df: pd.DataFrame,
                              prob_df: pd.DataFrame) -> str:
    """현재(2026~) 전환기 근거 시각화 — 지표 카드 + 국면 확률 추이"""
    today = pd.Timestamp.today()
    cutoff_10y = today - pd.DateOffset(years=10)

    # ── 1. 지표 정의 & 계산 ─────────────────────────────────────────
    def _pct(series, cur):
        h = series.dropna()
        return round((h < cur).mean() * 100, 0) if len(h) > 5 else None

    def _trend(series, days=60):
        s = series.dropna()
        if len(s) < days:
            return 0.0
        return float(s.iloc[-1]) - float(s.iloc[-days])

    daily_hist  = daily_df[daily_df.index >= cutoff_10y]
    latest_d    = daily_df.dropna(how="all").iloc[-1]
    latest_m    = monthly_df.dropna(how="all").iloc[-1] if monthly_df is not None else pd.Series(dtype=float)

    def _dv(col, df=daily_df):
        return float(df[col].dropna().iloc[-1]) if col in df.columns and not df[col].dropna().empty else None

    vix       = _dv("VIX")
    hy        = _dv("HY크레딧스프레드")
    dxy_now   = _dv("달러인덱스DXY")
    dxy_3m    = float(daily_df["달러인덱스DXY"].dropna().iloc[-63]) if "달러인덱스DXY" in daily_df.columns and len(daily_df["달러인덱스DXY"].dropna()) > 63 else dxy_now
    gold      = _dv("금현물가격")
    gold_3m   = float(daily_df["금현물가격"].dropna().iloc[-63]) if "금현물가격" in daily_df.columns and len(daily_df["금현물가격"].dropna()) > 63 else gold
    tips      = _dv("실질금리TIPS10Y")
    yldspread = _dv("장단기금리차(10Y-2Y)")
    sahm      = float(monthly_df["Sahm룰침체지표"].dropna().iloc[-1]) if "Sahm룰침체지표" in monthly_df.columns else None

    vix_pct   = _pct(daily_hist["VIX"],                  vix)   if vix  else None
    hy_pct    = _pct(daily_hist["HY크레딧스프레드"],      hy)    if hy   else None
    tips_pct  = _pct(daily_hist["실질금리TIPS10Y"],       tips)  if tips else None
    yld_pct   = _pct(daily_hist["장단기금리차(10Y-2Y)"],  yldspread) if yldspread is not None else None
    gold_pct  = _pct(daily_hist["금현물가격"],            gold)  if gold else None
    dxy_chg   = round((dxy_now / dxy_3m - 1) * 100, 1) if dxy_now and dxy_3m else None
    gold_chg  = round((gold    / gold_3m - 1) * 100, 1) if gold    and gold_3m else None

    # 지표 카드 정의: (label, value_str, subtitle, pct, signal_color, icon, note)
    # signal_color: #e74c3c=경고 / #f1c40f=주의 / #2ecc71=양호
    def _pct_badge(p):
        if p is None: return ""
        if p >= 80: return f"<br><span style='font-size:10px;color:#e74c3c;'>상위 {100-int(p)}% (극단)</span>"
        if p >= 65: return f"<br><span style='font-size:10px;color:#f1c40f;'>상위 {100-int(p)}% (높음)</span>"
        if p <= 20: return f"<br><span style='font-size:10px;color:#2ecc71;'>하위 {int(p)}% (낮음)</span>"
        return f"<br><span style='font-size:10px;color:rgba(255,255,255,0.35);'>10년 {int(p)}th 백분위</span>"

    cards = []

    # VIX
    if vix is not None:
        sig = "#f1c40f" if vix_pct and vix_pct >= 65 else "#2ecc71"
        note = "불안·경계 수준" if vix_pct and vix_pct >= 65 else "비교적 안정"
        cards.append(("😱 VIX 공포지수",
                       f"{vix:.1f}",
                       note + _pct_badge(vix_pct), sig))

    # 장단기 금리차
    if yldspread is not None:
        if yldspread < 0:
            sig, note = "#e74c3c", "역전 (침체 선행 신호)"
        elif yldspread < 0.3:
            sig, note = "#f1c40f", "정상화 초기 — 방향 불확실"
        else:
            sig, note = "#2ecc71", "정상 구간"
        cards.append(("📐 장단기 금리차(10Y-2Y)",
                       f"{yldspread:+.2f}%p",
                       note + _pct_badge(yld_pct), sig))

    # HY 스프레드
    if hy is not None:
        sig = "#f1c40f" if hy_pct and hy_pct <= 15 else "#e74c3c" if hy_pct and hy_pct >= 80 else "#2ecc71"
        note = "신용시장 과열 (낮은 스프레드 = 위험 과소평가)" if hy_pct and hy_pct <= 15 else "정상 범위"
        cards.append(("💳 HY 크레딧 스프레드",
                       f"{hy:.2f}%",
                       note + _pct_badge(hy_pct), sig))

    # 달러인덱스 (3개월 변화)
    if dxy_now is not None and dxy_chg is not None:
        sig = "#e74c3c" if dxy_chg <= -3 else "#f1c40f" if dxy_chg <= -1 else "#2ecc71"
        note = "달러 급락 → 미국 자산 신뢰 하락" if dxy_chg <= -3 else "달러 약세" if dxy_chg < 0 else "달러 안정"
        cards.append(("💵 달러인덱스(DXY)",
                       f"{dxy_now:.1f}",
                       f"3개월 변화 {dxy_chg:+.1f}%  {note}", sig))

    # 금 (3개월 변화 + 백분위)
    if gold is not None:
        note = "역사적 신고점 — 통화·지정학 불안 헤지" if gold_pct and gold_pct >= 95 else "높은 수준"
        sig = "#e74c3c" if gold_pct and gold_pct >= 90 else "#f1c40f"
        gold_chg_str = f"3개월 변화 {gold_chg:+.1f}%  " if gold_chg else ""
        cards.append(("🥇 금 현물가격",
                       f"${gold:,.0f}",
                       gold_chg_str + note + _pct_badge(gold_pct), sig))

    # 실질금리 TIPS
    if tips is not None:
        sig = "#e74c3c" if tips_pct and tips_pct >= 80 else "#f1c40f" if tips_pct and tips_pct >= 60 else "#2ecc71"
        note = "높은 실질금리 → 기업·소비 부담" if tips_pct and tips_pct >= 70 else "보통"
        cards.append(("📈 실질금리(TIPS 10Y)",
                       f"{tips:.2f}%",
                       note + _pct_badge(tips_pct), sig))

    # Sahm 룰
    if sahm is not None:
        if sahm >= 0.5:
            sig, note = "#e74c3c", "임계치(0.5) 돌파 → 침체 신호"
        elif sahm >= 0.3:
            sig, note = "#f1c40f", "임계치(0.5) 접근 중 — 노동시장 주의"
        else:
            sig, note = "#2ecc71", "침체 신호 아님 (임계치 0.5 미만)"
        cards.append(("🚨 Sahm 룰 침체지표",
                       f"{sahm:.2f}",
                       f"(임계치 0.5)  {note}", sig))

    # ── 카드 HTML ─────────────────────────────────────────────────
    card_style = ("display:flex;flex-direction:column;justify-content:space-between;"
                  "background:#1a1a2e;border-radius:8px;padding:14px 16px;"
                  "border-left:4px solid {c};")
    cards_html = "".join(
        f"<div style='{card_style.format(c=c)}'>"
        f"<div style='font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:6px;'>{label}</div>"
        f"<div style='font-size:22px;font-weight:bold;color:{c};'>{val}</div>"
        f"<div style='font-size:11px;color:rgba(255,255,255,0.45);margin-top:4px;line-height:1.5;'>{sub}</div>"
        f"</div>"
        for label, val, sub, c in cards
    )

    # ── 2. 국면 확률 추이 차트 ────────────────────────────────────
    prob_chart_html = ""
    if prob_df is not None and len(prob_df) >= 3:
        # 2026.01 이후 + 그 이전 6개월
        cutoff_p = pd.Timestamp("2025-07-01")
        p_sub = prob_df[prob_df.index >= cutoff_p].copy()
        p_sub.index = p_sub.index.to_period("M").to_timestamp("M")
        p_sub = p_sub[~p_sub.index.duplicated(keep="last")]
        cols4 = ["붐(강세)", "골디락스", "스태그플레이션", "침체(위기)"]
        colors4 = ["#27ae60", "#2980b9", "#e67e22", "#c0392b"]
        p_cols = [c for c in cols4 if c in p_sub.columns]
        if p_cols:
            p_data = p_sub[p_cols].dropna(how="all")
            dates_str = [d.strftime("%Y.%m") for d in p_data.index]
            traces = []
            for col, clr in zip(p_cols, [c for c, n in zip(colors4, cols4) if n in p_cols]):
                traces.append(go.Scatter(
                    x=dates_str,
                    y=(p_data[col] * 100).round(1).tolist(),
                    name=col, line=dict(color=clr, width=2),
                    mode="lines+markers",
                    marker=dict(size=5),
                    hovertemplate=f"{col}: %{{y:.1f}}%<extra></extra>",
                ))
            # 전환기 배경 음영
            tran_x = [d for d in dates_str if p_sub.get("전환기", pd.Series(dtype=bool)).reindex(
                p_data.index).fillna(False).loc[p_data.index[dates_str.index(d)]]
            ] if "전환기" in p_sub.columns else []

            fig_prob = go.Figure(traces)
            fig_prob.add_hline(y=25, line_dash="dot",
                               line_color="rgba(255,255,255,0.2)", line_width=1,
                               annotation_text="균등 분포(25%)",
                               annotation_font_size=10,
                               annotation_font_color="rgba(255,255,255,0.3)")
            fig_prob.update_layout(
                template="plotly_dark", paper_bgcolor="#161622", plot_bgcolor="#161622",
                height=220, margin=dict(l=40, r=20, t=30, b=40),
                title=dict(text="국면 확률 추이 — 4국면이 균등할수록 전환기",
                           font=dict(size=12, color="rgba(255,255,255,0.7)"),
                           x=0.5),
                legend=dict(orientation="h", y=-0.25, x=0.5, xanchor="center",
                            font=dict(size=10, color="rgba(255,255,255,0.7)")),
                yaxis=dict(title="확률(%)", range=[0, 60],
                           gridcolor="rgba(255,255,255,0.06)",
                           tickfont=dict(size=10)),
                xaxis=dict(gridcolor="rgba(255,255,255,0.06)", tickfont=dict(size=10)),
                font=dict(family="Malgun Gothic", color="rgba(255,255,255,0.8)"),
                dragmode="pan",
            )
            prob_chart_html = fig_prob.to_html(
                full_html=False, include_plotlyjs=False,
                config={"displayModeBar": False, "responsive": True}
            )

    # ── 3. 전환기 판단 근거 텍스트 ─────────────────────────────────
    reasons = []
    if vix_pct and vix_pct >= 60:
        reasons.append(f"VIX {vix:.1f} (10년 상위 {100-int(vix_pct)}%) — 투자자 경계감 지속")
    if gold_pct and gold_pct >= 90:
        reasons.append(f"금 현물 ${gold:,.0f} (10년 {int(gold_pct)}th 백분위) — 통화·지정학 헤지 수요 역대급")
    if tips_pct and tips_pct >= 75:
        reasons.append(f"실질금리 {tips:.2f}% (10년 상위 {100-int(tips_pct)}%) — 고금리 부담 지속")
    if dxy_chg and dxy_chg <= -2:
        reasons.append(f"달러 3개월 {dxy_chg:+.1f}% — 미국 자산 신뢰 하락 시그널")
    if hy_pct and hy_pct <= 15:
        reasons.append(f"HY 스프레드 {hy:.2f}% (하위 {int(hy_pct)}%) — 신용시장 위험 과소평가, 주가와 디커플링")
    if sahm and 0.15 <= sahm < 0.5:
        reasons.append(f"Sahm 룰 {sahm:.2f} — 침체 아니나 노동시장 선행 약화 진행 중")

    reason_items = "".join(
        f"<li style='margin-bottom:5px;'>{r}</li>"
        for r in reasons
    ) if reasons else "<li>데이터 로드 불가</li>"

    summary_html = f"""
<div style="background:rgba(179,157,219,0.08);border:1px solid rgba(179,157,219,0.3);
            border-radius:8px;padding:16px 20px;margin-top:16px;">
  <div style="font-size:13px;font-weight:bold;color:#b39ddb;margin-bottom:10px;">
    🔍 전환기(TRAN) 판단 근거 — 4국면 확률 균등분포 + 다중 경고 신호 동시 발생
  </div>
  <ul style="margin:0 0 10px 16px;padding:0;font-size:12px;color:rgba(255,255,255,0.6);line-height:1.7;">
    {reason_items}
  </ul>
  <div style="font-size:11px;color:rgba(255,255,255,0.35);line-height:1.6;border-top:1px solid rgba(255,255,255,0.08);padding-top:8px;">
    ※ 전환기(TRAN)는 모델이 4개 국면(붐·골디락스·스태그·침체) 중 어느 하나로 확정하기 어려울 때 발생합니다.
    주가 신고점과 동시에 나타날 수 있으며, 역사적으로 2000년 3월·2007년 10월 등 주요 고점 전후에도
    유사 국면이 관찰되었습니다. 현재 상황은 방향성 불확실 구간으로, 리스크 관리가 수익 추구보다 우선됩니다.
  </div>
</div>"""

    n_cards = len(cards)
    col_count = min(n_cards, 3)  # 한 줄에 최대 3개
    grid_cols = " ".join(["1fr"] * col_count)

    return f"""
<div style="margin-top:22px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.08);">
  <div style="font-size:14px;font-weight:bold;color:#b39ddb;margin-bottom:14px;">
    🧭 왜 지금이 전환기(TRAN)인가? — 핵심 지표 현황
  </div>
  <div style="display:grid;grid-template-columns:{grid_cols};gap:10px;margin-bottom:16px;">
    {cards_html}
  </div>
  <div style="margin-bottom:8px;">
    {prob_chart_html}
  </div>
  {summary_html}
</div>"""


def build_crisis_performance_html(crisis_perf: dict,
                                  daily_df: pd.DataFrame | None = None,
                                  monthly_df: pd.DataFrame | None = None,
                                  prob_df: pd.DataFrame | None = None,
                                  current_regime: str = "") -> str:
    """위기 국면별 자산 성과 & 최적 배분 섹션 HTML"""
    if not crisis_perf:
        return "<div class='section'><p>위기 국면 데이터 없음</p></div>"

    tab_btns    = []
    tab_panels  = []
    crisis_list = list(crisis_perf.items())

    for idx, (name, data) in enumerate(crisis_list):
        color       = data["color"]
        n_months    = data["n_months"]
        start       = data["start"]
        end_raw     = data["end"]
        latest_date = data.get("latest_date", end_raw)
        end_str     = end_raw.strftime("%Y.%m") if end_raw else "진행중"
        start_str   = start.strftime("%Y.%m")
        # 진행중 위기: 기준일 표시
        asof_str    = (latest_date.strftime("%Y.%m.%d") if end_raw is None
                       and latest_date is not None else None)
        is_active   = (idx == 0)

        # ── 탭 버튼 ──────────────────────────────
        tab_btns.append(
            f"<button class='crisis-tab-btn {'active' if is_active else ''}' "
            f"style='border-bottom:3px solid {color};' "
            f"onclick=\"switchCrisis({idx}, this)\">"
            f"<span style='display:inline-block;width:8px;height:8px;"
            f"border-radius:50%;background:{color};margin-right:5px;'></span>"
            f"{name}</button>"
        )

        # ── 수익률 바 차트 ────────────────────────
        rets        = data["returns"]           # 위기 기간 (막대 차트용)
        rets_sharpe = data.get("returns_sharpe", data["returns"])  # 최적배분 기간 (표용)
        groups = list(CRISIS_ASSET_GROUPS.keys())
        vals   = [rets.get(g, np.nan) for g in groups]
        colors_bar = [CRISIS_ASSET_GROUPS[g][1] for g in groups]

        # NaN 제외 후 정렬 (낮은→높은 순, 즉 차트에서 best가 최상단)
        paired = [(g, v, c) for g, v, c in zip(groups, vals, colors_bar)
                  if not np.isnan(v)]
        paired.sort(key=lambda x: x[1])
        if paired:
            g_names, g_vals, g_colors = zip(*paired)
        else:
            g_names, g_vals, g_colors = [], [], []

        g_vals_r = [round(v, 1) for v in g_vals]   # 소수점 1자리로 반올림
        bar_fig = go.Figure(go.Bar(
            x=g_vals_r, y=list(g_names),
            orientation="h",
            marker=dict(
                color=[("#2ecc71" if v >= 0 else "#e74c3c") for v in g_vals_r],
                opacity=0.85,
                line=dict(width=0),
            ),
            text=[f"{v:+.1f}%" for v in g_vals_r],
            textposition="outside",
            textfont=dict(size=12),
            hovertemplate="%{y}: %{x:.1f}%<extra></extra>",
        ))
        # 카테고리 구분선 (주식/채권/대체 경계)
        cat_order = ["주식"] * 4 + ["채권"] * 2 + ["대체"] * 3
        cat_map   = {g: cat_order[i] for i, g in enumerate(groups)}
        x_min = min(g_vals_r) * 1.35 if g_vals_r else -50
        x_max = max(g_vals_r) * 1.35 if g_vals_r else 50
        # 부호 조합 보정 (x_max가 음수면 0보다 크게, x_min이 양수면 0보다 작게)
        x_max = max(x_max, abs(min(g_vals_r)) * 0.3 + 5)
        x_min = min(x_min, -abs(max(g_vals_r)) * 0.1 - 2)

        bar_fig.update_layout(
            template="plotly_dark", paper_bgcolor="#111111", plot_bgcolor="#111111",
            height=300, autosize=True,
            margin=dict(l=0, r=60, t=10, b=10),
            xaxis=dict(
                title="기간 누적 수익률 (%)",
                showgrid=True, gridcolor="#2c3e50",
                zeroline=True, zerolinecolor="rgba(255,255,255,0.25)",
                range=[x_min, x_max],
            ),
            yaxis=dict(showgrid=False),
            font=dict(family="Malgun Gothic", size=12),
            showlegend=False,
        )
        bar_html = bar_fig.to_html(
            full_html=False, include_plotlyjs=False,
            config={"displayModeBar": False, "responsive": True}
        )

        # ── 최적 포트폴리오 파이 차트 ─────────────
        opt_w      = data["opt_weights"]
        opt_sh     = data["opt_sharpe"]
        n_sharpe   = data["n_sharpe"]
        sharpe_end = data["sharpe_end"]
        sharpe_end_str = sharpe_end.strftime("%Y.%m")
        pie_html = ""
        if opt_w:
            pie_labels = list(opt_w.keys())
            pie_vals   = list(opt_w.values())
            pie_colors = [CRISIS_ASSET_GROUPS[g][1] for g in pie_labels]
            pie_fig = go.Figure(go.Pie(
                labels=pie_labels, values=pie_vals,
                marker=dict(colors=pie_colors, line=dict(color="#111", width=2)),
                texttemplate="%{label}<br><b>%{value:.1f}%</b>",
                textfont=dict(size=12, family="Malgun Gothic"),
                hovertemplate="%{label}: %{value:.1f}%<extra></extra>",
                hole=0.38,
            ))
            pie_fig.update_layout(
                template="plotly_dark", paper_bgcolor="#161622", plot_bgcolor="#161622",
                margin=dict(l=5, r=5, t=40, b=10),
                width=240, height=240, autosize=False,
                showlegend=False,
                font=dict(family="Malgun Gothic"),
                title=dict(
                    text=(f"최적 배분 (샤프 {opt_sh:.2f})<br>"
                          f"<span style='font-size:10px;'>"
                          f"{start_str}~{sharpe_end_str} ({n_sharpe}M)</span>"),
                    font=dict(size=12, color="rgba(255,255,255,0.6)"),
                    x=0.5,
                ),
            )
            pie_html = pie_fig.to_html(
                full_html=False, include_plotlyjs=False,
                config={"displayModeBar": False, "responsive": False}
            )
        elif n_sharpe < 6:
            pie_html = ("<div style='color:rgba(255,255,255,0.35);font-size:12px;"
                        "padding:20px;text-align:center;'>"
                        f"기간이 짧아({n_sharpe}개월)<br>샤프 최적화 미산출<br>"
                        f"<span style='font-size:10px;'>(6개월 이상 필요)</span></div>")

        # ── 자산별 수익률 상세 테이블 (최적배분 기간 기준) ──
        th = "padding:7px 10px;font-size:12px;border-bottom:2px solid #2c3e50;"
        td = "padding:6px 10px;font-size:12px;border-bottom:1px solid rgba(255,255,255,0.06);"
        is_ongoing = (end_raw is None)
        last_col_header = "변동성(연환산)" if is_ongoing else "최적배분"
        group_vol_data = data.get("group_vol", {})

        # ── 스파크라인 (진행중 탭 전용) ──────────────
        def _sparkline(tickers, width=110, height=30):
            if daily_df is None:
                return ""
            avail = [t for t in tickers if t in daily_df.columns]
            if not avail:
                return ""
            df_s = daily_df[avail].loc[daily_df.index >= start].dropna(how="all")
            if len(df_s) < 3:
                return ""
            base = df_s.iloc[0].replace(0, np.nan)
            norm = (df_s / base).mean(axis=1).dropna()
            if len(norm) > 60:
                norm = norm.iloc[:: len(norm) // 60]
            vals = norm.tolist()
            n = len(vals)
            mn, mx = min(vals), max(vals)
            rng = mx - mn or 0.001
            pad = 3

            def px(i): return i / (n - 1) * width if n > 1 else width / 2
            def py(v): return height - pad - (v - mn) / rng * (height - 2 * pad)

            baseline = 1.0  # 시작일 기준 (정규화 기준값)

            # ── 기준선(1.0) 위/아래 구간 색상 분리 ──
            # 초록 = 시작일 대비 플러스, 빨강 = 마이너스
            # 기준선 교차 시 정확한 교차점 보간
            segs: list = []
            cur_color: str | None = None
            cur_pts: list = []

            for i in range(n):
                ci = "#2ecc71" if vals[i] >= baseline else "#e74c3c"
                xi, yi = px(i), py(vals[i])

                if cur_color is None:
                    cur_color = ci
                elif ci != cur_color:
                    dv = vals[i] - vals[i - 1]
                    t  = (baseline - vals[i - 1]) / dv if dv != 0 else 0.5
                    cx = px(i - 1) + t * (px(i) - px(i - 1))
                    cy = py(baseline)
                    cur_pts.append((cx, cy))
                    segs.append((cur_color, cur_pts))
                    cur_pts    = [(cx, cy)]
                    cur_color  = ci

                cur_pts.append((xi, yi))

            if cur_pts:
                segs.append((cur_color, cur_pts))

            def pline(pts_list, color):
                if len(pts_list) < 2:
                    return ""
                ps = " ".join(f"{x:.1f},{y:.1f}" for x, y in pts_list)
                return (f'<polyline points="{ps}" fill="none" stroke="{color}" '
                        f'stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>')

            # 기준선 점선 (시작일=0% 선)
            base_y  = py(baseline)
            base_line = (f'<line x1="0" y1="{base_y:.1f}" x2="{width}" y2="{base_y:.1f}" '
                         f'stroke="rgba(255,255,255,0.15)" stroke-width="1" stroke-dasharray="3,3"/>')

            svg_body = base_line + "".join(pline(p, c) for c, p in segs)

            return (f'<svg width="{width}" height="{height}" '
                    f'viewBox="0 0 {width} {height}" style="display:block;margin:0 auto;">'
                    f'{svg_body}</svg>')

        sparkline_th = (f"<th style='{th}text-align:center;'>추이 (2026.01~)</th>"
                        if is_ongoing else "")
        tbl_rows = [
            f"<tr>"
            f"<th style='{th}text-align:left;'>자산군</th>"
            f"<th style='{th}text-align:center;'>구분</th>"
            f"<th style='{th}text-align:right;'>누적수익률<br>"
            f"<span style='font-size:10px;color:rgba(255,255,255,0.4);font-weight:normal;'>"
            f"({start_str}~{sharpe_end_str})</span></th>"
            f"<th style='{th}text-align:right;'>{last_col_header}</th>"
            f"{sparkline_th}"
            f"</tr>"
        ]
        # 정렬: 최적배분 기간 수익률 내림차순
        sorted_groups = sorted(
            [(g, rets_sharpe.get(g, np.nan)) for g in groups],
            key=lambda x: (np.isnan(x[1]), -x[1] if not np.isnan(x[1]) else 0)
        )
        for g, ret_val in sorted_groups:
            gcolor  = CRISIS_ASSET_GROUPS[g][1]
            cat     = CRISIS_ASSET_GROUPS[g][2]
            tickers = CRISIS_ASSET_GROUPS[g][0]

            if np.isnan(ret_val):
                ret_str = "<span style='color:#444;'>N/A</span>"
            else:
                c = "#2ecc71" if ret_val >= 0 else "#e74c3c"
                ret_str = f"<span style='color:{c};font-weight:bold;'>{ret_val:+.1f}%</span>"

            if is_ongoing:
                vol = group_vol_data.get(g, np.nan)
                last_col_str = (f"<b>{vol:.1f}%</b>" if not np.isnan(vol)
                                else "<span style='color:#555;'>N/A</span>")
                last_col_color = "color:#64b5f6;"
                spark_td = (f"<td style='{td}vertical-align:middle;'>"
                            f"<div style='display:flex;justify-content:center;align-items:center;'>"
                            f"{_sparkline(tickers)}</div></td>")
            else:
                wgt = opt_w.get(g, 0)
                last_col_str = (f"<b>{wgt:.1f}%</b>" if wgt > 0
                                else "<span style='color:#555;'>—</span>")
                last_col_color = "color:#f1c40f;"
                spark_td = ""

            tbl_rows.append(
                f"<tr>"
                f"<td style='{td}color:{gcolor};font-weight:bold;'>{g}</td>"
                f"<td style='{td}text-align:center;color:rgba(255,255,255,0.4);font-size:11px;'>{cat}</td>"
                f"<td style='{td}text-align:right;'>{ret_str}</td>"
                f"<td style='{td}text-align:right;{last_col_color}'>{last_col_str}</td>"
                f"{spark_td}"
                f"</tr>"
            )

        ongoing_badge = ""
        if end_raw is None:
            ongoing_badge = (" <span style='font-size:11px;background:#e74c3c;color:white;"
                             "padding:1px 6px;border-radius:3px;'>진행중</span>")
            if current_regime:
                rc = REGIME_COLORS_SOLID.get(current_regime, "#888")
                ongoing_badge += (
                    f" <span style='font-size:11px;background:{rc};color:white;"
                    f"padding:1px 8px;border-radius:3px;font-weight:bold;'>"
                    f"{current_regime}</span>"
                )

        alloc_bar_html = ""

        asof_badge = (
            f" <span style='font-size:11px;background:rgba(255,255,255,0.1);"
            f"color:rgba(255,255,255,0.6);padding:2px 7px;border-radius:3px;"
            f"margin-left:4px;'>기준일 {asof_str}</span>"
            if asof_str else ""
        )
        bar_label = (
            f"↑ 기간 누적 수익률 (일간 가격 기준, {asof_str} 종가)"
            if asof_str else
            "↑ 기간 누적 수익률 (ETF 그룹 평균, 데이터 미존재 구간은 N/A)"
        )

        desc = CRISIS_DESC.get(name, "")
        desc_html = (
            f"<div style='margin-top:8px;font-size:13px;color:rgba(255,255,255,0.55);"
            f"line-height:1.7;padding:8px 12px;background:rgba(255,255,255,0.04);"
            f"border-left:3px solid {color};border-radius:0 4px 4px 0;'>"
            f"{desc}</div>"
            if desc else ""
        )

        # 현재(2026~) 전용 전환기 근거 섹션
        tran_evidence_html = ""
        if end_raw is None and daily_df is not None and monthly_df is not None:
            try:
                tran_evidence_html = _build_tran_evidence_html(daily_df, monthly_df, prob_df)
            except Exception as _e:
                tran_evidence_html = f"<p style='color:#e74c3c;font-size:11px;'>전환기 근거 섹션 오류: {_e}</p>"

        panel_display = "block" if is_active else "none"
        tab_panels.append(f"""
<div id="crisis-panel-{idx}" class="crisis-tab-panel" style="display:{panel_display};">
  <div style="padding:12px 0 12px;border-bottom:1px solid rgba(255,255,255,0.08);
              margin-bottom:16px;">
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
      <span style="font-size:16px;font-weight:bold;color:{color};">{name}</span>
      <span style="color:rgba(255,255,255,0.5);font-size:13px;">
        {start_str} ~ {end_str}{ongoing_badge} &nbsp;|&nbsp; {n_months}개월
      </span>{asof_badge}
    </div>
    {desc_html}
  </div>

  <div style="margin-bottom:16px;">
    <div style="font-size:12px;color:rgba(255,255,255,0.4);margin-bottom:6px;">
      {bar_label}
    </div>
    {bar_html}
    {alloc_bar_html}
  </div>

  {"" if is_ongoing else f"<div style='display:grid;grid-template-columns:250px 1fr;gap:20px;align-items:start;'><div>{pie_html}</div>"}
  <div style="overflow-x:auto;">
    <table style="width:100%;border-collapse:collapse;">
      {"".join(tbl_rows)}
