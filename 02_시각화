def main():
    print("===== 시각화_05_포트폴리오 시작 =====\n")

    print("[1/6] 국면 시계열 로드...")
    regime_series, period_type = load_regime_series()
    current_regime = regime_series.dropna().iloc[-1]
    as_of = regime_series.dropna().index[-1].strftime("%Y년 %m월")
    is_infer = (period_type.iloc[-1] == "추론") if not period_type.empty else False
    print(f"      기간: {regime_series.index[0].date()} ~ {regime_series.index[-1].date()}")
    print(f"      현재 국면: {current_regime} ({as_of}) "
          f"[{'추론 구간' if is_infer else '학습 구간'}]")
    n_train = (period_type == "학습").sum()
    n_infer = (period_type == "추론").sum()
    print(f"      학습 구간: {n_train}개월 / 추론 구간: {n_infer}개월")
    regime_counts = regime_series.value_counts()
    for r, c in regime_counts.items():
        print(f"      {r}: {c}개월")

    print("\n[2/6] 스타일 ETF 가격 로드...")
    price_df = load_etf_prices()
    print(f"      수집 ETF: {price_df.columns.tolist()}")
    print(f"      기간: {price_df.index[0].date()} ~ {price_df.index[-1].date()}")

    print("\n[3/6] 월별 수익률 계산...")
    monthly_ret = compute_monthly_returns(price_df)
    print(f"      월별 수익률 행수: {len(monthly_ret)}")

    print("\n[4/6] 국면별 성과 분석...")
    regime_data   = split_by_regime(monthly_ret, regime_series)
    all_metrics   = compute_style_metrics(regime_data)
    scores_df     = metrics_to_scores(all_metrics)

    print("      [국면별 스타일 점수]")
    print(scores_df.to_string())

    print("\n[5/7] 위기 국면별 자산 성과 분석...")
    crisis_perf = compute_crisis_perf(monthly_ret, price_df=price_df)
    for cname, cd in crisis_perf.items():
        valid = sum(1 for v in cd["returns"].values() if not np.isnan(v))
        print(f"      {cname}: {cd['n_months']}개월, 유효자산 {valid}개, "
              f"최적샤프 {cd['opt_sharpe']}")

    print("\n[6/7] DTW 유사 구간 분석...")
    macro_df  = dtw_load_macro()
    scores_m  = dtw_build_scores(macro_df)
    similar   = dtw_find_similar(scores_m)
    style_fwd = dtw_style_returns(monthly_ret, similar)
    if similar:
        print(f"      유사 구간 {len(similar)}개 탐색 완료")
        for i, (end_d, sim) in enumerate(similar):
            print(f"        {i+1}. {end_d.strftime('%Y-%m')}  유사도 {sim:.1f}%")
    else:
        print("      유사 구간 없음 (데이터 부족)")

    print("      현재 시점 최적 배분 산출 중...")
    opt_now, sharpe_now = dtw_current_optimal(monthly_ret, similar, fwd=12)
    if opt_now:
        print(f"      최적 샤프: {sharpe_now:.2f}")
        for s, w in sorted(opt_now.items(), key=lambda x: -x[1]):
            print(f"        {s}: {w:.1f}%")
    else:
        print("      최적 배분 산출 불가")

    print("\n[7/8] HTML 섹션 생성...")
    # 전환기 근거 시각화용 부가 데이터
    try:
        _xl_res  = pd.ExcelFile(RESULT_PATH)
        _prob_df = pd.read_excel(_xl_res, sheet_name="국면_확률_상세",
                                 index_col=0, parse_dates=True).sort_index()
    except Exception:
        _prob_df = None
    _xl_raw   = pd.ExcelFile(FRED_PATH)
    _daily_df = pd.read_excel(_xl_raw, sheet_name="일간데이터",
                              index_col=0, parse_dates=True).sort_index()
    _monthly_df = pd.read_excel(_xl_raw, sheet_name="월간데이터",
                                index_col=0, parse_dates=True).sort_index()
    s_crisis = build_crisis_performance_html(
        crisis_perf,
        daily_df=_daily_df, monthly_df=_monthly_df, prob_df=_prob_df,
        current_regime=current_regime,
    )
    s3       = build_section3_html(scores_df, current_regime, monthly_ret=monthly_ret,
                                   opt_now=opt_now, sharpe_now=sharpe_now)
    s4       = build_section4_html(similar, style_fwd, monthly_ret,
                                   opt_now=opt_now, sharpe_now=sharpe_now)

    print("\n[8/8] HTML 저장...")
    html = build_full_html(s_crisis, s3, s4, current_regime, as_of,
                           is_infer=is_infer)
    OUTPUT_PATH.write_text(html, encoding="utf-8")
    print(f"      [완료] {OUTPUT_PATH}")


