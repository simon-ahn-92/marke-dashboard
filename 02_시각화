def load_regime_series() -> tuple[pd.Series, pd.Series]:
    """
    국면판단_결과_v2.xlsx 국면_시계열 시트 → (국면 시계열, 구간구분 시계열)
    구간구분: "학습" | "추론"
    """
    df = pd.read_excel(RESULT_PATH, sheet_name="국면_시계열",
                       index_col=0, parse_dates=True).sort_index()
    regime = df["국면"].dropna()

    if "구간구분" in df.columns:
        period_type = df["구간구분"].reindex(regime.index).fillna("학습")
    else:
        # fallback: 날짜 기준 생성
        period_type = regime.index.map(
            lambda d: "추론" if d > pd.Timestamp(TRAIN_END_DATE) else "학습"
        )
        period_type = pd.Series(period_type, index=regime.index)

    return regime, period_type


def load_etf_prices() -> pd.DataFrame:
    """국면판단_원데이터.xlsx에서 스타일·현금성 ETF 가격 통합 로드"""
    xl  = pd.ExcelFile(FRED_PATH)
    daily = pd.read_excel(xl, sheet_name="일간데이터",
                          index_col=0, parse_dates=True).sort_index()
    df = daily.copy()

    if "현금성ETF" in xl.sheet_names:
        cash_df = pd.read_excel(xl, sheet_name="현금성ETF",
                                index_col=0, parse_dates=True).sort_index()
        df = pd.concat([df, cash_df], axis=1)

    df = df.loc[:, ~df.columns.duplicated(keep="last")]

    etf_tickers = [t for etfs in STYLE_ETFS.values() for t, _ in etfs]
    cols    = [c for c in etf_tickers if c in df.columns]
    missing = [c for c in etf_tickers if c not in df.columns]
    if missing:
        print(f"  [경고] 데이터 없는 ETF: {missing}")
    print(f"  Excel 로드: {len(cols)}개 ETF 컬럼")
    return df[cols].dropna(how="all")


def compute_monthly_returns(price_df: pd.DataFrame) -> pd.DataFrame:
    """일간 가격 → 월말 종가 → 월별 수익률"""
    monthly = price_df.resample("ME").last()
    returns = monthly.pct_change().dropna(how="all")
    return returns


