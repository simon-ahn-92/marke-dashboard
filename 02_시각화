def split_by_regime(monthly_ret: pd.DataFrame,
                    regime: pd.Series) -> dict[str, pd.DataFrame]:
    """월별 수익률을 국면별로 분리"""
    # 인덱스를 월말로 통일
    regime.index = regime.index.to_period("M").to_timestamp("M")
    regime = regime[~regime.index.duplicated(keep="last")]
    monthly_ret.index = monthly_ret.index.to_period("M").to_timestamp("M")

    combined = monthly_ret.copy()
    combined["__regime__"] = regime

    result = {}
    for r in REGIME_ORDER:
        sub = combined[combined["__regime__"] == r].drop(columns=["__regime__"])
        if len(sub) >= 3:
            result[r] = sub
    return result


def compute_group_metrics(ret_series: pd.Series) -> dict:
    """단일 그룹 수익률 시계열 → 4개 지표 계산"""
    if len(ret_series) < 3:
        return None
    avg_ret  = ret_series.mean() * 100          # %
    win_rate = (ret_series > 0).mean() * 100    # %
    sharpe   = (ret_series.mean() / ret_series.std() * np.sqrt(12)
                if ret_series.std() > 0 else 0)
    cum      = (1 + ret_series).cumprod()
    roll_max = cum.cummax()
    dd       = (cum - roll_max) / roll_max
    mdd      = abs(dd.min()) * 100              # %
    return {"avg_ret": avg_ret, "win_rate": win_rate,
            "sharpe": sharpe, "mdd": mdd, "n": len(ret_series)}


def compute_style_metrics(regime_data: dict[str, pd.DataFrame]) -> dict:
    """regime → style → metrics 계산"""
    result = {}
    for regime, ret_df in regime_data.items():
        result[regime] = {}
        for style, etfs in STYLE_ETFS.items():
            tickers = [t for t, _ in etfs if t in ret_df.columns]
            if not tickers:
                continue
            grp = ret_df[tickers].mean(axis=1).dropna()
            m = compute_group_metrics(grp)
            if m:
                result[regime][style] = m
    return result


def metrics_to_scores(all_metrics: dict) -> pd.DataFrame:
    """
    metrics → 0-100 점수 (국면 내 스타일 간 상대 순위 기반)
    Returns DataFrame: index=style, columns=regime
    """
    styles = list(STYLE_ETFS.keys())
    scores_dict = {}

    for regime in REGIME_ORDER:
        mets = all_metrics.get(regime, {})
        valid_styles = [s for s in styles if s in mets]
        if len(valid_styles) < 2:
            continue

        n = len(valid_styles)
        style_scores = {}
        for s in valid_styles:
            m = mets[s]
            # 각 지표별 퍼센타일 (높을수록 좋음)
            def pct_rank(val, vals, higher_better=True):
                ranked = sorted(vals, reverse=higher_better)
                rank = ranked.index(val)  # 0 = best
                return (n - 1 - rank) / max(n - 1, 1) * 100

            all_avg = [mets[x]["avg_ret"]  for x in valid_styles]
            all_wr  = [mets[x]["win_rate"] for x in valid_styles]
            all_sh  = [mets[x]["sharpe"]   for x in valid_styles]
            all_mdd = [mets[x]["mdd"]      for x in valid_styles]

            p_avg = pct_rank(m["avg_ret"],  all_avg, True)
            p_wr  = pct_rank(m["win_rate"], all_wr,  True)
            p_sh  = pct_rank(m["sharpe"],   all_sh,  True)
            p_mdd = pct_rank(m["mdd"],      all_mdd, False)  # mdd낮을수록 좋음

            weighted = p_avg * 0.40 + p_wr * 0.25 + p_sh * 0.25 + p_mdd * 0.10
            style_scores[s] = round(weighted, 1)

        scores_dict[regime] = style_scores

    df = pd.DataFrame(scores_dict, index=styles)
    df = df.reindex(columns=[r for r in REGIME_ORDER if r in df.columns])
    return df


def compute_portfolio_weights(scores: pd.Series) -> dict:
    """
    현재 국면 스타일 점수 → 3가지 포트폴리오 가중치
    scores: pd.Series (index=style, values=0-100 score)
    """
    s = scores.dropna()
    if s.empty:
        return {}

    # 비례배분: 점수에 비례
    prop = (s / s.sum() * 100).round(1)

    # 집중형: 점수 제곱에 비례 (상위 스타일에 집중)
    sq = s ** 2
    conc = (sq / sq.sum() * 100).round(1)

    # 균등혼합: 상위 3개에만 균등 배분
    top3 = s.nlargest(3).index
    equal = pd.Series(0.0, index=s.index)
    equal[top3] = round(100 / len(top3), 1)
    equal = equal.round(1)

    return {"비례배분": prop, "집중형": conc, "균등혼합": equal}


