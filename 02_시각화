def _score_cell_style(score: float) -> str:
    """점수 → 셀 배경색 (0=빨강, 50=회색, 100=초록)"""
    if np.isnan(score):
        return "background:#1a1a2e;color:#555;"
    # 0-50: 빨강→회색, 50-100: 회색→초록
    r = g = b = 0
    if score <= 50:
        t = score / 50.0
        r = int(180 * (1 - t) + 60 * t)
        g = int(40  * (1 - t) + 80 * t)
        b = int(40  * (1 - t) + 60 * t)
    else:
        t = (score - 50) / 50.0
        r = int(60  * (1 - t) + 30  * t)
        g = int(80  * (1 - t) + 160 * t)
        b = int(60  * (1 - t) + 80  * t)
    text = "white"
    return f"background:rgb({r},{g},{b});color:{text};"


