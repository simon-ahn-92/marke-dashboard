def compute_phase_scores(df: pd.DataFrame,
                         train_end_t: int | None = None) -> pd.DataFrame:
    """
    각 시점(월)에 대해 모든 지표의 가중 합산 점수 계산.
    train_end_t: 학습 구간 마지막 정수 인덱스.
                 추론 구간(t > train_end_t)은 학습 분포 기준으로 평가.
    반환: DataFrame (index=날짜, columns=PHASE_CODES)
    """
    T           = len(df)
    scores_arr  = np.zeros((T, 4))
    contrib_log = []                # 최신 시점 기여도 기록

    for col, label, weight, dtype, alpha, beta, gamma in INDICATORS:
        if col not in df.columns:
            continue

        series = df[col]
        latest_contrib = None

        for t in range(T):
            raw = series.iloc[t]
            if pd.isna(raw):
                continue

            if dtype == "inf":
                # 물가 지표: composite score + theory 임계값 점수 혼합
                cpct = composite_score(series, t, alpha, beta, gamma,
                                       train_end_t=train_end_t)
                if np.isnan(cpct):
                    continue
                theory_s = _inflation_theory_score(col, raw)
                accel_s  = _growth_score(cpct) * np.array([-1, 1, -1, 1])
                score = theory_s * 0.65 + accel_s * 0.35
            else:
                # 성장 지표: direction 보정 후 composite_score
                cpct = composite_score(series, t, alpha, beta, gamma,
                                       train_end_t=train_end_t)
                if np.isnan(cpct):
                    continue
                if dtype == "g_i":
                    cpct = 1.0 - cpct
                score = _growth_score(cpct)

            scores_arr[t] += score * weight

            if t == T - 1:
                latest_contrib = {"지표": label, "가중치": weight,
                                  "유형": dtype,
                                  "점수_BOOM": round(score[0] * weight, 3),
                                  "점수_GOLD": round(score[1] * weight, 3),
                                  "점수_STAG": round(score[2] * weight, 3),
                                  "점수_RECE": round(score[3] * weight, 3)}
        if latest_contrib:
            contrib_log.append(latest_contrib)

    score_df = pd.DataFrame(scores_arr, index=df.index, columns=PHASE_CODES)
    return score_df, pd.DataFrame(contrib_log)





# =====================================================================
# 7. Softmax → 국면 확률  (CLAUDE.md §5-1)
# =====================================================================
def compute_probabilities(score_df: pd.DataFrame,
                          temperature: float = TEMPERATURE) -> pd.DataFrame:
    """가중 합산 점수 → Softmax 확률 (합=100%)"""
    arr  = score_df.values
    prob = softmax(arr / temperature, axis=1)
    return pd.DataFrame(prob, index=score_df.index, columns=PHASES)


# =====================================================================
# 8. EMA 스무딩 + Confirmation Rule  (CLAUDE.md §5-2)
# =====================================================================
def smooth_and_confirm(prob_df: pd.DataFrame,
                       ema_span: int    = EMA_SPAN,
                       confirm_m: int   = CONFIRM_M,
                       confirm_th: float = CONFIRM_TH) -> pd.DataFrame:
    """
    Step1: EMA 스무딩 (span개월)
    Step2: 재정규화
    Step3: Confirmation Rule — confirm_m 연속 confirm_th 초과 시 국면 확정
    """
    smoothed = prob_df.ewm(span=ema_span, adjust=False).mean()
    smoothed = smoothed.div(smoothed.sum(axis=1), axis=0)

    confirmed = []
    current   = None
    streak    = 0
    candidate = None

    for _, row in smoothed.iterrows():
        dominant = row.idxmax()
        if row[dominant] > confirm_th:
            if dominant == candidate:
                streak += 1
            else:
                candidate = dominant
                streak    = 1
            if streak >= confirm_m:
                current = candidate
        else:
            streak = 0   # 임계값 미달 시 연속 카운트 초기화
        confirmed.append(current)

    smoothed["확정국면"] = confirmed
    return smoothed


# =====================================================================
# 9. Shannon Entropy → 전환기(TRAN) 감지  (CLAUDE.md §5-3)
# =====================================================================
def detect_transition(prob_row: np.ndarray,
                      threshold: float = ENTROPY_TH) -> bool:
    """4국면 최대 엔트로피 ≈ 1.386; threshold 초과 시 전환기 선언"""
    p       = np.clip(prob_row, 1e-9, 1.0)
    entropy = -np.sum(p * np.log(p))
    return bool(entropy > threshold)


def apply_transition_flag(smoothed_df: pd.DataFrame) -> pd.DataFrame:
    """확률 행렬에 TRAN 플래그 열 추가"""
    prob_cols = [c for c in smoothed_df.columns if c in PHASES]
    smoothed_df["전환기"] = smoothed_df[prob_cols].apply(
        lambda row: detect_transition(row.values), axis=1
    )
    smoothed_df["국면"] = smoothed_df.apply(
        lambda row: "전환기(TRAN)" if row["전환기"] else (row["확정국면"] or "미확정"),
        axis=1
    )
    return smoothed_df


# =====================================================================
# 10. 저장
# =====================================================================
def save_results(smoothed_df: pd.DataFrame, score_df: pd.DataFrame,
                 contrib_df: pd.DataFrame, monthly_df: pd.DataFrame):
    OUTPUT_PATH.parent.mkdir(parents=True, exist_ok=True)

    train_end_ts = pd.Timestamp(TRAIN_END_DATE)
    prob_cols = [c for c in smoothed_df.columns if c in PHASES]

    regime_ts = smoothed_df[["국면"]].copy()
    regime_ts["구간구분"] = [
        "추론" if d > train_end_ts else "학습"
        for d in regime_ts.index
    ]
    regime_ts.index.name = "Date"

    prob_ts = smoothed_df[prob_cols].copy()
    prob_ts.index.name = "Date"

    with pd.ExcelWriter(OUTPUT_PATH, engine="xlsxwriter",
                        date_format="yyyy-mm-dd") as writer:
        # 기존 결과 파일과 동일한 시트명 → 시각화 코드 호환
        regime_ts.to_excel(writer, sheet_name="국면_시계열")
        prob_ts.to_excel(writer, sheet_name="국면_확률")
        smoothed_df.to_excel(writer, sheet_name="국면_확률_상세")
        score_df.to_excel(writer, sheet_name="원점수")
        if not contrib_df.empty:
            contrib_df.to_excel(writer, sheet_name="지표_기여도", index=False)

        # 지표 사용 현황 (monthly_df 컬럼 기준으로 판단)
        summary = []
        for col, label, weight, dtype, *_ in INDICATORS:
            used = "O" if col in monthly_df.columns else "X (데이터 없음)"
            summary.append({"지표": label, "컬럼": col,
                             "가중치": weight, "유형": dtype, "사용여부": used})
        pd.DataFrame(summary).to_excel(writer, sheet_name="지표현황", index=False)

    print(f"\n[완료] 저장: {OUTPUT_PATH}")


# =====================================================================
# 11. 현재 국면 진단 출력
# =====================================================================
def print_current_diagnosis(smoothed_df: pd.DataFrame):
    latest = smoothed_df.iloc[-1]
    prob_cols = [c for c in smoothed_df.columns if c in PHASES]
    print("\n" + "=" * 55)
    print(f"  현재 국면 진단  ({smoothed_df.index[-1].strftime('%Y-%m')})")
    print("=" * 55)
    print(f"  확정 국면  : {latest['국면']}")
    print(f"  전환기 여부: {'예 (신호 혼재)' if latest['전환기'] else '아니오'}")
    print()
    print("  국면별 확률 (EMA 스무딩 후):")
    for phase in prob_cols:
        bar = "#" * int(latest[phase] * 30)
        print(f"    {phase:<14s} {latest[phase]*100:5.1f}%  {bar}")
    print("=" * 55)


