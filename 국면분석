# 12. 메인 파이프라인
# =====================================================================
def main():
    print("===== 국면판단 v2 시작 =====\n")

    print("[1/5] 월별 데이터 로드...")
    df = build_monthly_df()
    avail = [col for col, *_ in INDICATORS if col in df.columns]
    print(f"      전체 기간: {df.index[0].strftime('%Y-%m')} ~ "
          f"{df.index[-1].strftime('%Y-%m')}  ({len(df)}개월)")
    print(f"      사용 지표 ({len(avail)}/{len(INDICATORS)}개): "
          f"{', '.join(avail)}")

    # ── 학습 / 추론 구간 분리 ──────────────────────────────
    train_mask  = df.index <= pd.Timestamp(TRAIN_END_DATE)
    infer_mask  = df.index >= pd.Timestamp(INFER_START_DATE)
    train_end_t = int(np.where(train_mask)[0][-1]) if train_mask.any() else None

    n_train = train_mask.sum()
    n_infer = infer_mask.sum()
    print(f"\n      ┌─ 학습 구간: {df.index[0].strftime('%Y-%m')} ~ "
          f"{TRAIN_END_DATE[:7]}  ({n_train}개월) ← 백분위 기준 분포 고정")
    if n_infer > 0:
        print(f"      └─ 추론 구간: {INFER_START_DATE[:7]} ~ "
              f"{df.index[-1].strftime('%Y-%m')}  ({n_infer}개월) ← 학습 분포 기준 평가")
    else:
        print(f"      └─ 추론 구간: 없음 (현재 날짜가 {TRAIN_END_DATE} 이전)")

    print("\n[2/5] Composite Score 계산 (Blended Percentile)...")
    score_df, contrib_df = compute_phase_scores(df, train_end_t=train_end_t)
    print(f"      점수 계산 완료: {score_df.shape}")

    print("\n[3/5] Softmax → 국면 확률...")
    prob_df = compute_probabilities(score_df)

    print("[4/5] EMA 스무딩 + Confirmation Rule + Entropy 감지...")
    smoothed_df = smooth_and_confirm(prob_df)
    smoothed_df = apply_transition_flag(smoothed_df)

    # ── 구간별 국면 분포 출력 ──────────────────────────────
    print("\n  [학습 구간] 국면별 발생 월수:")
    train_regimes = smoothed_df.loc[train_mask, "국면"].value_counts()
    for regime, cnt in train_regimes.items():
        print(f"    {regime:<18s}: {cnt}개월")

    if n_infer > 0:
        print("\n  [추론 구간] 국면별 발생 월수:")
        infer_regimes = smoothed_df.loc[infer_mask, "국면"].value_counts()
        for regime, cnt in infer_regimes.items():
            print(f"    {regime:<18s}: {cnt}개월")

        # 추론 구간 각 지표의 학습 분포 대비 백분위 출력
        print("\n  [추론 구간] 현재 지표 수준 (학습 분포 기준 백분위):")
        print(f"  {'지표':<20s} {'현재값':>10s} {'백분위':>8s}  해석")
        print("  " + "-" * 60)
        for ind in INDICATORS:
            col, label, dtype = ind[0], ind[1], ind[3]
            if col not in df.columns or train_end_t is None:
                continue
            series = df[col]
            infer_rows = df.index[infer_mask]
            if infer_rows.empty:
                continue
            t_last = len(df) - 1
            val = series.iloc[t_last]
            if pd.isna(val):
                continue
            pct = blended_percentile(series, t_last,
                                     train_end_t=train_end_t) * 100
            # 방향 보정: g_i는 높을수록 나쁨 → 해석 반전
            if dtype == "g_i":
                interp = "극단적 위험" if pct > 85 else ("위험↑" if pct > 65 else
                         ("중립" if pct > 35 else ("안정" if pct > 15 else "극단적 안정")))
            elif dtype == "g_n":
                interp = "극단적 강세" if pct > 85 else ("강세" if pct > 65 else
                         ("중립" if pct > 35 else ("약세" if pct > 15 else "극단적 약세")))
            else:  # inf
                interp = "고물가" if pct > 70 else ("중립" if pct > 30 else "저물가")
            print(f"  {label:<20s} {val:>10.3f} {pct:>7.1f}%  {interp}")

    print_current_diagnosis(smoothed_df)

    print("\n[5/5] 결과 저장...")
    save_results(smoothed_df, score_df, contrib_df, df)


if __name__ == "__main__":
    sys.stdout = io.TextIOWrapper(sys.stdout.buffer, encoding="utf-8")
    sys.stderr = io.TextIOWrapper(sys.stderr.buffer, encoding="utf-8")
    main()
