def _load_fred_monthly() -> pd.DataFrame:
    """FRED 일간/월간 데이터 → 월말 기준 집계"""
    daily   = pd.read_excel(FRED_PATH, sheet_name="일간데이터",
                             index_col=0, parse_dates=True).sort_index()
    monthly = pd.read_excel(FRED_PATH, sheet_name="월간데이터",
                             index_col=0, parse_dates=True).sort_index()

    # 금 컬럼명 통일
    if "금현물가격(USD/oz)" in daily.columns and "금현물가격" not in daily.columns:
        daily = daily.rename(columns={"금현물가격(USD/oz)": "금현물가격"})

    # 심리지수 시트 (있으면 병합)
    try:
        sentiment = pd.read_excel(FRED_PATH, sheet_name="심리지수",
                                   index_col=0, parse_dates=True).sort_index()
        daily_s = sentiment.reindex(daily.index, method="ffill")
        daily   = pd.concat([daily, daily_s], axis=1)
    except Exception:
        pass

    # 일간 → 월말 평균
    daily_m = daily.resample("ME").mean()
    # 월간 데이터는 이미 월별이므로 월말 인덱스로 통일
    monthly.index = monthly.index + pd.offsets.MonthEnd(0)
    monthly_m = monthly.resample("ME").last()

    df = pd.concat([daily_m, monthly_m], axis=1)
    df = df[df.index >= START_DATE].sort_index()
    return df


def _load_index_monthly() -> pd.DataFrame:
    """지수데이터.xlsx Sheet6 → SP500 월말 가격"""
    try:
        raw = pd.read_excel(INDEX_PATH, sheet_name="Sheet6", header=None)
        col_names = raw.iloc[8, 1:].tolist()
        data = raw.iloc[14:].copy()
        data.columns = ["Date"] + col_names
        data["Date"] = pd.to_datetime(data["Date"], errors="coerce")
        data = data.dropna(subset=["Date"]).set_index("Date").sort_index()
        for c in data.columns:
            data[c] = pd.to_numeric(data[c], errors="coerce")
        rename = {"S&P 500": "SP500", "US Dollar Index": "달러인덱스DXY"}
        data = data.rename(columns=rename)
        return data[["SP500"]].resample("ME").last()
    except Exception as e:
        print(f"    [경고] 지수데이터 로드 실패: {e}")
        return pd.DataFrame()


def _load_commodity_monthly() -> tuple:
    """원자재 가격.csv → (금현물가격 월말 Series, 구리선물가격 월말 Series)"""
    if not COMMODITY_PATH.exists():
        print(f"    [경고] 원자재 가격.csv 없음 → 금/구리 데이터 없음")
        return pd.Series(dtype=float), pd.Series(dtype=float)
    try:
        df = pd.read_csv(COMMODITY_PATH, header=0, encoding="cp949")
        df.columns = ["Date", "금현물가격", "구리선물가격"]
        df["Date"] = pd.to_datetime(df["Date"], format="%m/%d/%Y", errors="coerce")
        df["금현물가격"]   = pd.to_numeric(df["금현물가격"].astype(str).str.replace(",", ""), errors="coerce")
        df["구리선물가격"] = pd.to_numeric(df["구리선물가격"].astype(str).str.replace(",", ""), errors="coerce")
        df = df.dropna(subset=["Date"]).set_index("Date").sort_index()
        gold_m   = df["금현물가격"].resample("ME").last().rename("금현물가격")
        copper_m = df["구리선물가격"].resample("ME").last().rename("구리선물가격")
        return gold_m, copper_m
    except Exception as e:
        print(f"    [경고] 원자재 가격.csv 로드 실패: {e}")
        return pd.Series(dtype=float), pd.Series(dtype=float)


