# 2. Blended Percentile 엔진  (CLAUDE.md §4-2)
# =====================================================================
def blended_percentile(series: pd.Series, t: int,
                        windows: list = BLEND_WINDOWS,
                        weights: list = BLEND_WEIGHTS,
                        train_end_t: int | None = None) -> float:
    """
    단기(36M)/중기(60M)/장기(120M) 백분위 가중 혼합.

    train_end_t 지정 시:
      - 학습 구간(t <= train_end_t): 기존과 동일, t 기준 롤링 창
      - 추론 구간(t > train_end_t) : hist_end를 train_end_t로 고정
        → 현재 값을 학습 기간 분포에 비추어 평가 (분포 오염 방지)
    반환값: 0~1
    """
    val = series.iloc[t]
    if pd.isna(val):
        return np.nan

    # 추론 구간이면 참조 분포 끝점을 학습 끝으로 고정
    hist_end = (train_end_t
                if (train_end_t is not None and t > train_end_t)
                else t)

    pcts = []
    for w in windows:
        hist = series.iloc[max(0, hist_end - w):hist_end].dropna()
        if len(hist) < 12:   # 최소 12개월 필요
            pcts.append(0.5)
            continue
        pcts.append(sp_stats.percentileofscore(hist, val, kind="rank") / 100)
    return float(np.dot(pcts, weights))


# =====================================================================
# 3. Composite Score  (CLAUDE.md §4-1)
# =====================================================================
def composite_score(series: pd.Series, t: int,
                    alpha: float = 0.50, beta: float = 0.35, gamma: float = 0.15,
                    m: int = 1,
                    train_end_t: int | None = None) -> float:
    """
    Level(α) + Momentum(β) + Acceleration(γ) 복합 백분위 스코어.
    train_end_t: blended_percentile에 전달 (추론 구간 분포 고정)
    반환값: 0~1
    """
    if t < 3:
        return np.nan
    kw = dict(train_end_t=train_end_t)
    level_pct = blended_percentile(series,             t, **kw)
    mom_pct   = blended_percentile(series.diff(m),     t, **kw)
    accel_pct = blended_percentile(series.diff(m).diff(1), t, **kw)
    vals = [level_pct, mom_pct, accel_pct]
    if any(np.isnan(v) for v in vals):
        return np.nan
    return alpha * level_pct + beta * mom_pct + gamma * accel_pct


# =====================================================================
# 4. 성장 지표 점수 매핑  (composite_pct → 4국면 점수)
# =====================================================================
def _growth_score(pct: float) -> np.ndarray:
    """
    성장 지표 복합 백분위 → [BOOM, GOLD, STAG, RECE] 점수.
    성장 지표는 주로 (BOOM+GOLD) vs (STAG+RECE) 축 분리.
    pct: 0~1, direction 보정 후 (high = 성장 강세)

    NOTE: 성장 지표 자체는 STAG vs RECE를 구분하지 않음.
    STAG/RECE 판별은 인플레이션 지표(CPI/BEI, 합산 weight ~0.25)가 담당.
    """
    if pct >= 0.80: return np.array([ 2.0,  2.0, -1.5, -2.5])
    if pct >= 0.65: return np.array([ 1.5,  1.5, -1.0, -1.5])
    if pct >= 0.50: return np.array([ 0.5,  0.5, -0.3, -0.5])
    if pct >= 0.35: return np.array([-0.5, -0.5,  0.5,  1.0])
    if pct >= 0.20: return np.array([-1.5, -1.0,  1.0,  2.0])
    return              np.array([-2.0, -1.5,  1.5,  3.0])


# =====================================================================
# 5. 물가 지표 이론 임계값 매핑  (CLAUDE.md §3-2, §4-3)
# =====================================================================
def _inflation_theory_score(col: str, raw_val: float) -> np.ndarray:
    """
    CPI YoY / BEI 5Y5Y 절대 레벨 → [BOOM, GOLD, STAG, RECE] 점수.
    물가 지표는 주로 (BOOM+STAG) vs (GOLD+RECE) 축 분리.
    """
    if col == "CPI_yoy":
        if raw_val > 5.0: return np.array([ 1.0, -2.5,  3.0, -1.5])
        if raw_val > 3.5: return np.array([ 2.0, -1.0,  1.5, -1.5])
        if raw_val > 2.0: return np.array([ 1.5,  0.5, -0.5, -1.0])
        return              np.array([-0.5,  2.0, -2.0,  0.5])

    elif col == "BEI_5Y5Y":   # CLAUDE.md §3-2 임계값 준수
        if raw_val > 2.8: return np.array([ 1.0, -2.0,  3.0, -1.5])  # 스태그 강신호
        if raw_val > 2.2: return np.array([ 2.0, -0.5,  0.5, -1.0])  # 붐 신호
        if raw_val > 1.8: return np.array([ 0.5,  2.0, -1.0, -0.5])  # 골디락스
        return              np.array([-1.5,  0.5, -2.0,  1.5])        # 침체 우려

    elif col == "PCE_yoy":    # Fed 목표 2% 기준 (CPI보다 약 0.3%p 낮음)
        if raw_val > 3.5: return np.array([ 0.5, -2.5,  3.0, -1.5])  # 스태그플레이션
        if raw_val > 2.5: return np.array([ 1.5, -0.5,  1.0, -1.5])  # 인플레 우려
        if raw_val > 1.5: return np.array([ 1.0,  2.0, -1.0, -0.5])  # 골디락스 (목표권)
        return              np.array([-0.5,  1.0, -2.0,  1.5])        # 저물가/침체 우려

    elif col == "PPI_yoy":    # 생산자물가 — CPI 3~6개월 선행
        if raw_val > 6.0: return np.array([ 0.5, -2.0,  3.5, -1.5])  # 극심한 코스트푸시
        if raw_val > 3.0: return np.array([ 1.5, -1.0,  1.5, -1.5])  # 인플레 상승 압력
        if raw_val > 1.0: return np.array([ 1.0,  2.0, -0.5, -0.5])  # 완만한 회복
        return              np.array([-1.0,  0.5, -1.5,  2.0])        # 디플레이션 압력

    return np.zeros(4)


